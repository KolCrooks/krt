# jj colocation — .jj is not tracked by git
.jj/

# Claude Code session state
.claude/

# OS — anywhere in the tree
.DS_Store
Thumbs.db

# Editor swap files — anywhere
*.swp
*.swo
*~

# Logs — anywhere
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies — anywhere (covers vscode/ and per-extension node_modules)
node_modules/

# Packaged extensions — anywhere
*.vsix

# Root-only — anchored so we don't clobber vscode/'s tracked .vscode/, dist/, out/
/.vscode/
/.idea/
/.env
/.env.local
/out/
/dist/
