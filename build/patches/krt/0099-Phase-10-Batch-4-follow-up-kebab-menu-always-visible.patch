From de5d1e95995da21ee92d9d088e958df303657a5b Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Fri, 8 May 2026 15:13:55 -0400
Subject: [PATCH] Phase 10 Batch 4 follow-up: kebab menu always visible
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Drop the hover-reveal — the kebab now stays visible at 0.6 opacity by
default and brightens to 1.0 on hover/focus. Per the same reasoning as
keeping bot-list management out of the command palette: invisible
affordances are functionally absent for users who don't already know
where to look.
---
 .../contrib/krt/browser/pr/krtPullRequestEditorPane.css  | 9 ++-------
 1 file changed, 2 insertions(+), 7 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
index 4a5ac163333..3ae439cf320 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
@@ -455,7 +455,7 @@ img.krt-pr-comment-avatar {
 	border-radius: 4px;
 	padding: 0;
 	cursor: pointer;
-	opacity: 0;
+	opacity: 0.6;
 	transition: opacity 80ms, background 80ms;
 }
 
@@ -463,13 +463,8 @@ img.krt-pr-comment-avatar {
 	font-size: 14px;
 }
 
-.krt-pr-comment:hover .krt-pr-comment-menu-btn,
-.krt-pr-comment-menu-btn:focus-visible {
-	opacity: 0.7;
-}
-
 .krt-pr-comment-menu-btn:hover,
-.krt-pr-comment:hover .krt-pr-comment-menu-btn:hover {
+.krt-pr-comment-menu-btn:focus-visible {
 	opacity: 1;
 	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.12));
 	color: var(--vscode-foreground);
-- 
2.52.0

