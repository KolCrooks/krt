From 1505d74c509e3dc79eea6cb2ef24bb9441cae120 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Tue, 5 May 2026 12:37:18 -0400
Subject: [PATCH] Phase 8: expand emoji shortcodes in PR description and
 comments
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The previous patch only ran expandEmojiShortcodes() through the
chapter-content path. PR descriptions, discussion comments, and
inline review comments still went straight to MarkdownString
unexpanded — so :rocket:, :white_check_mark:, etc. rendered as
literal :shortcode: text. Pipe all three sites through
expandEmojiShortcodes before constructing the MarkdownString.
---
 .../contrib/krt/browser/pr/krtPullRequestEditorPane.ts      | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
index 11ddcd20dd2..16af53dbbe1 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
@@ -343,7 +343,7 @@ export class KrtPullRequestEditorPane extends EditorPane {
 			bodyEl.textContent = localize('krt.pr.noDescription', "No description provided.");
 			return;
 		}
-		const md = new MarkdownString(pr.body, { isTrusted: false, supportThemeIcons: false, supportHtml: false });
+		const md = new MarkdownString(expandEmojiShortcodes(pr.body), { isTrusted: false, supportThemeIcons: false, supportHtml: false });
 		const rendered = renderMarkdown(md, {
 			actionHandler: (link) => this.openExternal(link),
 		});
@@ -433,7 +433,7 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		when.textContent = relativeTime(comment.createdAt);
 		const body = DOM.append(row, DOM.$('.krt-pr-comment-body'));
 		if (comment.body.trim()) {
-			const md = new MarkdownString(comment.body, { isTrusted: false });
+			const md = new MarkdownString(expandEmojiShortcodes(comment.body), { isTrusted: false });
 			const rendered = renderMarkdown(md, {
 				actionHandler: link => this.openExternal(link),
 			});
@@ -921,7 +921,7 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		when.textContent = relativeTime(comment.createdAt);
 		const body = DOM.append(row, DOM.$('.krt-pr-comment-body'));
 		if (comment.body.trim()) {
-			const md = new MarkdownString(comment.body, { isTrusted: false });
+			const md = new MarkdownString(expandEmojiShortcodes(comment.body), { isTrusted: false });
 			const rendered = renderMarkdown(md, { actionHandler: link => this.openExternal(link) });
 			this.bodyDisposables.add(rendered);
 			body.appendChild(rendered.element);
-- 
