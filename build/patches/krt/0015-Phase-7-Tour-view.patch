+	private renderTourMiniDiffs(parent: HTMLElement, pr: PullRequest, paths: readonly string[]): void {
+		const filesByPath = new Map<string, PullRequestFile>();
+		for (const f of this.diffFiles ?? []) {
+			filesByPath.set(f.path, f);
+		}
+		const wrap = DOM.append(parent, DOM.$('.krt-pr-tour-mini-diffs'));
+		if (this.diffFiles === undefined) {
+			const note = DOM.append(wrap, DOM.$('.krt-pr-empty'));
+			note.textContent = localize('krt.pr.tour.diffPending', "Loading file patches…");
+			if (!this.diffFilesLoading) {
+				this.loadDiffFiles(pr);
+			}
+			return;
+		}
+		for (const path of paths) {
+			const file = filesByPath.get(path);
+			const section = DOM.append(wrap, DOM.$('.krt-pr-tour-mini-section'));
+			const head = DOM.append(section, DOM.$('.krt-pr-tour-mini-head'));
+			const status = DOM.append(head, DOM.$('span.krt-pr-diff-status-dot'));
+			const headPath = DOM.append(head, DOM.$('span.krt-pr-tour-mini-path'));
+			headPath.textContent = path;
+			if (!file) {
+				status.classList.add('changed');
+				status.textContent = '·';
+				const note = DOM.append(section, DOM.$('.krt-pr-tour-mini-empty'));
+				note.textContent = localize('krt.pr.tour.fileMissing', "(file is not in the PR's changed-files list)");
+				continue;
+			}
+			status.classList.add(file.status);
+			status.textContent = statusGlyph(file.status);
+			const counts = DOM.append(head, DOM.$('span.krt-pr-tour-mini-counts'));
+			const add = DOM.append(counts, DOM.$('span.add'));
+			add.textContent = `+${file.additions}`;
+			const del = DOM.append(counts, DOM.$('span.del'));
+			del.textContent = `-${file.deletions}`;
+			const body = DOM.append(section, DOM.$('.krt-pr-tour-mini-body'));
+			if (!file.patch) {
+				const empty = DOM.append(body, DOM.$('.krt-pr-tour-mini-empty'));
+				empty.textContent = file.status === 'renamed'
+					? localize('krt.pr.diffRenameOnly', "Rename only — no content change.")
+					: localize('krt.pr.diffNoPatchAvailable', "No patch available (binary or too large).");
+				continue;
+			}
+			for (const line of parsePatch(file.patch)) {
+				const row = DOM.append(body, DOM.$('.krt-pr-diff-line'));
+				row.classList.add(line.kind);
+				const oldNo = DOM.append(row, DOM.$('span.krt-pr-diff-lineno.old'));
+				oldNo.textContent = line.oldLine !== undefined ? String(line.oldLine) : '';
+				const newNo = DOM.append(row, DOM.$('span.krt-pr-diff-lineno.new'));
+				newNo.textContent = line.newLine !== undefined ? String(line.newLine) : '';
+				const gutter = DOM.append(row, DOM.$('span.krt-pr-diff-gutter'));
+				gutter.textContent = '';
+				const content = DOM.append(row, DOM.$('span.krt-pr-diff-line-content'));
+				const prefix = line.kind === 'add' ? '+' : line.kind === 'del' ? '-' : line.kind === 'hunk' ? '' : ' ';
+				content.textContent = line.kind === 'hunk' ? line.raw : `${prefix}${line.raw}`;
+			}
+		}
+	}
+
+	private refreshTourSubheading(): void {
