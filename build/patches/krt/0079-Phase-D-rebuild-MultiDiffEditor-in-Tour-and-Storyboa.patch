+/* Phase 10/D — host for the chapter-scoped MultiDiffEditorWidget.
+ * Shorter than the main Diff sub-mode's host because chapters are
+ * usually a handful of files, not the whole PR. */
+.krt-pr-tour-mini-host {
+	position: relative;
+	min-height: 50vh;
+	max-height: calc(100vh - 280px);
+	border: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
+	border-radius: 6px;
+	overflow: hidden;
+}
+
+.krt-pr-tour-mini-cta {
+	padding: 14px 16px;
+	border: 1px dashed var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
+	border-radius: 6px;
+	color: var(--vscode-descriptionForeground);
+	font-size: 12.5px;
+	line-height: 1.5;
+}
+
