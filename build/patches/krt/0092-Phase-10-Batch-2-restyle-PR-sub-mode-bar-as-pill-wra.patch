From 42838c834e4392b5cea2370e6a30ae80f3616f2f Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Fri, 8 May 2026 14:09:46 -0400
Subject: [PATCH] Phase 10 Batch 2: restyle PR sub-mode bar as pill-wrapped
 subtabs

Replace the connected-buttons-with-dividers segmented control with the
demo's pill style: an outer track (subtle background + 1px line) holding
individually-rounded subtabs that switch to an accent-soft chip on
active. Hover state on inactive buttons stays in the
toolbar-hoverBackground range so the accent only fires on selection.
---
 .../browser/pr/krtPullRequestEditorPane.css   | 33 +++++++++++--------
 1 file changed, 19 insertions(+), 14 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
index 3348b909163..20e40846dc8 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
@@ -728,38 +728,43 @@
 	display: flex;
 	align-items: center;
 	gap: 12px;
-	padding: 4px 0 0;
+	padding: 8px 0 4px;
 }
 
+/* Pill-wrapped segmented control: matches the demo's outer track
+ * (subtle bg + line) holding individually-rounded subtabs with an
+ * accent-soft active state. */
 .krt-pr-segmented {
 	display: inline-flex;
+	gap: 2px;
+	padding: 2px;
+	background: var(--vscode-input-background, rgba(127, 127, 127, 0.06));
 	border: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
-	border-radius: 6px;
-	overflow: hidden;
+	border-radius: 7px;
 }
 
 .krt-pr-segmented-btn {
+	height: 24px;
+	padding: 0 12px;
+	border-radius: 5px;
 	background: transparent;
 	border: none;
-	padding: 5px 14px;
-	font-size: 12px;
+	font-size: 11.5px;
 	font-weight: 500;
-	color: var(--vscode-foreground);
+	color: var(--vscode-descriptionForeground, var(--vscode-foreground));
 	cursor: pointer;
 	font-family: inherit;
 }
 
-.krt-pr-segmented-btn:hover {
-	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.1));
+.krt-pr-segmented-btn:hover:not(.active) {
+	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.12));
+	color: var(--vscode-foreground);
 }
 
 .krt-pr-segmented-btn.active {
-	background: var(--vscode-button-background, rgba(80, 110, 230, 0.18));
-	color: var(--vscode-button-foreground, inherit);
-}
-
-.krt-pr-segmented-btn + .krt-pr-segmented-btn {
-	border-left: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
+	background: var(--krt-accent-soft, var(--vscode-button-background));
+	color: var(--krt-accent, var(--vscode-button-foreground));
+	box-shadow: inset 0 0 0 1px var(--krt-accent-line, transparent);
 }
 
 /* ---------- Diff body ---------- */
