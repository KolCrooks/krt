From ab27ce59fc6fcb006cb6ae2c8b6588fce613ff49 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 15:34:13 -0400
Subject: [PATCH] Phase C fix: add initialCollapsibleState setter on
 KrtPrCommentThread
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Reported: getDocumentComments fired correctly (4 threads on
k8s/rtdb/values.yaml RIGHT) but no widgets rendered. Console showed:

  TypeError: Cannot set property initialCollapsibleState of
  #<KrtPrCommentThread> which has only a getter
    at new ReviewZoneWidget (commentThreadZoneWidget.js:118)
    ...
    at CommentController.displayCommentThread (commentsController.js:921)
    at CommentController.setComments (commentsController.js:1179)

Workbench's `ReviewZoneWidget` constructor writes to
`commentThread.initialCollapsibleState` directly. The upstream
`CommentThread` interface declares it as a non-readonly property,
but my implementation only had a getter — the prior Phase 9.5
attempt had latched the initial state via a setter on
`collapsibleState`, which doesn't help here because the workbench
sets `initialCollapsibleState` itself (not collapsibleState first).

Added a setter that fires `onDidChangeInitialCollapsibleState` on
change, matching `MainThreadCommentThread`'s shape.

The cascading "Cannot read properties of undefined (reading
'layout')" error was a downstream effect of the failed
ReviewZoneWidget construction — the widget partially-initialised
state crashed on the next layout fire. Fixing the constructor
fixes that too.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 .../contrib/krt/browser/pr/krtPrCommentThread.ts      | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
index b5244ccdc78..e13979cc665 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
@@ -82,6 +82,17 @@ export class KrtPrCommentThread implements CommentThread<IRange> {
 
 	private _initialCollapsibleState: CommentThreadCollapsibleState | undefined;
 	get initialCollapsibleState(): CommentThreadCollapsibleState | undefined { return this._initialCollapsibleState; }
+	set initialCollapsibleState(value: CommentThreadCollapsibleState | undefined) {
+		// `ReviewZoneWidget`'s constructor writes to this directly. The
+		// upstream `CommentThread` interface declares it as a non-
+		// readonly property, so implementers (us included) must allow
+		// the assignment. Latching also fires the change event so
+		// downstream listeners react.
+		if (value !== this._initialCollapsibleState) {
+			this._initialCollapsibleState = value;
+			this._onDidChangeInitialCollapsibleState.fire(value);
+		}
+	}
 	private readonly _onDidChangeInitialCollapsibleState = new Emitter<CommentThreadCollapsibleState | undefined>();
 	readonly onDidChangeInitialCollapsibleState: Event<CommentThreadCollapsibleState | undefined> = this._onDidChangeInitialCollapsibleState.event;
 
