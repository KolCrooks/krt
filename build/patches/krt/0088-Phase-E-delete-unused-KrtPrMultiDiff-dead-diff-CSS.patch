-
-import { Disposable, DisposableStore, IDisposable, IReference } from '../../../../../base/common/lifecycle.js';
-import { observableValue, ValueWithChangeEventFromObservable } from '../../../../../base/common/observable.js';
-import { URI } from '../../../../../base/common/uri.js';
-import { MultiDiffEditorWidget } from '../../../../../editor/browser/widget/multiDiffEditor/multiDiffEditorWidget.js';
-import { MultiDiffEditorViewModel } from '../../../../../editor/browser/widget/multiDiffEditor/multiDiffEditorViewModel.js';
-import { IDocumentDiffItem, IMultiDiffEditorModel } from '../../../../../editor/browser/widget/multiDiffEditor/model.js';
-import { IResourceLabel, IWorkbenchUIElementFactory } from '../../../../../editor/browser/widget/multiDiffEditor/workbenchUIElementFactory.js';
-import { RefCounted } from '../../../../../editor/browser/widget/diffEditor/utils.js';
-import { IResolvedTextEditorModel, ITextModelService } from '../../../../../editor/common/services/resolverService.js';
-import { IInstantiationService } from '../../../../../platform/instantiation/common/instantiation.js';
-import { IKrtGitService } from '../../../../../platform/krt/common/krtGit.js';
-import { ILogService } from '../../../../../platform/log/common/log.js';
-import { PullRequest, PullRequestFile } from '../../../../../platform/krt/common/krt.js';
-import { ResourceLabel } from '../../../../browser/labels.js';
-import { encodeKrtGit } from '../workspace/krtGitContentProvider.js';
-import { KrtWorkspace } from '../workspace/krtWorkspaceRegistry.js';
-import { IKrtPrCommentController } from './krtPrCommentController.js';
-
-/**
- * Phase 10/B — owns the embedded `MultiDiffEditorWidget` for KRT's
- * Diff sub-mode. One instance per render. The widget self-virtualises
- * the file list and self-scrolls internally; KRT's job is to feed it
- * the right `(originalUri, modifiedUri)` pairs and let the workbench's
- * normal model resolution handle everything else (LSP activation on
- * the modified `file://` URI, content via `git show` for the
- * `krt-git://` original, etc.).
- *
- * URI strategy:
- *   - **modifiedUri** = `file://${workspace.folderPath}/${path}` for any
- *     file whose `status !== 'removed'`. The workbench loads this via
- *     `IFileService` through its normal file-loading path → language
- *     extensions activate.
- *   - **originalUri** = `krt-git://${workspace}/${baseSha}/${previousPath}`
- *     for any file whose `status !== 'added'`. The Phase 8.6
- *     `KrtGitContentProvider` shells `git show baseSha:path` for the
- *     content. Read-only, no LSP — but the base side rarely needs it.
- *
- * Strict gate: callers should only construct this when the workspace
- * is registered AND the working tree's HEAD matches `pr.head.sha`.
- * Without that, the `file://` content would reflect a different
- * commit and the diff would lie. The gate lives in the editor pane
- * because the pane already tracks `isCheckedOut`.
- */
-export class KrtPrMultiDiff extends Disposable {
-
-	private readonly widget: MultiDiffEditorWidget;
-	private currentModel: { dispose(): void } | undefined;
-	/**
-	 * The widget's `setViewModel` doesn't take ownership — it just
-	 * stores a reference. The previous viewModel still holds
-	 * `createNewRef`-style refs to the previous diff items, keeping
-	 * their `itemStore`s alive. Track the current viewModel so we can
-	 * dispose it on swap (and on full disposal). Without this the
-	 * GC-based leak tracker logs a `[LEAKED DISPOSABLE]` warning
-	 * pointing at every `new DisposableStore()` we create per file.
-	 */
-	private currentViewModel: MultiDiffEditorViewModel | undefined;
-	private readonly uriRegistrations = this._register(new DisposableStore());
-
-	constructor(
-		container: HTMLElement,
-		@IInstantiationService private readonly instantiationService: IInstantiationService,
-		@ITextModelService private readonly textModelService: ITextModelService,
-		@ILogService private readonly logService: ILogService,
-		@IKrtPrCommentController private readonly commentController: IKrtPrCommentController,
-		@IKrtGitService private readonly gitService: IKrtGitService,
-	) {
-		super();
-		const factory = this.instantiationService.createInstance(KrtMultiDiffUIElementFactory);
-		this.widget = this._register(this.instantiationService.createInstance(
-			MultiDiffEditorWidget,
-			container,
-			factory,
-		));
-	}
-
-	/**
-	 * Build a `MultiDiffEditorViewModel` from the PR's file list and
-	 * push it into the widget. Resolves each side via
-	 * `ITextModelService.createModelReference` so the workbench's
-	 * normal lifetime/sharing rules apply. References live until the
-	 * model is replaced or this view disposes.
-	 *
-	 * Per-side resolution is independent. If the original side fails
-	 * (e.g. GitHub flagged the file `renamed` from a path the local
-	 * clone of the base SHA doesn't have, or the base SHA simply
-	 * doesn't fetch the file), the file still renders with an empty
-	 * original — same visual as an `added` file. Same for modified
-	 * failure → empty modified, looks like `removed`. Only when BOTH
-	 * sides fail does the file get skipped entirely.
-	 */
-	async setPullRequest(pr: PullRequest, files: readonly PullRequestFile[], workspace: KrtWorkspace, opts: { renderSideBySide: boolean }): Promise<void> {
-		const previous = this.currentModel;
-		this.uriRegistrations.clear();
-
-		// Compute the merge base of the PR's two refs. GitHub diffs the
-		// PR against the merge base, NOT `pr.base.sha` directly:
-		// `pr.base.sha` is the *current* tip of the target branch, so
-		// when the target has moved forward since the PR was opened,
-		// diffing against it shows every commit that landed on target
-		// as a "reverted" change in the PR. Merge base = common
-		// ancestor = the SHA the PR's diff should anchor on.
-		// Fall back to `pr.base.sha` if `git merge-base` fails (the
-		// per-side resolver will warn on each file in that case).
-		let baseSha = pr.base.sha;
-		try {
-			baseSha = await this.gitService.getMergeBase(workspace.folderPath, pr.base.sha, pr.head.sha);
-		} catch (err) {
-			this.logService.warn(
-				`[krt] multi-diff: git merge-base ${pr.base.sha.slice(0, 7)} ${pr.head.sha.slice(0, 7)} failed in ${workspace.folderPath} — falling back to pr.base.sha`,
-				err,
-			);
-		}
-		if (this._store.isDisposed) {
-			return;
-		}
-
-		const items: RefCounted<IDocumentDiffItem>[] = [];
-		for (const file of files) {
-			const itemStore = new DisposableStore();
-			const previousPath = file.previousPath ?? file.path;
-			const originalUri = file.status !== 'added'
-				? encodeKrtGit(workspace.folderUri, workspace.folderPath, baseSha, previousPath)
-				: undefined;
-			const modifiedUri = file.status !== 'removed'
-				? URI.joinPath(URI.file(workspace.folderPath), file.path)
-				: undefined;
-
-			// Per-side resolution. `Promise.allSettled` so a one-sided
-			// rejection doesn't leak the other side's reference.
-			const [originalSettled, modifiedSettled] = await Promise.allSettled([
-				originalUri ? this.textModelService.createModelReference(originalUri) : Promise.resolve(undefined),
-				modifiedUri ? this.textModelService.createModelReference(modifiedUri) : Promise.resolve(undefined),
-			]);
-
-			let original: IReference<IResolvedTextEditorModel> | undefined;
-			let modified: IReference<IResolvedTextEditorModel> | undefined;
-			if (originalSettled.status === 'fulfilled') {
-				original = originalSettled.value;
-			} else {
-				this.logService.warn(`[krt] multi-diff: ${file.path} (base side) — ${originalSettled.reason instanceof Error ? originalSettled.reason.message : originalSettled.reason}`);
-			}
-			if (modifiedSettled.status === 'fulfilled') {
-				modified = modifiedSettled.value;
-			} else {
-				this.logService.warn(`[krt] multi-diff: ${file.path} (head side) — ${modifiedSettled.reason instanceof Error ? modifiedSettled.reason.message : modifiedSettled.reason}`);
-			}
-
-			if (this._store.isDisposed) {
-				original?.dispose();
-				modified?.dispose();
-				itemStore.dispose();
-				return;
-			}
-
-			// Both sides failed — nothing to render. Only happens when
-			// the file is genuinely missing on both sides; one-sided
-			// failures fall through with the surviving side.
-			if (!original && !modified) {
-				itemStore.dispose();
-				continue;
-			}
-
-			if (original) { itemStore.add(original); }
-			if (modified) { itemStore.add(modified); }
-
-			// Phase 10/C — register URIs with the comment controller so
-			// it can fan review comments out to the right side and so
-			// the native `+` glyph anchors back to the right
-			// `(prUrl, side, path)` tuple on click. LEFT comments
-			// anchor at `previousPath` (matters on rename); RIGHT at
-			// `path`. Only register sides that resolved — registering a
-			// URI we couldn't load would leak into the panel as a
-			// thread the user can never reach.
-			if (original && originalUri) {
-				this.uriRegistrations.add(this.commentController.registerDiffUri(originalUri, {
-					prUrl: pr.url,
-					headSha: pr.head.sha,
-					side: 'LEFT',
-					path: previousPath,
-				}));
-			}
-			if (modified && modifiedUri) {
-				this.uriRegistrations.add(this.commentController.registerDiffUri(modifiedUri, {
-					prUrl: pr.url,
-					headSha: pr.head.sha,
-					side: 'RIGHT',
-					path: file.path,
-				}));
-			}
-
-			const item: IDocumentDiffItem = {
-				original: original?.object.textEditorModel,
-				modified: modified?.object.textEditorModel,
-				options: {
-					readOnly: true,
-					originalEditable: false,
-					renderSideBySide: opts.renderSideBySide,
-					hideUnchangedRegions: { enabled: true, contextLineCount: 3, minimumLineCount: 4 },
-				},
-			};
-			items.push(RefCounted.createOfNonDisposable(item, itemStore));
-		}
-
-		if (this._store.isDisposed) {
-			for (const item of items) { item.dispose(); }
-			return;
-		}
-
-		const documents = observableValue<readonly RefCounted<IDocumentDiffItem>[] | 'loading'>('krt.pr.multiDiff.documents', items);
-		const model: IMultiDiffEditorModel & IDisposable = {
-			documents: new ValueWithChangeEventFromObservable(documents),
-			dispose: () => {
-				for (const item of items) { item.dispose(); }
-			},
-		};
-
-		const vm = this.widget.createViewModel(model);
-		this.widget.setViewModel(vm);
-		const previousViewModel = this.currentViewModel;
-		this.currentViewModel = vm;
-		this.currentModel = model;
-
-		// Drop the previous viewModel + model after the swap so the
-		// widget never holds a destroyed text model. The viewModel
-		// owns its own `createNewRef` against each item; if we don't
-		// dispose it, the previous items' refs never reach 0 and
-		// their `itemStore`s leak. (Mirrors the pattern in upstream's
-		// `MultiDiffEditor.clearInput`.)
-		previousViewModel?.dispose();
-		previous?.dispose();
-
-		// Phase 10/C — kick the comment controller's data-provider
-		// registration so the editors that just mounted via
-		// `setViewModel` trigger their initial compute. Their
-		// `editor.contrib.review` is `AfterFirstRender` (max ~50ms
-		// after model attach) and only computes via the comment
-		// service events; firing them while no editor was listening
-		// (controller registers eagerly at singleton init) means the
-		// new editors miss the data. 150ms is comfortably past the
-		// 50ms `AfterFirstRender` idle timeout.
-		setTimeout(() => {
-			if (this._store.isDisposed) {
-				return;
-			}
-			this.commentController.bumpDataProvider();
-		}, 150);
-	}
-
-	revealFile(modifiedUri: URI | undefined, originalUri: URI | undefined): void {
-		this.widget.reveal({ modified: modifiedUri, original: originalUri }, { highlight: false });
-	}
-
-	override dispose(): void {
-		this.widget.setViewModel(undefined);
-		this.currentViewModel?.dispose();
-		this.currentViewModel = undefined;
-		this.currentModel?.dispose();
-		this.currentModel = undefined;
-		super.dispose();
-	}
-}
-
