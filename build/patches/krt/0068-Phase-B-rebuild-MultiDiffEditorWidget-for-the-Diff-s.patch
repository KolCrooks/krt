+import { Disposable, DisposableStore, IDisposable, IReference } from '../../../../../base/common/lifecycle.js';
+import { observableValue, ValueWithChangeEventFromObservable } from '../../../../../base/common/observable.js';
+import { URI } from '../../../../../base/common/uri.js';
+import { MultiDiffEditorWidget } from '../../../../../editor/browser/widget/multiDiffEditor/multiDiffEditorWidget.js';
+import { IDocumentDiffItem, IMultiDiffEditorModel } from '../../../../../editor/browser/widget/multiDiffEditor/model.js';
+import { IResourceLabel, IWorkbenchUIElementFactory } from '../../../../../editor/browser/widget/multiDiffEditor/workbenchUIElementFactory.js';
+import { RefCounted } from '../../../../../editor/browser/widget/diffEditor/utils.js';
+import { IResolvedTextEditorModel, ITextModelService } from '../../../../../editor/common/services/resolverService.js';
+import { IInstantiationService } from '../../../../../platform/instantiation/common/instantiation.js';
+import { ILogService } from '../../../../../platform/log/common/log.js';
+import { PullRequest, PullRequestFile } from '../../../../../platform/krt/common/krt.js';
+import { ResourceLabel } from '../../../../browser/labels.js';
+import { encodeKrtGit } from '../workspace/krtGitContentProvider.js';
+import { KrtWorkspace } from '../workspace/krtWorkspaceRegistry.js';
+
+/**
+ * Phase 10/B — owns the embedded `MultiDiffEditorWidget` for KRT's
+ * Diff sub-mode. One instance per render. The widget self-virtualises
+ * the file list and self-scrolls internally; KRT's job is to feed it
+ * the right `(originalUri, modifiedUri)` pairs and let the workbench's
+ * normal model resolution handle everything else (LSP activation on
+ * the modified `file://` URI, content via `git show` for the
+ * `krt-git://` original, etc.).
+ *
+ * URI strategy:
+ *   - **modifiedUri** = `file://${workspace.folderPath}/${path}` for any
+ *     file whose `status !== 'removed'`. The workbench loads this via
+ *     `IFileService` through its normal file-loading path → language
+ *     extensions activate.
+ *   - **originalUri** = `krt-git://${workspace}/${baseSha}/${previousPath}`
+ *     for any file whose `status !== 'added'`. The Phase 8.6
+ *     `KrtGitContentProvider` shells `git show baseSha:path` for the
+ *     content. Read-only, no LSP — but the base side rarely needs it.
+ *
+ * Strict gate: callers should only construct this when the workspace
+ * is registered AND the working tree's HEAD matches `pr.head.sha`.
+ * Without that, the `file://` content would reflect a different
+ * commit and the diff would lie. The gate lives in the editor pane
+ * because the pane already tracks `isCheckedOut`.
+ */
+export class KrtPrMultiDiff extends Disposable {
+
+	private readonly widget: MultiDiffEditorWidget;
+	private currentModel: { dispose(): void } | undefined;
+
+	constructor(
+		container: HTMLElement,
+		@IInstantiationService private readonly instantiationService: IInstantiationService,
+		@ITextModelService private readonly textModelService: ITextModelService,
+		@ILogService private readonly logService: ILogService,
+	) {
+		super();
+		const factory = this.instantiationService.createInstance(KrtMultiDiffUIElementFactory);
+		this.widget = this._register(this.instantiationService.createInstance(
+			MultiDiffEditorWidget,
+			container,
+			factory,
+		));
+	}
+
+	/**
+	 * Build a `MultiDiffEditorViewModel` from the PR's file list and
+	 * push it into the widget. Resolves each side via
+	 * `ITextModelService.createModelReference` so the workbench's
+	 * normal lifetime/sharing rules apply. References live until the
+	 * model is replaced or this view disposes.
+	 *
+	 * Files whose resolution fails on either side (e.g. the base SHA
+	 * isn't fetched locally) get skipped with a warning log — the
+	 * remaining files still render. A more nuanced "couldn't load
+	 * this file's base" UI can land in a polish pass.
+	 */
+	async setPullRequest(pr: PullRequest, files: readonly PullRequestFile[], workspace: KrtWorkspace): Promise<void> {
+		const previous = this.currentModel;
+
+		const items: RefCounted<IDocumentDiffItem>[] = [];
+		for (const file of files) {
+			const itemStore = new DisposableStore();
+			const previousPath = file.previousPath ?? file.path;
+			const originalUri = file.status !== 'added'
+				? encodeKrtGit(workspace.folderUri, pr.base.sha, previousPath)
+				: undefined;
+			const modifiedUri = file.status !== 'removed'
+				? URI.joinPath(URI.file(workspace.folderPath), file.path)
+				: undefined;
+
+			let original: IReference<IResolvedTextEditorModel> | undefined;
+			let modified: IReference<IResolvedTextEditorModel> | undefined;
+			try {
+				[original, modified] = await Promise.all([
+					originalUri ? this.textModelService.createModelReference(originalUri) : undefined,
+					modifiedUri ? this.textModelService.createModelReference(modifiedUri) : undefined,
+				]);
+			} catch (err) {
+				this.logService.warn(`[krt] multi-diff: skipping ${file.path} — model resolution failed`, err);
+				original?.dispose();
+				modified?.dispose();
+				itemStore.dispose();
+				continue;
+			}
+
+			if (this._store.isDisposed) {
+				original?.dispose();
+				modified?.dispose();
+				itemStore.dispose();
+				return;
+			}
+
+			if (original) { itemStore.add(original); }
+			if (modified) { itemStore.add(modified); }
+
+			const item: IDocumentDiffItem = {
+				original: original?.object.textEditorModel,
+				modified: modified?.object.textEditorModel,
+				options: {
+					readOnly: true,
+					originalEditable: false,
+					renderSideBySide: true,
+					hideUnchangedRegions: { enabled: true, contextLineCount: 3, minimumLineCount: 4 },
+				},
+			};
+			items.push(RefCounted.createOfNonDisposable(item, itemStore));
+		}
+
+		if (this._store.isDisposed) {
+			for (const item of items) { item.dispose(); }
+			return;
+		}
+
+		const documents = observableValue<readonly RefCounted<IDocumentDiffItem>[] | 'loading'>('krt.pr.multiDiff.documents', items);
+		const model: IMultiDiffEditorModel & IDisposable = {
+			documents: new ValueWithChangeEventFromObservable(documents),
+			dispose: () => {
+				for (const item of items) { item.dispose(); }
+			},
+		};
+
+		const vm = this.widget.createViewModel(model);
+		this.widget.setViewModel(vm);
+		this.currentModel = model;
+
+		// Drop the previous model after the swap so the widget never
+		// holds a destroyed text model. (Mirrors the pattern in
+		// upstream's `MultiDiffEditor.clearInput`.)
+		previous?.dispose();
+	}
+
+	revealFile(modifiedUri: URI | undefined, originalUri: URI | undefined): void {
+		this.widget.reveal({ modified: modifiedUri, original: originalUri }, { highlight: false });
+	}
+
+	override dispose(): void {
+		this.widget.setViewModel(undefined);
+		this.currentModel?.dispose();
+		this.currentModel = undefined;
+		super.dispose();
+	}
+}
+
+/**
+ * Tiny `IWorkbenchUIElementFactory` impl — the widget asks us to
+ * create file labels for its per-item header. Mirrors upstream's
+ * private `WorkbenchUIElementFactory` in `multiDiffEditor.ts`.
+ */
+class KrtMultiDiffUIElementFactory implements IWorkbenchUIElementFactory {
+	constructor(
+		@IInstantiationService private readonly instantiationService: IInstantiationService,
+	) { }
+
+	createResourceLabel(element: HTMLElement): IResourceLabel {
+		const label = this.instantiationService.createInstance(ResourceLabel, element, {});
+		return {
+			setUri: (uri, options = {}) => {
+				if (!uri) {
+					label.element.clear();
+				} else {
+					label.element.setFile(uri, { strikethrough: options.strikethrough });
+				}
+			},
+			dispose: () => label.dispose(),
+		};
+	}
+}
