+/* Phase 10/B host for the embedded MultiDiffEditorWidget. The widget
+ * virtualises its file list and self-scrolls internally, so the host
+ * needs an explicit height. min-height anchors the bottom of the
+ * viewport on tall pages without forcing a layout when the user has
+ * something else above; max-height caps it on short viewports so the
+ * widget stays within the pane. */
+.krt-pr-multidiff-host {
+	position: relative;
+	min-height: 70vh;
+	max-height: calc(100vh - 200px);
+	border: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
+	border-radius: 6px;
+	overflow: hidden;
+}
+
+/* CTA shown when the diff is gated (no workspace registered, or the
+ * working tree isn't on the PR head). Mirrors the Search overlay's
+ * empty-state look. */
+.krt-pr-diff-cta {
+	display: flex;
+	flex-direction: column;
+	gap: 10px;
+	align-items: flex-start;
+	padding: 24px;
+	border: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
+	border-radius: 6px;
+	background: var(--vscode-editor-background);
+}
+
+.krt-pr-diff-cta-heading {
+	font-size: 14px;
+	font-weight: 600;
+}
+
+.krt-pr-diff-cta-body {
+	font-size: 12.5px;
+	color: var(--vscode-descriptionForeground);
+	max-width: 60ch;
+	line-height: 1.55;
+}
+
+.krt-pr-diff-cta-btn {
+	font: inherit;
+	font-size: 12px;
+	font-weight: 500;
+	background: var(--krt-accent, var(--vscode-button-background));
+	color: var(--vscode-button-foreground, white);
+	border: none;
+	border-radius: 4px;
+	padding: 6px 14px;
+	cursor: pointer;
+}
+
+.krt-pr-diff-cta-btn:hover {
+	background: var(--krt-accent-2, var(--vscode-button-hoverBackground));
+}
+
 .krt-pr-diff-tree {
 	display: flex;
 	flex-direction: column;
