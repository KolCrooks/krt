From 3577f60e9e230f1d1aae070cdc62a15cfe91cd06 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Tue, 5 May 2026 10:54:05 -0400
Subject: [PATCH] Phase 8: route long edges over a top rail to avoid crossing
 nodes

Multi-tier edges (those spanning two or more tier columns) now
route through a dedicated horizontal track above all node bodies
instead of cutting straight through whichever intermediate node
happens to sit on the path.

For each edge whose source-tier and target-tier differ by 2+:
  source.right -> up channel after source -> across in unique
  top-rail track -> down channel before target -> target.left

Each long edge gets its own y-track in the reserved top-rail
zone so multi-tier edges don't overlap each other either.
Adjacent-tier (single-bend) routing is unchanged.
---
 .../krt/browser/ai/krtStoryboardLayout.ts     | 124 ++++++++++++++++--
 1 file changed, 112 insertions(+), 12 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts b/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
index d8bdae99b04..9907809c7ac 100644
--- a/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
+++ b/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
@@ -99,13 +99,34 @@ export function layoutStoryboard(
 		return Math.max(max, h);
 	}, 0);
 
+	// Count multi-tier edges so we can reserve enough space above
+	// the graph for their routing tracks. Each multi-tier edge gets
+	// a unique horizontal channel above all node bodies — this is
+	// what keeps long edges from cutting through intermediate nodes.
+	let multiTierEdgeCount = 0;
+	for (const c of chapters) {
+		const targetTier = tiers.get(c.id) ?? 0;
+		for (const dep of deps.get(c.id) ?? []) {
+			const sourceTier = tiers.get(dep) ?? 0;
+			if (targetTier - sourceTier >= 2) {
+				multiTierEdgeCount++;
+			}
+		}
+	}
+	const trackSpacing = 14;
+	const trackMargin = 16;
+	const topRailHeight = multiTierEdgeCount > 0
+		? trackMargin + multiTierEdgeCount * trackSpacing + trackMargin
+		: 0;
+
 	const nodes: StoryboardNode[] = [];
 	const positions = new Map<string, StoryboardNode>();
 	for (let t = 0; t < tierCount; t++) {
 		const column = byTier[t];
 		const columnHeight = column.length * nodeHeight + Math.max(0, column.length - 1) * rowGap;
-		// Centre the column vertically against the tallest column.
-		const yOffset = padding + (tallest - columnHeight) / 2;
+		// Centre the column vertically against the tallest column,
+		// shifted down by the reserved top-rail space.
+		const yOffset = padding + topRailHeight + (tallest - columnHeight) / 2;
 		for (let i = 0; i < column.length; i++) {
 			const id = column[i];
 			const node: StoryboardNode = {
@@ -121,12 +142,23 @@ export function layoutStoryboard(
 		}
 	}
 
-	const totalHeight = tallest + padding * 2;
+	const totalHeight = tallest + padding * 2 + topRailHeight;
 	const totalWidth = tierCount === 0
 		? padding * 2
 		: padding * 2 + tierCount * nodeWidth + Math.max(0, tierCount - 1) * columnGap;
 
-	const edges = routeEdges(chapters, deps, positions, cornerRadius);
+	const edges = routeEdges(
+		chapters,
+		deps,
+		tiers,
+		positions,
+		cornerRadius,
+		padding,
+		trackMargin,
+		trackSpacing,
+		nodeWidth,
+		columnGap,
+	);
 	return { nodes, edges, width: totalWidth, height: totalHeight };
 }
 
@@ -171,8 +203,14 @@ function assignTiers(
 function routeEdges(
 	chapters: readonly Chapter[],
 	deps: Map<string, string[]>,
+	tiers: Map<string, number>,
 	positions: Map<string, StoryboardNode>,
 	cornerRadius: number,
+	padding: number,
+	trackMargin: number,
+	trackSpacing: number,
+	nodeWidth: number,
+	columnGap: number,
 ): StoryboardEdge[] {
 	const incoming = new Map<string, string[]>();
 	const outgoing = new Map<string, string[]>();
@@ -200,7 +238,15 @@ function routeEdges(
 		return top + height * (0.3 + (index / Math.max(1, count - 1)) * 0.4);
 	};
 
+	// X-coordinate of the vertical channel inside the gap between
+	// tier `t` and tier `t + 1`. Long edges enter the rail through
+	// the channel after their source and exit through the channel
+	// before their target, so they never cross tiers in-between.
+	const channelX = (t: number): number =>
+		padding + (t + 1) * nodeWidth + t * columnGap + columnGap / 2;
+
 	const edges: StoryboardEdge[] = [];
+	let multiTierIdx = 0;
 	for (const c of chapters) {
 		const ds = deps.get(c.id) ?? [];
 		const inList = incoming.get(c.id) ?? [];
@@ -208,11 +254,13 @@ function routeEdges(
 		if (!target) {
 			continue;
 		}
+		const targetTier = tiers.get(c.id) ?? 0;
 		for (const dep of ds) {
 			const source = positions.get(dep);
 			if (!source) {
 				continue;
 			}
+			const sourceTier = tiers.get(dep) ?? 0;
 			const outList = outgoing.get(dep) ?? [];
 			const sourceIdx = outList.indexOf(c.id);
 			const targetIdx = inList.indexOf(dep);
@@ -220,20 +268,72 @@ function routeEdges(
 			const sy = portY(outList.length, sourceIdx, source.y, source.height);
 			const tx = target.x;
 			const ty = portY(inList.length, targetIdx, target.y, target.height);
-			const midX = sx + Math.max(28, (tx - sx) / 2);
 			const r = cornerRadius;
 			let path: string;
-			if (Math.abs(sy - ty) < 1) {
-				path = `M ${sx} ${sy} L ${tx} ${ty}`;
-			} else if (ty > sy) {
-				path = `M ${sx} ${sy} L ${midX - r} ${sy} Q ${midX} ${sy} ${midX} ${sy + r} L ${midX} ${ty - r} Q ${midX} ${ty} ${midX + r} ${ty} L ${tx} ${ty}`;
+			let labelX: number;
+			let labelY: number;
+
+			const tierSpan = targetTier - sourceTier;
+			if (tierSpan >= 2) {
+				// Multi-tier edge — route up to the top rail, across,
+				// and back down. Each long edge gets its own y-track
+				// so they don't overlap each other either.
+				const railY = trackMargin + multiTierIdx * trackSpacing;
+				multiTierIdx++;
+				const x1 = channelX(sourceTier);   // gap right after source tier
+				const x2 = channelX(targetTier - 1); // gap right before target tier
+				path = buildRailPath(sx, sy, x1, x2, railY, tx, ty, r);
+				labelX = (x1 + x2) / 2;
+				labelY = railY - 8;
 			} else {
-				path = `M ${sx} ${sy} L ${midX - r} ${sy} Q ${midX} ${sy} ${midX} ${sy - r} L ${midX} ${ty + r} Q ${midX} ${ty} ${midX + r} ${ty} L ${tx} ${ty}`;
+				// Adjacent-tier edge — single bend through the gap.
+				const midX = sx + Math.max(28, (tx - sx) / 2);
+				if (Math.abs(sy - ty) < 1) {
+					path = `M ${sx} ${sy} L ${tx} ${ty}`;
+				} else if (ty > sy) {
+					path = `M ${sx} ${sy} L ${midX - r} ${sy} Q ${midX} ${sy} ${midX} ${sy + r} L ${midX} ${ty - r} Q ${midX} ${ty} ${midX + r} ${ty} L ${tx} ${ty}`;
+				} else {
+					path = `M ${sx} ${sy} L ${midX - r} ${sy} Q ${midX} ${sy} ${midX} ${sy - r} L ${midX} ${ty + r} Q ${midX} ${ty} ${midX + r} ${ty} L ${tx} ${ty}`;
+				}
+				labelX = midX;
+				labelY = Math.abs(sy - ty) < 1 ? sy - 8 : (sy + ty) / 2;
 			}
-			const labelX = midX;
-			const labelY = Math.abs(sy - ty) < 1 ? sy - 8 : (sy + ty) / 2;
+
 			edges.push({ from: dep, to: c.id, path, labelX, labelY });
 		}
 	}
 	return edges;
 }
+
+/**
+ * Build the SVG `d` attribute for a multi-tier edge that goes:
+ *   source.right -> up to railY -> across -> down to target.left
+ * with rounded corners. Both vertical segments go upward (railY
+ * sits above all node bodies) so the maths is symmetric.
+ */
+function buildRailPath(
+	sx: number,
+	sy: number,
+	x1: number,
+	x2: number,
+	railY: number,
+	tx: number,
+	ty: number,
+	r: number,
+): string {
+	// Direction from sy to railY is upward; from railY to ty is
+	// downward. With rounded Q corners we step in the relevant
+	// direction by r before/after the corner point.
+	return [
+		`M ${sx} ${sy}`,
+		`L ${x1 - r} ${sy}`,
+		`Q ${x1} ${sy} ${x1} ${sy - r}`,
+		`L ${x1} ${railY + r}`,
+		`Q ${x1} ${railY} ${x1 + r} ${railY}`,
+		`L ${x2 - r} ${railY}`,
+		`Q ${x2} ${railY} ${x2} ${railY + r}`,
+		`L ${x2} ${ty - r}`,
+		`Q ${x2} ${ty} ${x2 + r} ${ty}`,
+		`L ${tx} ${ty}`,
+	].join(' ');
+}
