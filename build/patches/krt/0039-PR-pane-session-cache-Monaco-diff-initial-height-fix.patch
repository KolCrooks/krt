From 2962e524530dedce45b1cee82195275eccb6e349 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 13:06:46 -0400
Subject: [PATCH] PR pane: session cache + Monaco diff initial-height fix
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Two related polish items the user hit on a real review session:

1. Reopening a PR re-shelled `gh api` every time, even within seconds
   of the previous open. Added a session-scoped LRU map keyed on PR
   url with a 5-minute TTL and 20-entry cap (krtPrCache.ts). setInput
   short-circuits on cache hit, seeding sub-resources (files, review
   comments, activity) so their lazy loaders skip too. Refresh button
   and comment posts (issue + review) invalidate the entry so the
   next reopen re-fetches.

2. The Monaco diff was rendering blank — `getContentHeight()` returns
   0 until the inner editors layout, but with `automaticLayout: false`
   and a 0-height container they never lay out, so getContentHeight
   stays 0 forever. Switched the initial container height to an
   estimate from the head model's line count (lineCount * 19 + 24),
   capped at MAX_HEIGHT_PX, and call `widget.layout()` immediately so
   the editors lay out at least once. `waitForDiff().then(...)` then
   refines via `layoutToContent` once the diff settles, and
   `onDidContentSizeChange` keeps it in sync afterwards.
---
 .../contrib/krt/browser/pr/krtMonacoDiff.ts   | 25 ++++-
 .../contrib/krt/browser/pr/krtPrCache.ts      | 98 +++++++++++++++++++
 .../browser/pr/krtPullRequestEditorPane.ts    | 44 ++++++++-
 3 files changed, 163 insertions(+), 4 deletions(-)
 create mode 100644 src/vs/workbench/contrib/krt/browser/pr/krtPrCache.ts

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
index b5a8b869931..55eaae48eee 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
@@ -72,7 +72,13 @@ export class KrtMonacoDiffView extends Disposable {
 		super();
 
 		this.container = DOM.append(parent, DOM.$('.krt-pr-diff-monaco'));
-		this.container.style.height = '0px';
+		// Start with a generous-ish placeholder height so the inner code
+		// editors actually render their first frame. With
+		// `automaticLayout: false` and a 0-height container, Monaco's
+		// `getContentHeight()` stays 0 forever and `layoutToContent`
+		// can't recover. Real height is computed below from the head
+		// model's line count, then refined post-`waitForDiff()`.
+		this.container.style.height = '240px';
 
 		this.widget = this._register(instantiationService.createInstance(
 			DiffEditorWidget,
@@ -198,8 +204,21 @@ export class KrtMonacoDiffView extends Disposable {
 		// Leave them in `IModelService` for the workbench's lifetime; they
 		// share a URI per (owner, repo, sha, path) so memory stays bounded.
 
-		// Initial size + dynamic refit.
-		this.layoutToContent();
+		// Estimate initial height from the head model's line count so the
+		// container is big enough on first paint. Refine after the diff
+		// computation settles.
+		const lineHeight = 19;
+		const chrome = 24;
+		const lineCount = headModel.getLineCount();
+		this.container.style.height = `${Math.min(
+			Math.max(lineCount * lineHeight + chrome, 80),
+			MAX_HEIGHT_PX,
+		)}px`;
+		this.widget.layout();
+		void this.widget.waitForDiff().then(() => this.layoutToContent());
+
+		// Dynamic refit on subsequent content-size changes (e.g. user
+		// expands "Show unchanged regions").
 		this._register(this.widget.onDidContentSizeChange(() => this.layoutToContent()));
 	}
 
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCache.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCache.ts
new file mode 100644
index 00000000000..8bfb72d9093
--- /dev/null
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCache.ts
@@ -0,0 +1,98 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { AutomationEvent, Comment, PullRequest, PullRequestFile } from '../../../../../platform/krt/common/krt.js';
+
+/**
+ * Session-scoped PR cache. Reopening a PR (closing + reopening the
+ * editor, switching tabs, opening from Search again) shouldn't re-shell
+ * `gh api` if we already have fresh data — the gh CLI calls dominate
+ * perceived latency. Posting a comment invalidates the entry.
+ *
+ * Lives at module scope on purpose: the cache must outlive any single
+ * `KrtPullRequestEditorPane` instance (panes are recreated on each
+ * editor input). All entries are dropped when the renderer reloads.
+ */
+export interface CachedPr {
+	readonly pr: PullRequest;
+	readonly fetchedAt: number;
+	files?: readonly PullRequestFile[];
+	reviewComments?: readonly Comment[];
+	activity?: readonly AutomationEvent[];
+}
+
+const TTL_MS = 5 * 60 * 1000;
+const MAX_ENTRIES = 20;
+
+const cache = new Map<string, CachedPr>();
+
+/**
+ * Returns the cached entry for `url` if present and fresh. Stale and
+ * missing entries both return `undefined`. Touches LRU order so hits
+ * stay alive longer.
+ */
+export function getCached(url: string): CachedPr | undefined {
+	const entry = cache.get(url);
+	if (!entry) {
+		return undefined;
+	}
+	if (Date.now() - entry.fetchedAt > TTL_MS) {
+		cache.delete(url);
+		return undefined;
+	}
+	// Touch — Map preserves insertion order, so re-setting bumps LRU.
+	cache.delete(url);
+	cache.set(url, entry);
+	return entry;
+}
+
+/**
+ * Replaces the entry for `url`. Drops sub-resources (files, comments,
+ * activity) — they belong to the prior fetch. The caller should call
+ * `set*` for any sub-resources it already has loaded.
+ */
+export function putPr(url: string, pr: PullRequest): void {
+	const entry: CachedPr = { pr, fetchedAt: Date.now() };
+	cache.delete(url);
+	cache.set(url, entry);
+	evictIfFull();
+}
+
+export function putFiles(url: string, files: readonly PullRequestFile[]): void {
+	const entry = cache.get(url);
+	if (entry) {
+		entry.files = files;
+	}
+}
+
+export function putReviewComments(url: string, comments: readonly Comment[]): void {
+	const entry = cache.get(url);
+	if (entry) {
+		entry.reviewComments = comments;
+	}
+}
+
+export function putActivity(url: string, activity: readonly AutomationEvent[]): void {
+	const entry = cache.get(url);
+	if (entry) {
+		entry.activity = activity;
+	}
+}
+
+/** Drops the entry for `url`. Used by Refresh and after posting a comment. */
+export function invalidate(url: string): void {
+	cache.delete(url);
+}
+
+function evictIfFull(): void {
+	while (cache.size > MAX_ENTRIES) {
+		// Map.keys() iterates in insertion order — the oldest is first.
+		const first = cache.keys().next().value;
+		if (first === undefined) {
+			break;
+		}
+		cache.delete(first);
+	}
+}
