-		throw badPullRequestUrl(url);
+function buildSearchQuery(query: string, scope: SearchScope): string {
+	const trimmed = query.trim();
+	const qualifiers: string[] = ['is:pr', 'archived:false'];
+	switch (scope) {
+		case 'all-open':
+			qualifiers.push('is:open');
+			break;
+		case 'reviewed':
+			qualifiers.push('reviewed-by:@me');
+			break;
+		case 'awaiting-review':
+			qualifiers.push('review-requested:@me');
+			break;
 	}
-	return {
-		owner: match.groups.owner,
-		repo: match.groups.repo,
-		number: Number(match.groups.number),
-	};
+	return trimmed ? `${trimmed} ${qualifiers.join(' ')}` : qualifiers.join(' ');
+}
+
+function deriveSummaryState(item: GhSearchItem): PullRequestState {
+	if (item.pull_request?.merged_at) {
+		return 'merged';
+	}
+	if (item.state === 'closed') {
+		return 'closed';
+	}
+	if (item.draft) {
+		return 'draft';
+	}
+	return 'open';
 }
 
 function mapPullRequest(parsed: { owner: string; repo: string; number: number }, data: GhPullRequest): PullRequest {
