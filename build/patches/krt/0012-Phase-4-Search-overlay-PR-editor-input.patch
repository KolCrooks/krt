@@ -50,22 +66,71 @@ export class PullRequestProviderMainService implements IPullRequestProvider {
 
 	async getPullRequest(url: string): Promise<PullRequest> {
 		const parsed = parsePullRequestUrl(url);
+		if (!parsed) {
+			throw badPullRequestUrl(url);
+		}
 		const path = `repos/${parsed.owner}/${parsed.repo}/pulls/${parsed.number}`;
 		const data = await this.ghClient.apiJson<GhPullRequest>(path);
 		return mapPullRequest(parsed, data);
 	}
+
+	async search(query: string, scope: SearchScope): Promise<readonly PullRequestSummary[]> {
+		const q = buildSearchQuery(query, scope);
+		const path = `search/issues?per_page=${SEARCH_PER_PAGE}&sort=updated&order=desc&q=${encodeURIComponent(q)}`;
+		const data = await this.ghClient.apiJson<GhSearchResponse>(path);
+		const items = Array.isArray(data?.items) ? data.items : [];
+		const out: PullRequestSummary[] = [];
+		for (const item of items) {
+			if (!item.pull_request) {
+				continue;
+			}
+			const parsed = ISSUE_HTML_URL_RE.exec(item.html_url);
+			if (!parsed?.groups) {
+				continue;
+			}
+			out.push({
+				url: item.html_url,
+				owner: parsed.groups.owner,
+				repo: parsed.groups.repo,
+				number: item.number,
+				title: item.title,
+				state: deriveSummaryState(item),
+				author: { login: item.user.login, avatarUrl: item.user.avatar_url },
+				updatedAt: item.updated_at,
+			});
+		}
+		return out;
+	}
 }
 
-function parsePullRequestUrl(url: string): { owner: string; repo: string; number: number } {
