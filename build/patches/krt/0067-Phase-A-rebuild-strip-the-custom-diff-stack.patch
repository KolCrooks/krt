-interface ILineZoneOptions {
-	readonly side: DiffSide;
-	readonly afterLine: number;
-	readonly domNode: HTMLElement;
-}
-
-// Card sizing — STATIC. We compute the editor's height from the patch
-// up-front: every visible line in the patch becomes one row in the
-// rendered diff, and each hunk implies a "+ N hidden lines" widget
-// from Monaco's `hideUnchangedRegions` feature. Both are
-// deterministic — the height is knowable before Monaco has rendered
-// anything, so we never read `getContentHeight()` or poll. The wrapper
-// element itself is *not* JS-sized; instead we pass the height to
-// `widget.layout({width, height})` and Monaco writes it onto its own
-// outer DOM, which the wrapper natural-fits via `height: auto`.
-//
-// `onDidContentSizeChange` still drives re-layout for content growth
-// that ISN'T knowable from the patch (review-comment view zones,
-// user expanding a hidden region) — those rare events refit Monaco
-// directly without touching the wrapper's CSS.
-const LINE_HEIGHT_PX = 19;
-const MIN_CARD_HEIGHT_PX = 80;
-const CARD_CHROME_PX = 12;
-
-/**
- * Compute the editor height we expect Monaco to render the patch at.
- * Patch-direct rendering: each non-meta patch line becomes one row in
- * the modified-side editor (or original-side, whichever has more —
- * the diff editor's height is `max(modified, original)`). Take the
- * larger of the two side counts so the container is sized for the
- * tallest side.
- */
-function estimateEditorHeight(patch: string | undefined): number {
-	if (!patch) {
-		return MIN_CARD_HEIGHT_PX;
-	}
-	let baseLines = 0;
-	let headLines = 0;
-	for (const raw of patch.split('\n')) {
-		if (raw.startsWith('@@') || raw.length === 0 || raw.startsWith('\\')) {
-			continue;
-		}
-		if (raw.startsWith('+')) {
-			headLines++;
-		} else if (raw.startsWith('-')) {
-			baseLines++;
-		} else {
-			// context line — counts on both sides
-			baseLines++;
-			headLines++;
-		}
-	}
-	const tallestSide = Math.max(baseLines, headLines);
-	return Math.max(tallestSide * LINE_HEIGHT_PX + CARD_CHROME_PX, MIN_CARD_HEIGHT_PX);
-}
-
-/**
- * Embeds Monaco's `DiffEditorWidget` in a container, populates it with
- * patch-reconstructed base/head models, and exposes a tiny API for
- * attaching review-comment view zones.
- *
- * Owns the two text models it creates and disposes them on `dispose()`.
- * Auto-sizes the container height to the diff's content height (capped
- * at `MAX_HEIGHT_PX` to keep giant patches scrollable).
- */
-export class KrtMonacoDiffView extends Disposable {
-
-	private readonly widget: DiffEditorWidget;
-	private readonly container: HTMLElement;
-	private readonly zoneDisposables = this._register(new DisposableStore());
-	private readonly resourceRegistrations = this._register(new DisposableStore());
-	private baseRealLines: ReadonlyArray<number | undefined> = [];
-	private headRealLines: ReadonlyArray<number | undefined> = [];
-	private activeComposerZone: IDisposable | undefined;
-
-	constructor(
-		parent: HTMLElement,
-		private readonly opts: IKrtMonacoDiffViewOptions,
-		@IInstantiationService instantiationService: IInstantiationService,
-		@IModelService private readonly modelService: IModelService,
-		@ILanguageService private readonly languageService: ILanguageService,
-		@ITextModelService private readonly textModelService: ITextModelService,
-		@IKrtGitService private readonly gitService: IKrtGitService,
-		@ILogService private readonly logService: ILogService,
-	) {
-		super();
-
-		this.container = DOM.append(parent, DOM.$('.krt-pr-diff-monaco'));
-		// One-shot static height from the patch — see `estimateEditorHeight`.
-		// No polling, no `getContentHeight`-races. The width comes from
-		// `automaticLayout: true` watching the wrapper's CSS-driven width.
-		this.container.style.height = `${estimateEditorHeight(opts.file.patch)}px`;
-
-		// Pass `{}` (no `contributions` field) for the per-editor widget
-		// options so the diff editor's inner CodeEditorWidgets fall back
-		// to the full registered-contribution set — same as a regular
-		// file editor. Filtering to a subset here suppresses the hover /
-		// goto-definition feature stack — those contributions register
-		// themselves into the global list and the widget only instantiates
-		// them when the field is left undefined. The native review-
-		// comment controller (`editor.contrib.review`) is part of the
-		// default set, so comments still attach.
-		this.widget = this._register(instantiationService.createInstance(
-			DiffEditorWidget,
-			this.container,
-			{
-				readOnly: true,
-				originalEditable: false,
-				renderSideBySide: opts.renderSideBySide ?? true,
-				useInlineViewWhenSpaceIsLimited: true,
-				// Default OFF — the async resolution below flips this on
-				// when both sides upgrade to full content. With virtual
-				// patch-direct models there's nothing to fold.
-				hideUnchangedRegions: { enabled: false },
-				renderOverviewRuler: false,
-				automaticLayout: true,
-				scrollBeyondLastLine: false,
-				minimap: { enabled: false },
-				scrollbar: {
-					handleMouseWheel: true,
-					alwaysConsumeMouseWheel: false,
-				},
-				lineNumbersMinChars: 4,
-			},
-			{
-				originalEditor: {},
-				modifiedEditor: {},
-			},
-		));
-
-		// Pre-compute the patch-derived realLines map so synchronously-
-		// wired callers (line-number click handler, comment registry
-		// during initial mount) see the right map. The async
-		// `attachModels` overwrites these with identity maps when the
-		// workspace upgrade succeeds.
-		const reconstructed = reconstructFromPatch(opts.file.patch ?? '');
-		this.baseRealLines = reconstructed.base.realLines;
-		this.headRealLines = reconstructed.head.realLines;
-
-		// Single-shot model attachment. Mixing the previous
-		// "synchronously mount virtual, asynchronously upgrade" pattern
-		// caused Monaco's `_diffModel` autorun to fire `onWillDispose`
-		// errors on later model interactions ("TextModel got disposed
-		// before DiffEditorWidget model got reset"). Calling
-		// `setDiffModel` exactly once eliminates the swap entirely.
-		// Trade-off: the diff is briefly empty (~50ms) while resolution
-		// runs; on a fast path the user usually doesn't notice.
-		void this.attachModels(reconstructed);
-
-		// `onDidContentSizeChange` only matters for changes the static
-		// estimate can't predict — review-comment view zones rendering
-		// markdown, the user expanding a "+ N hidden lines" region. On
-		// any such fire, refresh the wrapper's height from Monaco's
-		// current content height. (This is the one place runtime
-		// re-sizing can happen; on first construction the height is
-		// set up-front from the patch, no Monaco APIs consulted.)
-		this._register(this.widget.onDidContentSizeChange(() => {
-			const target = Math.max(
-				this.widget.getContentHeight() + CARD_CHROME_PX,
-				MIN_CARD_HEIGHT_PX,
-			);
-			if (this.container.clientHeight !== target) {
-				this.container.style.height = `${target}px`;
-			}
-		}));
-	}
-
-	private virtualBaseUri(): URI {
-		const previousPath = this.opts.file.previousPath ?? this.opts.file.path;
-		return URI.parse(`krt-pr-base://${encodeURIComponent(this.opts.owner)}/${encodeURIComponent(this.opts.repo)}/${encodeURIComponent(this.opts.baseSha)}/${encodeURI(previousPath)}`);
-	}
-
-	private virtualHeadUri(): URI {
-		return URI.parse(`krt-pr-head://${encodeURIComponent(this.opts.owner)}/${encodeURIComponent(this.opts.repo)}/${encodeURIComponent(this.opts.headSha)}/${encodeURI(this.opts.file.path)}`);
-	}
-
-	private getOrCreate(uri: URI, value: string): ITextModel {
-		const existing = this.modelService.getModel(uri);
-		if (existing) {
-			return existing;
-		}
-		return this.modelService.createModel(
-			value,
-			this.languageService.createByFilepathOrFirstLine(uri),
-			uri,
-			false,
-		);
-	}
-
-	private buildVirtualModels(reconstructed: Reconstructed): { base: ITextModel; head: ITextModel } {
-		const baseModel = this.getOrCreate(this.virtualBaseUri(), reconstructed.base.text);
-		const headModel = this.getOrCreate(this.virtualHeadUri(), reconstructed.head.text);
-		return { base: baseModel, head: headModel };
-	}
-
-	/**
-	 * Single-shot model resolution + attach. Picks workspace-backed
-	 * URIs (file:// + krt-git://) when the working tree is on the PR
-	 * head and both sides resolve cleanly, otherwise falls back to the
-	 * patch-reconstructed virtual URIs. Calls `setDiffModel` exactly
-	 * once — the previous "synchronous virtual then async upgrade"
-	 * pattern triggered Monaco's `onWillDispose`-on-old-model error
-	 * path on subsequent interactions.
-	 */
-	private async attachModels(reconstructed: Reconstructed): Promise<void> {
-		const upgrade = this.opts.workspace
-			? await this.tryWorkspaceModels(this.opts.workspace)
-			: undefined;
-		if (this._store.isDisposed) {
-			return;
-		}
-
-		let base: ITextModel;
-		let head: ITextModel;
-		let identity: boolean;
-		if (upgrade) {
-			base = upgrade.base;
-			head = upgrade.head;
-			this.baseRealLines = identityArray(base.getLineCount());
-			this.headRealLines = identityArray(head.getLineCount());
-			identity = true;
-		} else {
-			const virtual = this.buildVirtualModels(reconstructed);
-			base = virtual.base;
-			head = virtual.head;
-			this.baseRealLines = reconstructed.base.realLines;
-			this.headRealLines = reconstructed.head.realLines;
-			identity = false;
-		}
-
-		this.applyDiffModel(base, head);
-		this.applyLineNumbers(identity);
-		this.registerCommentResources(base.uri, head.uri);
-
-		if (identity) {
-			// Both sides full content — collapse unchanged regions so
-			// the visual stays focused on the changes plus a few lines
-			// of real surrounding context. On virtual models this would
-			// reveal padding blanks (or, with patch-direct rendering,
-			// nothing) so we leave it off there.
-			this.widget.updateOptions({
-				hideUnchangedRegions: { enabled: true, contextLineCount: 3, minimumLineCount: 4 },
-			});
-		}
-	}
-
-	private applyDiffModel(base: ITextModel, head: ITextModel): void {
-		// Phase 8.5/8.6 — view-model refcount workaround. The public
-		// `setModel({original, modified})` path goes through
-		// `RefCounted.create(...)` once and `createNewRef` once, leaving
-		// refcount = 2 with no caller-owned reference for the base ref.
-		// The widget's `setDiffModel(null)` only releases the cloned ref
-		// (count → 1), so the inner `DiffEditorViewModel` and its
-		// `autorunWithStore` never reach 0 → leaked-disposable warnings
-		// in dev mode and (on some Electron versions) the diff fails to
-		// render at all because the view-model's autoruns block layout.
-		//
-		// Workaround: build the view model ourselves and feed it through
-		// `setDiffModel(RefCounted.create(viewModel))`. Internally
-		// `setDiffModel` calls `createNewRef(this)` (refcount = 2). When
-		// we dispose, the registered base ref decrements to 1; when the
-		// widget disposes (also from our store), `_diffModelSrc` clears
-		// → cloned ref disposes → refcount = 0 → view-model torn down
-		// cleanly.
-		const viewModel = this.widget.createViewModel({ original: base, modified: head });
-		const ref = RefCounted.create(viewModel);
-		this._register(toDisposable(() => ref.dispose()));
-		this.widget.setDiffModel(ref);
-	}
-
-	private applyLineNumbers(identity: boolean): void {
-		// Per-side line-number callback — model line N → real file line.
-		// Identity (model line == real file line) is used when both sides
-		// are full-content models from the workspace. Otherwise the
-		// patch-derived sparse map maps model line N back to the original
-		// file's line number.
-		if (identity) {
-			this.widget.getOriginalEditor().updateOptions({ lineNumbers: 'on' });
-			this.widget.getModifiedEditor().updateOptions({ lineNumbers: 'on' });
-			return;
-		}
-		this.widget.getOriginalEditor().updateOptions({
-			lineNumbers: (n: number) => formatRealLine(this.baseRealLines[n - 1]),
-		});
-		this.widget.getModifiedEditor().updateOptions({
-			lineNumbers: (n: number) => formatRealLine(this.headRealLines[n - 1]),
-		});
-	}
-
-	private registerCommentResources(baseUri: URI, headUri: URI): void {
-		this.resourceRegistrations.clear();
-		if (!this.opts.pr) {
-			return;
-		}
-		const path = this.opts.file.path;
-		const previousPath = this.opts.file.previousPath ?? path;
-		this.logService.info(`[krt] diff view registering URIs for PR ${this.opts.pr.url}: base=${baseUri.toString()} head=${headUri.toString()}`);
-		const prMeta = {
-			url: this.opts.pr.url,
-			owner: this.opts.owner,
-			repo: this.opts.repo,
-			number: this.opts.pr.number,
-			headSha: this.opts.headSha,
-		};
-		this.resourceRegistrations.add(registerKrtPrResource(baseUri, {
-			side: 'LEFT',
-			path,
-			previousPath,
-			realLines: this.baseRealLines,
-			pr: prMeta,
-		} satisfies IKrtPrResource));
-		this.resourceRegistrations.add(registerKrtPrResource(headUri, {
-			side: 'RIGHT',
-			path,
-			previousPath,
-			realLines: this.headRealLines,
-			pr: prMeta,
-		} satisfies IKrtPrResource));
-	}
-
-	/**
-	 * Resolve workspace-backed text models so language extensions
-	 * (rust-analyzer, gopls, pyright, …) activate against the head
-	 * side. Head: real `file://` URI when the working tree is on the
-	 * PR's head SHA — that's the URI scheme language servers anchor
-	 * on. Base: `krt-git://` whose content provider shells `git show
-	 * ${baseSha}:${path}`.
-	 *
-	 * **All-or-nothing.** Mixing full content on one side with the
-	 * patch-reconstructed virtual model on the other looks visually
-	 * broken: the diff editor compares them and every line outside the
-	 * patch's hunks shows as a difference. So we only return models
-	 * when *both* sides resolve cleanly; any failure (working tree
-	 * drifted, base SHA not fetched, …) returns `undefined` and the
-	 * caller falls back to the virtual diff.
-	 *
-	 * Added/removed files keep the virtual diff: the patch already
-	 * shows their full content (one side is empty, the other is
