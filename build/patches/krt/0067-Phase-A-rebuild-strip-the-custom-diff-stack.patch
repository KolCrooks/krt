-	 */
-	readonly workspace?: KrtWorkspace;
-	/**
-	 * Phase 9.5 — identity passed through to
-	 * `KrtPrCommentController` via the per-URI registry so review
-	 * comments loaded by the pane can be matched back to the right
-	 * diff editor (and the right side of it). Optional: when omitted,
