-/**
- * Reconstructs the base and head sides of a unified-diff patch into
- * compact text bodies for `KrtMonacoDiffView`. v2 (patch-direct):
- * each model line corresponds to one real patch line. No padding
- * between hunks — instead the diff editor renders only what's in the
- * patch, and a `realLineNumbers` map lets the line-number gutter
- * display the file's actual line numbers (549, 550, …) instead of
- * the model's sequential 1, 2, ….
- *
- * Why this shape (vs. earlier blank-padded reconstruction):
- *   - No empty rows. Earlier versions padded gaps between hunks with
- *     `''` strings so model lines = file lines; that fed Monaco's
- *     `hideUnchangedRegions` feature, but expanding a "+ N hidden
- *     lines" widget revealed those padding blanks.
- *   - hideUnchangedRegions becomes irrelevant — the patch already
- *     trims to context+changes per hunk; no large unchanged regions
- *     to fold.
- *
- * Format reminder (unified diff):
- *
- *   @@ -<oldStart>,<oldLines> +<newStart>,<newLines> @@ optional
- *    context line                                          (' ' prefix)
- *   -removed line                                           ('-' prefix)
- *   +added line                                             ('+' prefix)
- *   \ No newline at end of file                             ('\' prefix — skip)
- */
-
-const HUNK_HEADER_RE = /^@@\s+-(?<oldStart>\d+)(?:,(?<oldLines>\d+))?\s+\+(?<newStart>\d+)(?:,(?<newLines>\d+))?\s+@@/;
-
-export interface ReconstructedSide {
-	readonly text: string;
-	/**
-	 * For each model line (1-indexed), the corresponding real file
-	 * line number on this side. `undefined` for lines that don't exist
-	 * on this side (e.g., a `+` line is undefined in the base map).
-	 */
-	readonly realLines: ReadonlyArray<number | undefined>;
-}
-
-export interface Reconstructed {
-	readonly base: ReconstructedSide;
-	readonly head: ReconstructedSide;
-}
-
-export function reconstructFromPatch(patch: string): Reconstructed {
-	const baseLines: string[] = [];
-	const headLines: string[] = [];
-	const baseRealLines: (number | undefined)[] = [];
-	const headRealLines: (number | undefined)[] = [];
-
-	let oldLine = 0;
-	let newLine = 0;
-
-	for (const raw of patch.split('\n')) {
-		const header = HUNK_HEADER_RE.exec(raw);
-		if (header) {
-			oldLine = Number(header.groups!.oldStart);
-			newLine = Number(header.groups!.newStart);
-			continue;
-		}
-		if (raw.startsWith('\\') || raw.length === 0) {
-			// `\ No newline at end of file` — informational, doesn't
-			// belong on either side. Trailing empty line at split end
-			// is the same: skip.
-			continue;
-		}
-		if (raw.startsWith('+')) {
-			headLines.push(raw.slice(1));
-			headRealLines.push(newLine);
-			newLine++;
-			continue;
-		}
-		if (raw.startsWith('-')) {
-			baseLines.push(raw.slice(1));
-			baseRealLines.push(oldLine);
-			oldLine++;
-			continue;
-		}
-		if (raw.startsWith(' ')) {
-			const content = raw.slice(1);
-			baseLines.push(content);
-			baseRealLines.push(oldLine);
-			headLines.push(content);
-			headRealLines.push(newLine);
-			oldLine++;
-			newLine++;
-			continue;
-		}
-		// Pre-image / metadata lines (rare in modern unified diffs).
-	}
-
-	return {
-		base: { text: baseLines.join('\n'), realLines: baseRealLines },
-		head: { text: headLines.join('\n'), realLines: headRealLines },
-	};
-}
