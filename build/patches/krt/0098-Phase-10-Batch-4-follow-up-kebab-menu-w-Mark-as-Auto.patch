 	border: 1px solid transparent;
 	border-radius: 4px;
-	padding: 2px 8px;
+	padding: 0;
 	cursor: pointer;
-	white-space: nowrap;
 	opacity: 0;
-	transition: opacity 80ms;
+	transition: opacity 80ms, background 80ms;
 }
 
-.krt-pr-comment:hover .krt-pr-comment-bot-toggle,
-.krt-pr-comment-bot-toggle:focus-visible,
-.krt-pr-comment-bot-toggle.active {
-	opacity: 1;
+.krt-pr-comment-menu-btn .codicon {
+	font-size: 14px;
 }
 
-.krt-pr-comment-bot-toggle:hover {
-	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.12));
-	color: var(--vscode-foreground);
+.krt-pr-comment:hover .krt-pr-comment-menu-btn,
+.krt-pr-comment-menu-btn:focus-visible {
+	opacity: 0.7;
 }
 
-.krt-pr-comment-bot-toggle.active {
-	color: var(--krt-accent);
-	border-color: var(--krt-accent-line);
-	background: var(--krt-accent-soft);
+.krt-pr-comment-menu-btn:hover,
+.krt-pr-comment:hover .krt-pr-comment-menu-btn:hover {
+	opacity: 1;
+	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.12));
+	color: var(--vscode-foreground);
 }
 
