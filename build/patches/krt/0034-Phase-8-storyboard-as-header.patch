From 294d5b4bfbe0a684121305dcdb1e84a2a948d512 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Tue, 5 May 2026 13:18:38 -0400
Subject: [PATCH] Phase 8: storyboard becomes a header section, full-page diff
 below
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The storyboard sub-mode used to live inside its own bounded
flex column with internal scrolling; the diff drawer at the
bottom was a small max-height:40% panel showing mini-diffs.
Restructure so the whole sub-mode is one long scrollable page:

- .krt-pr-editor-body.storyboard drops overflow:hidden — the
  editor root resumes vertical scrolling.
- The graph row (.krt-pr-storyboard-body) sizes to its natural
  canvas height instead of taking flex:1.
- The canvas scroller only handles horizontal overflow; vertical
  scroll falls through to the root.
- The detail rail sticks to the top of the viewport (position:
  sticky) while the graph is in view; the graph header sticks
  too.
- The diff section below the graph now uses the SAME file-tree
  layout the Diff sub-mode uses (.krt-pr-diff with a sticky
  file tree on the left and stacked .krt-pr-diff-section's on
  the right). It's still scoped to the selected chapter's files,
  so clicking a chapter card both centres the graph on it and
  reflows the diff section to that chapter's diffs.
- focusOnNode now scrolls horizontally inside the canvas
  scroller and vertically on the editor root, so connection-
  link clicks land the target card centred in the viewport.
---
 .../browser/pr/krtPullRequestEditorPane.css   | 54 +++++++----
 .../browser/pr/krtPullRequestEditorPane.ts    | 91 +++++++++++++++----
 2 files changed, 109 insertions(+), 36 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
index e0d07bafc55..3f8b7ad0bfa 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
@@ -1557,7 +1557,9 @@
 	flex-direction: column;
 	gap: 0;
 	padding: 0;
-	overflow: hidden;
+	/* No overflow:hidden — the editor root handles vertical
+	 * scrolling so the storyboard graph + diff section stack
+	 * vertically as one long scrollable page. */
 }
 
 .krt-pr-storyboard-header {
@@ -1569,6 +1571,9 @@
 	border-bottom: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.2));
 	background: var(--vscode-editor-background, transparent);
 	flex-shrink: 0;
+	position: sticky;
+	top: 0;
+	z-index: 3;
 }
 
 .krt-pr-storyboard-heading {
@@ -1618,20 +1623,23 @@
 }
 
 .krt-pr-storyboard-body {
-	flex: 1 1 auto;
-	min-height: 0;
-	overflow: hidden;
 	display: flex;
+	/* No flex / overflow constraints — body sizes to the canvas's
+	 * natural height; vertical overflow falls through to the root. */
 }
 
+/*
+ * Storyboard diff section. Sits below the storyboard graph and
+ * uses the same file-tree-on-the-side layout as the Diff sub-mode
+ * (.krt-pr-diff and friends), reusing those styles. We just give
+ * the section a top border so it visually separates from the
+ * graph and a min-height so it occupies a useful slice of viewport
+ * even before the user scrolls.
+ */
 .krt-pr-storyboard-diff {
-	flex: 0 0 auto;
-	max-height: 40%;
 	border-top: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.25));
 	background: var(--vscode-editor-background, transparent);
-	display: flex;
-	flex-direction: column;
-	min-height: 0;
+	min-height: 60vh;
 }
 
 .krt-pr-storyboard-diff:empty {
@@ -1642,10 +1650,12 @@
 	display: flex;
 	align-items: baseline;
 	gap: 12px;
-	padding: 8px 18px;
+	padding: 10px 18px;
 	border-bottom: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.18));
-	flex-shrink: 0;
 	background: var(--vscode-editorWidget-background, transparent);
+	position: sticky;
+	top: 0;
+	z-index: 2;
 }
 
 .krt-pr-storyboard-diff-heading {
@@ -1666,13 +1676,6 @@
 	white-space: nowrap;
 }
 
-.krt-pr-storyboard-diff-body {
-	flex: 1 1 auto;
-	min-height: 0;
-	overflow: auto;
-	padding: 8px 18px 16px;
-}
-
 .krt-pr-storyboard-layout {
 	display: flex;
 	flex: 1;
@@ -1683,7 +1686,11 @@
 .krt-pr-storyboard-scroller {
 	flex: 1;
 	min-width: 0;
-	overflow: auto;
+	/* Only the horizontal axis scrolls inside the scroller; the
+	 * editor root handles vertical scrolling so the diff section
+	 * below the graph flows on the same scroll surface. */
+	overflow-x: auto;
+	overflow-y: visible;
 	background:
 		radial-gradient(circle, var(--vscode-widget-border, rgba(127, 127, 127, 0.2)) 1px, transparent 1px) -1px -1px / 18px 18px,
 		var(--vscode-editor-background, transparent);
@@ -1980,6 +1987,15 @@
 	border-left: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.2));
 	background: var(--vscode-editor-background, transparent);
 	min-height: 0;
+	/* Stick to the top of the editor's scroll viewport while the
+	 * storyboard graph is in view, so the user can read the
+	 * details of the selected chapter without losing their place
+	 * when scrolling vertically. */
+	position: sticky;
+	top: 0;
+	align-self: flex-start;
+	max-height: 100vh;
+	overflow: auto;
 }
 
 .krt-pr-storyboard-detail-empty {
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
index a4bde40e325..a73b4e0e001 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
@@ -1701,8 +1701,11 @@ export class KrtPullRequestEditorPane extends EditorPane {
 
 	/**
 	 * Populate the diff panel below the storyboard with the
-	 * selected chapter's mini-diffs. Re-uses the same patch
-	 * rendering the Tour Reading variant uses.
+	 * selected chapter's full diff — same file-tree + stacked-
+	 * sections layout the Diff sub-mode uses, just scoped to the
+	 * chapter's `files`. The whole pane shares one scroll surface
+	 * (the editor root), so the file tree sticks while the user
+	 * scrolls through the diff sections.
 	 */
 	private renderStoryboardDiffPanel(pr: PullRequest, chapterId: string): void {
 		const panel = this.storyboardDiffPanelEl;
@@ -1714,19 +1717,66 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		if (!chapter) {
 			return;
 		}
+
 		const head = DOM.append(panel, DOM.$('.krt-pr-storyboard-diff-head'));
 		const heading = DOM.append(head, DOM.$('span.krt-pr-storyboard-diff-heading'));
 		heading.textContent = localize('krt.pr.storyboard.diffHeading', "Diff for selected chapter");
 		const title = DOM.append(head, DOM.$('span.krt-pr-storyboard-diff-title'));
 		renderChapterMarkdown(title, chapter.title, this.bodyDisposables, { inline: true });
-		const body = DOM.append(panel, DOM.$('.krt-pr-storyboard-diff-body'));
-		const focusPath = chapter.diffFile && chapter.files.includes(chapter.diffFile)
-			? chapter.diffFile
-			: chapter.files[0];
-		const ordered = focusPath
-			? [focusPath, ...chapter.files.filter(p => p !== focusPath)]
-			: [...chapter.files];
-		this.renderTourMiniDiffs(body, pr, ordered);
+
+		const wrap = DOM.append(panel, DOM.$('.krt-pr-diff'));
+		const tree = DOM.append(wrap, DOM.$('.krt-pr-diff-tree'));
+		const stack = DOM.append(wrap, DOM.$('.krt-pr-diff-stack'));
+
+		if (this.diffFiles === undefined) {
+			const empty = DOM.append(stack, DOM.$('.krt-pr-empty'));
+			empty.textContent = this.diffFilesLoading
+				? localize('krt.pr.diffLoading', "Loading changed files…")
+				: localize('krt.pr.diffPending', "Fetching changed files…");
+			const treeEmpty = DOM.append(tree, DOM.$('.krt-pr-side-empty'));
+			treeEmpty.textContent = localize('krt.pr.diffTreeLoading', "Loading…");
+			if (!this.diffFilesLoading) {
+				this.loadDiffFiles(pr);
+			}
+			return;
+		}
+
+		// Filter PR files to just the chapter's files, preserving the
+		// chapter's order; missing files (rare, usually stale model
+		// output) are skipped silently.
+		const chapterPathSet = new Set(chapter.files);
+		const orderedFiles = chapter.files
+			.map(p => this.diffFiles!.find(f => f.path === p))
+			.filter((f): f is PullRequestFile => !!f && chapterPathSet.has(f.path));
+
+		if (orderedFiles.length === 0) {
+			const empty = DOM.append(stack, DOM.$('.krt-pr-empty'));
+			empty.textContent = localize('krt.pr.storyboard.diffNoFiles', "This chapter's files aren't in the PR's diff.");
+			return;
+		}
+
+		// Lazy-load review comments the same way the Diff sub-mode
+		// does, so existing inline comments populate when ready.
+		if (this.reviewComments === undefined && !this.reviewCommentsLoading) {
+			this.loadReviewComments(pr);
+		}
+
+		const treeRows = new Map<string, HTMLElement>();
+		this.renderDiffTree(tree, orderedFiles, treeRows);
+		const sectionByPath = new Map<string, HTMLElement>();
+		for (const file of orderedFiles) {
+			const section = this.renderDiffFileSection(stack, pr, file);
+			sectionByPath.set(file.path, section);
+		}
+		// Tree clicks scroll the editor root to the section.
+		for (const [path, row] of treeRows) {
+			this.bodyDisposables.add(DOM.addDisposableListener(row, 'click', () => {
+				const section = sectionByPath.get(path);
+				if (section) {
+					section.scrollIntoView({ behavior: 'smooth', block: 'start' });
+				}
+			}));
+		}
 	}
 
 	private renderStoryboardGraph(parent: HTMLElement, pr: PullRequest, chapters: readonly Chapter[]): void {
@@ -2047,16 +2097,23 @@ export class KrtPullRequestEditorPane extends EditorPane {
 
 		const focusOnNode = (id: string, smooth: boolean) => {
 			const node = layout.nodes.find(n => n.id === id);
-			if (!node) {
+			if (!node || !this.root) {
 				return;
 			}
+			// Horizontal: centre the node inside the scroller's
+			// horizontal viewport.
 			const targetLeft = Math.max(0, node.x + node.width / 2 - scroller.clientWidth / 2);
-			const targetTop = Math.max(0, node.y + node.height / 2 - scroller.clientHeight / 2);
-			scroller.scrollTo({
-				left: targetLeft,
-				top: targetTop,
-				behavior: smooth ? 'smooth' : 'auto',
-			});
+			scroller.scrollTo({ left: targetLeft, behavior: smooth ? 'smooth' : 'auto' });
+
+			// Vertical: the editor root is the scroll container, not
+			// the canvas. Compute the node's y-coordinate inside the
+			// root's content via its bounding rect, then scroll the
+			// root to centre it in the viewport.
+			const canvasRect = canvas.getBoundingClientRect();
+			const rootRect = this.root.getBoundingClientRect();
+			const nodeYInRoot = (canvasRect.top - rootRect.top) + this.root.scrollTop + node.y;
+			const targetTop = Math.max(0, nodeYInRoot + node.height / 2 - this.root.clientHeight / 2);
+			this.root.scrollTo({ top: targetTop, behavior: smooth ? 'smooth' : 'auto' });
 		};
 
 		const selectNode = (id: string, options?: { focus?: boolean }) => {
