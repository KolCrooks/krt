@@ -0,0 +1,213 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import * as DOM from '../../../../../base/browser/dom.js';
+import { Disposable, DisposableStore, IDisposable, toDisposable } from '../../../../../base/common/lifecycle.js';
+import { URI } from '../../../../../base/common/uri.js';
+import { ICodeEditor, MouseTargetType } from '../../../../../editor/browser/editorBrowser.js';
+import { DiffEditorWidget } from '../../../../../editor/browser/widget/diffEditor/diffEditorWidget.js';
+import { ILanguageService } from '../../../../../editor/common/languages/language.js';
+import { IModelService } from '../../../../../editor/common/services/model.js';
+import { IInstantiationService } from '../../../../../platform/instantiation/common/instantiation.js';
+import { PullRequestFile } from '../../../../../platform/krt/common/krt.js';
+import { reconstructFromPatch } from './krtPatchReconstruct.js';
+
+export type DiffSide = 'LEFT' | 'RIGHT';
+
+export interface IKrtMonacoDiffViewOptions {
+	readonly owner: string;
+	readonly repo: string;
+	readonly baseSha: string;
+	readonly headSha: string;
+	readonly file: PullRequestFile;
+}
+
+interface ILineZoneOptions {
+	readonly side: DiffSide;
+	readonly afterLine: number;
+	readonly domNode: HTMLElement;
+}
+
+const MAX_HEIGHT_PX = 2000;
+
+/**
+ * Embeds Monaco's `DiffEditorWidget` in a container, populates it with
+ * patch-reconstructed base/head models, and exposes a tiny API for
+ * attaching review-comment view zones.
+ *
+ * Owns the two text models it creates and disposes them on `dispose()`.
+ * Auto-sizes the container height to the diff's content height (capped
+ * at `MAX_HEIGHT_PX` to keep giant patches scrollable).
+ */
+export class KrtMonacoDiffView extends Disposable {
+
+	private readonly widget: DiffEditorWidget;
+	private readonly container: HTMLElement;
+	private readonly zoneDisposables = this._register(new DisposableStore());
+
+	constructor(
+		parent: HTMLElement,
+		opts: IKrtMonacoDiffViewOptions,
+		@IInstantiationService instantiationService: IInstantiationService,
+		@IModelService modelService: IModelService,
+		@ILanguageService languageService: ILanguageService,
+	) {
+		super();
+
+		this.container = DOM.append(parent, DOM.$('.krt-pr-diff-monaco'));
+		this.container.style.height = '0px';
+
+		this.widget = this._register(instantiationService.createInstance(
+			DiffEditorWidget,
+			this.container,
+			{
+				readOnly: true,
+				originalEditable: false,
+				renderSideBySide: true,
+				useInlineViewWhenSpaceIsLimited: true,
+				hideUnchangedRegions: {
+					enabled: true,
+					contextLineCount: 3,
+					minimumLineCount: 4,
+				},
+				renderOverviewRuler: false,
+				automaticLayout: false,
+				scrollBeyondLastLine: false,
+				minimap: { enabled: false },
+				scrollbar: {
+					alwaysConsumeMouseWheel: false,
+					handleMouseWheel: false,
+				},
+				lineNumbersMinChars: 4,
+			},
+			{
+				originalEditor: { contributions: [] },
+				modifiedEditor: { contributions: [] },
+			},
+		));
+
+		const { base, head } = reconstructFromPatch(opts.file.patch ?? '');
+		const path = opts.file.path;
+		const previousPath = opts.file.previousPath ?? path;
+		const baseUri = URI.parse(`krt-pr-base://${encodeURIComponent(opts.owner)}/${encodeURIComponent(opts.repo)}/${encodeURIComponent(opts.baseSha)}/${encodeURI(previousPath)}`);
+		const headUri = URI.parse(`krt-pr-head://${encodeURIComponent(opts.owner)}/${encodeURIComponent(opts.repo)}/${encodeURIComponent(opts.headSha)}/${encodeURI(path)}`);
+
+		const baseModel = modelService.createModel(
+			base,
+			languageService.createByFilepathOrFirstLine(baseUri),
+			baseUri,
+			false,
+		);
+		const headModel = modelService.createModel(
+			head,
+			languageService.createByFilepathOrFirstLine(headUri),
+			headUri,
+			false,
+		);
+		this._register(toDisposable(() => baseModel.dispose()));
+		this._register(toDisposable(() => headModel.dispose()));
+
+		this.widget.setModel({ original: baseModel, modified: headModel });
+
+		// Initial size + dynamic refit.
+		this.layoutToContent();
+		this._register(this.widget.onDidContentSizeChange(() => this.layoutToContent()));
+	}
+
+	private layoutToContent(): void {
+		const contentHeight = Math.min(this.widget.getContentHeight(), MAX_HEIGHT_PX);
+		// Add a small chrome margin so the bottom row isn't flush against
+		// the section's border.
+		const target = Math.max(contentHeight + 8, 60);
+		if (this.container.clientHeight !== target) {
+			this.container.style.height = `${target}px`;
+			this.widget.layout();
+		}
+	}
+
+	/**
+	 * Attach a DOM node as a Monaco view zone after the given line on the
+	 * specified side. Returns a disposable that removes the zone.
+	 *
+	 * The caller's `domNode` is wrapped in a host div before being handed
+	 * to Monaco — Monaco writes `style.height` directly onto whatever
+	 * node we hand it, and a non-`box-sizing: content-box` host avoids
+	 * the height-feedback loop where padding/borders bump `offsetHeight`
+	 * past the assigned height on every observer pass.
+	 */
+	addLineZone(opts: ILineZoneOptions): IDisposable {
+		const editor = opts.side === 'RIGHT' ? this.widget.getModifiedEditor() : this.widget.getOriginalEditor();
+		const host = document.createElement('div');
+		host.className = 'krt-pr-diff-zone-host';
+		host.style.boxSizing = 'border-box';
+		host.appendChild(opts.domNode);
+
+		let zoneId: string | null = null;
+		editor.changeViewZones(accessor => {
+			zoneId = accessor.addZone({
+				afterLineNumber: opts.afterLine,
+				domNode: host,
+				heightInPx: Math.max(host.offsetHeight, 80),
+			});
+		});
+
+		// Resize whenever the inner DOM grows (e.g. markdown finishes
+		// rendering or the user expands a long comment).
+		const observer = new ResizeObserver(() => {
+			if (zoneId === null) {
+				return;
+			}
+			const measured = opts.domNode.offsetHeight + 16; // host padding budget
+			editor.changeViewZones(accessor => {
+				accessor.layoutZone(zoneId!);
+			});
+			if (host.offsetHeight !== measured && measured > 0) {
+				editor.changeViewZones(accessor => {
+					accessor.removeZone(zoneId!);
+					zoneId = accessor.addZone({
+						afterLineNumber: opts.afterLine,
+						domNode: host,
+						heightInPx: measured,
+					});
+				});
+			}
+		});
+		observer.observe(opts.domNode);
+
+		const dispose = toDisposable(() => {
+			observer.disconnect();
+			if (zoneId !== null) {
+				editor.changeViewZones(accessor => accessor.removeZone(zoneId!));
+				zoneId = null;
+			}
+		});
+		this.zoneDisposables.add(dispose);
+		return dispose;
+	}
+
+	/**
+	 * Wire a click handler on both editors' line-number gutters. The
+	 * callback receives the side ('LEFT' | 'RIGHT') and the file's real
+	 * line number on that side. Used by the diff sub-mode to open the
+	 * inline composer when a reviewer clicks a line number.
+	 */
+	onLineNumberClick(callback: (side: DiffSide, line: number) => void): IDisposable {
+		const wire = (editor: ICodeEditor, side: DiffSide) =>
+			editor.onMouseDown(e => {
+				if (e.target.type !== MouseTargetType.GUTTER_LINE_NUMBERS) {
+					return;
+				}
+				const line = e.target.position?.lineNumber;
+				if (line !== undefined) {
+					callback(side, line);
+				}
+			});
+		const store = new DisposableStore();
+		store.add(wire(this.widget.getModifiedEditor(), 'RIGHT'));
+		store.add(wire(this.widget.getOriginalEditor(), 'LEFT'));
+		this._register(store);
+		return store;
+	}
+}
