+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+/**
+ * Reconstructs the base and head sides of a unified-diff `patch` string
+ * into two text bodies whose line numbers map directly to the real file
+ * line numbers — the gap between hunks is padded with empty strings so
+ * that line N in the returned `base`/`head` corresponds to line N in
+ * the original file.
+ *
+ * Used by `KrtMonacoDiffView` to populate Monaco text models without
+ * fetching the full base/head file content from GitHub. Monaco's
+ * `hideUnchangedRegions` option compresses the padded gaps so the diff
+ * view doesn't show acres of blank lines.
+ *
+ * Format reminder (unified diff):
+ *
+ *   @@ -<oldStart>,<oldLines> +<newStart>,<newLines> @@ optional
+ *    context line                                          (' ' prefix)
+ *   -removed line                                           ('-' prefix)
+ *   +added line                                             ('+' prefix)
+ *   \ No newline at end of file                             ('\' prefix — skip)
+ *
+ * `<oldLines>` and `<newLines>` are optional; default to 1 when absent.
+ */
+
+const HUNK_HEADER_RE = /^@@\s+-(?<oldStart>\d+)(?:,(?<oldLines>\d+))?\s+\+(?<newStart>\d+)(?:,(?<newLines>\d+))?\s+@@/;
+
+export function reconstructFromPatch(patch: string): { readonly base: string; readonly head: string } {
+	const baseLines: string[] = [];
+	const headLines: string[] = [];
+
+	// Track the *next* line number we're about to emit on each side.
+	// Start at 1 (first file line); the patch's hunk headers are 1-indexed.
+	let baseLine = 1;
+	let headLine = 1;
+
+	const padTo = (target: string[], current: number, target1Indexed: number) => {
+		while (current < target1Indexed) {
+			target.push('');
+			current++;
+		}
+		return current;
+	};
+
+	for (const raw of patch.split('\n')) {
+		const header = HUNK_HEADER_RE.exec(raw);
+		if (header) {
+			const oldStart = Number(header.groups!.oldStart);
+			const newStart = Number(header.groups!.newStart);
+			// Pad both sides up to the hunk's starting line so subsequent
+			// pushes land at the correct index.
+			baseLine = padTo(baseLines, baseLine, oldStart);
+			headLine = padTo(headLines, headLine, newStart);
+			continue;
+		}
+		if (raw.startsWith('\\')) {
+			// `\ No newline at end of file` — informational, doesn't
+			// belong on either side.
+			continue;
+		}
+		if (raw.startsWith('+')) {
+			headLines.push(raw.slice(1));
+			headLine++;
+			continue;
+		}
+		if (raw.startsWith('-')) {
+			baseLines.push(raw.slice(1));
+			baseLine++;
+			continue;
+		}
+		if (raw.startsWith(' ')) {
+			const content = raw.slice(1);
+			baseLines.push(content);
+			headLines.push(content);
+			baseLine++;
+			headLine++;
+			continue;
+		}
+		// Empty line in the patch (rare — only happens at the very end of
+		// some `git diff` outputs) or non-hunk metadata. Skip silently.
+	}
+
+	return {
+		base: baseLines.join('\n'),
+		head: headLines.join('\n'),
+	};
+}
