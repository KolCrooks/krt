From 3d4053a2d4dd5cfd4c7d23ada2e27ccd9b197690 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 15:53:20 -0400
Subject: [PATCH] PR pane: grey out Check Out when already on PR head
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Compares `IKrtGitService.getHeadSha(workspace)` to `pr.head.sha` after
PR load and on `IKrtSwitchResumeService.onDidChange`. When they match,
flips the button label to "Checked out" with a clarifying tooltip and
disables it.

Three states for the button now:
  1. No PR loaded → disabled, neutral label.
  2. PR loaded, workspace at PR head → disabled, "Checked out".
  3. PR loaded, otherwise → enabled (no-workspace case still routes
     to Add Workspace on click).

Failures of `getHeadSha` (no git, broken folder, etc.) are silent —
button stays enabled so the user can attempt a switch and surface
the underlying error via the existing notification path.
---
 .../browser/pr/krtPullRequestEditorPane.ts    | 94 ++++++++++++++++++-
 1 file changed, 89 insertions(+), 5 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
index bb5084fd8ac..5d7f989003e 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
@@ -124,6 +124,14 @@ export class KrtPullRequestEditorPane extends EditorPane {
 	private reviewedPaths: Set<string> = new Set();
 	private collapsedDiffFiles: Set<string> = new Set();
 	private diffRenderMode: 'side-by-side' | 'inline' = 'side-by-side';
+	/**
+	 * `true` when the registered workspace's current HEAD SHA matches
+	 * `currentPr.head.sha` — i.e., the user has already checked the PR
+	 * out (via KRT or manually). Drives the Check Out button's
+	 * disabled state. Updated asynchronously on PR load + on
+	 * `IKrtSwitchResumeService.onDidChange`.
+	 */
+	private isCheckedOut = false;
 	private reviewComments: readonly Comment[] | undefined;
 	private reviewCommentsLoading = false;
 	private liveReviewComments: Comment[] = [];
@@ -170,6 +178,13 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		@IFileService private readonly fileService: IFileService,
 	) {
 		super(KrtPullRequestEditorPane.ID, group, telemetryService, themeService, krtStorageService);
+		// Re-check the workspace's HEAD whenever the resume token
+		// changes (i.e., a switch happened) so the Check Out button
+		// flips to "Checked out" / back without waiting for the user
+		// to navigate elsewhere.
+		this._register(this.switchResumeService.onDidChange(() => {
+			void this.refreshCheckoutStatus();
+		}));
 	}
 
 	protected createEditor(parent: HTMLElement): void {
@@ -212,19 +227,85 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		const hasPr = !!this.currentPr;
 		this.refreshBtnElement.disabled = !hasPr;
 		this.openOnGithubBtnElement.disabled = !hasPr;
-		// Always show Check Out so the affordance is discoverable. When
-		// the workspace isn't registered for the PR's repo, click takes
-		// the user to the Add Workspace flow instead of attempting a
-		// switch.
 		const workspace = this.currentPr
 			? this.workspaceRegistry.findByOwnerRepo(this.currentPr.owner, this.currentPr.repo)
 			: undefined;
-		this.checkoutBtnElement.disabled = !hasPr;
+		// Three states for Check Out:
+		//   1. No PR loaded → disabled.
+		//   2. PR loaded, workspace already at PR head → disabled +
+		//      "Already checked out" tooltip.
+		//   3. PR loaded, workspace registered or not → enabled (in the
+		//      no-workspace case, click prompts Add Workspace).
+		if (!hasPr) {
+			this.checkoutBtnElement.disabled = true;
+			this.checkoutBtnElement.textContent = localize('krt.pr.checkout', "Check out");
+			this.checkoutBtnElement.title = '';
+			return;
+		}
+		if (workspace && this.isCheckedOut) {
+			this.checkoutBtnElement.disabled = true;
+			this.checkoutBtnElement.textContent = localize('krt.pr.checkout.checkedOut', "Checked out");
+			this.checkoutBtnElement.title = localize(
+				'krt.pr.checkout.tooltip.alreadyOn',
+				"Workspace is already on this PR's head commit.",
+			);
+			return;
+		}
+		this.checkoutBtnElement.disabled = false;
+		this.checkoutBtnElement.textContent = localize('krt.pr.checkout', "Check out");
 		this.checkoutBtnElement.title = workspace
 			? localize('krt.pr.checkout.tooltip', "Switch the registered workspace's working tree to this PR's head commit")
 			: localize('krt.pr.checkout.tooltip.noWorkspace', "No workspace is registered for this repo. Click to add one.");
 	}
 
+	/**
+	 * Compare the workspace's HEAD SHA against the PR's head and update
+	 * `isCheckedOut`. Async — re-runs `updateHeaderActionsEnablement`
+	 * when finished. Triggered on PR load + on switch-resume changes.
+	 * Failures are silent (no workspace → false; shell errors → false).
+	 */
+	private async refreshCheckoutStatus(): Promise<void> {
+		const pr = this.currentPr;
+		if (!pr) {
+			if (this.isCheckedOut) {
+				this.isCheckedOut = false;
+				this.updateHeaderActionsEnablement();
+			}
+			return;
+		}
+		const workspace = this.workspaceRegistry.findByOwnerRepo(pr.owner, pr.repo);
+		if (!workspace) {
+			if (this.isCheckedOut) {
+				this.isCheckedOut = false;
+				this.updateHeaderActionsEnablement();
+			}
+			return;
+		}
+		try {
+			const sha = await this.krtGitService.getHeadSha(workspace.folderPath);
+			const matches = sha === pr.head.sha;
+			// Don't fire updates if the active PR has changed under us
+			// (user switched tabs while we were awaiting).
+			if (this.currentPr?.url !== pr.url) {
+				return;
+			}
+			if (this.isCheckedOut !== matches) {
+				this.isCheckedOut = matches;
+				this.updateHeaderActionsEnablement();
+			}
+		} catch (err) {
+			// `getHeadSha` can fail if the folder isn't a git repo, etc.
+			// Treat as "not checked out" — the button stays enabled and
+			// the user can attempt a switch (which will surface the
+			// underlying error if the workspace is genuinely broken).
+			this.logService.debug?.('[krt] refreshCheckoutStatus failed', err);
+			if (this.isCheckedOut) {
+				this.isCheckedOut = false;
+				this.updateHeaderActionsEnablement();
+			}
+		}
+	}
+
 	private async refreshCurrentPr(): Promise<void> {
 		const input = this.currentInput;
 		if (!input) {
@@ -532,6 +613,9 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		this.titleElement.textContent = pr.title;
 		this.applyStatePill(pr.state);
 		this.updateHeaderActionsEnablement();
+		// Async — kicks off a HEAD-SHA check that may flip the Check
+		// Out button to "Checked out" if we're already on PR head.
+		void this.refreshCheckoutStatus();
 		this.bodyDisposables.clear();
 		DOM.clearNode(this.subModeBarElement);
 		DOM.clearNode(this.bodyElement);
-- 
