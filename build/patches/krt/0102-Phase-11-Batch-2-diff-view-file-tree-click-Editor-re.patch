+
+/* ---------- Phase 11 — AI inline chips ---------- */
+
+/*
+ * Chips render as Monaco "after" injected text. The selectors target
+ * the inline class we set on the decoration (`krt-tour-chip` plus a
+ * severity modifier). Text is intentionally a tiny pill — hover
+ * exposes the full body via Monaco's standard hover system.
+ */
+.krt-tour-chip {
+	font-size: 11px;
+	padding: 0 6px;
+	margin-left: 8px;
+	border-radius: 999px;
+	border: 1px solid transparent;
+	letter-spacing: 0.01em;
+	font-style: normal;
+	white-space: nowrap;
+}
+
+.krt-tour-chip-info {
+	color: var(--vscode-descriptionForeground, #888);
+	background: rgba(110, 118, 129, 0.18);
+	border-color: rgba(110, 118, 129, 0.35);
+}
+
+.krt-tour-chip-note {
+	color: var(--vscode-textLink-foreground, #4493f8);
+	background: rgba(80, 110, 230, 0.16);
+	border-color: rgba(80, 110, 230, 0.35);
+}
+
+.krt-tour-chip-warn {
+	color: var(--vscode-editorWarning-foreground, #c2c200);
+	background: rgba(194, 194, 0, 0.16);
+	border-color: rgba(194, 194, 0, 0.45);
+}
