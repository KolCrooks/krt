From 31c26d80ec05fa0a7b31448813c61432b0e540c2 Mon Sep 17 00:00:00 2001
From: KRT <krt@local>
Date: Mon, 4 May 2026 17:00:16 -0400
Subject: [PATCH] Phase 2: hide command center & layout controls

---
 .../krt/browser/chrome/krtChrome.contribution.ts       | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/chrome/krtChrome.contribution.ts b/src/vs/workbench/contrib/krt/browser/chrome/krtChrome.contribution.ts
index f42c09f3357..ffc83b9e6bf 100644
--- a/src/vs/workbench/contrib/krt/browser/chrome/krtChrome.contribution.ts
+++ b/src/vs/workbench/contrib/krt/browser/chrome/krtChrome.contribution.ts
@@ -8,12 +8,16 @@ import { Extensions as ConfigurationExtensions, IConfigurationRegistry } from '.
 import { KeybindingsRegistry, KeybindingWeight } from '../../../../../platform/keybinding/common/keybindingsRegistry.js';
 import { Registry } from '../../../../../platform/registry/common/platform.js';
 
-// Hide the menu bar by default. macOS menu lives in OS chrome regardless, but
-// on Windows/Linux this prevents the upstream menu from claiming the title bar.
-// Users who want it can flip the setting back manually.
+// KRT chrome defaults — menu bar hidden, command center hidden, layout
+// controls hidden. On macOS the OS draws traffic lights regardless; on
+// Windows/Linux this strips the upstream menu/command-center clutter from
+// the title bar. Phase 3 swaps the centre region for a `repo · branch`
+// badge once there's PR data to drive it.
 Registry.as<IConfigurationRegistry>(ConfigurationExtensions.Configuration).registerDefaultConfigurations([{
 	overrides: {
 		'window.menuBarVisibility': 'hidden',
+		'window.commandCenter': false,
+		'workbench.layoutControl.enabled': false,
 	},
 }]);
 
