+
+class KrtRefreshPullRequestAction extends Action2 {
+
+	static readonly ID = 'krt.refreshPullRequest';
+
+	constructor() {
+		super({
+			id: KrtRefreshPullRequestAction.ID,
+			title: localize2('krt.refreshPullRequest.title', "Refresh PR"),
+			category: localize2('krt.category', "KRT"),
+			f1: true,
+			precondition: ContextKeyExpr.equals('activeEditor', KrtPullRequestEditorInput.ID),
+			keybinding: {
+				when: ContextKeyExpr.equals('activeEditor', KrtPullRequestEditorInput.ID),
+				weight: KeybindingWeight.WorkbenchContrib + 75,
+				primary: KeyMod.CtrlCmd | KeyCode.KeyR,
+				secondary: [KeyCode.F5],
+				mac: { primary: KeyMod.CtrlCmd | KeyCode.KeyR, secondary: [] },
+			},
+		});
+	}
+
+	override async run(accessor: ServicesAccessor): Promise<void> {
+		const activePane = accessor.get(IEditorService).activeEditorPane;
+		if (activePane instanceof KrtPullRequestEditorPane) {
+			await activePane.refreshPullRequest();
+		}
+	}
+}
+
+registerAction2(KrtRefreshPullRequestAction);
