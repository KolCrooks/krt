+
+import { localize, localize2 } from '../../../../../nls.js';
+import { Action2, registerAction2 } from '../../../../../platform/actions/common/actions.js';
+import { InstantiationType, registerSingleton } from '../../../../../platform/instantiation/common/extensions.js';
+import { ServicesAccessor } from '../../../../../platform/instantiation/common/instantiation.js';
+import { INotificationService, Severity } from '../../../../../platform/notification/common/notification.js';
+import { IQuickInputService, IQuickPickItem } from '../../../../../platform/quickinput/common/quickInput.js';
+import { IEditorService } from '../../../../services/editor/common/editorService.js';
+import { IKrtBotListService, KrtBotListService } from './krtBotListService.js';
+import { getCached } from './krtPrCache.js';
+import { KrtPullRequestEditorInput } from './krtPullRequestEditorInput.js';
+import { IKrtWorkspaceRegistry, KrtWorkspace } from '../workspace/krtWorkspaceRegistry.js';
+
+const KRT_CATEGORY = localize2('krt.category', "KRT");
+
+registerSingleton(IKrtBotListService, KrtBotListService, InstantiationType.Delayed);
+
+/**
+ * Picks the workspace the bot list edits should target. If a PR editor
+ * is open, prefer that PR's workspace. If only one workspace is
+ * registered, use it. Otherwise quick-pick from the registered set.
+ */
+async function pickActiveWorkspace(accessor: ServicesAccessor): Promise<KrtWorkspace | undefined> {
+	const editorService = accessor.get(IEditorService);
+	const registry = accessor.get(IKrtWorkspaceRegistry);
+	const quickInput = accessor.get(IQuickInputService);
+
+	const activeInput = editorService.activeEditor;
+	if (activeInput instanceof KrtPullRequestEditorInput) {
+		const ws = registry.findByOwnerRepo(activeInput.owner, activeInput.repo);
+		if (ws) {
+			return ws;
+		}
+	}
+	const all = registry.getAll();
+	if (all.length === 0) {
+		return undefined;
+	}
+	if (all.length === 1) {
+		return all[0];
+	}
+	type WorkspacePick = IQuickPickItem & { workspace: KrtWorkspace };
+	const picked = await quickInput.pick<WorkspacePick>(
+		all.map(ws => ({
+			label: `${ws.owner}/${ws.repo}`,
+			description: ws.folderPath,
+			workspace: ws,
+		})),
+		{ placeHolder: localize('krt.bots.pickWorkspace', "Pick a workspace") },
+	);
+	return picked?.workspace;
+}
+
+class KrtAddBotAction extends Action2 {
+	static readonly ID = 'krt.bots.add';
+
+	constructor() {
+		super({
+			id: KrtAddBotAction.ID,
+			title: localize2('krt.bots.add.title', "Add Bot User…"),
+			category: KRT_CATEGORY,
+			f1: true,
+		});
+	}
+
+	override async run(accessor: ServicesAccessor): Promise<void> {
+		const editorService = accessor.get(IEditorService);
+		const botList = accessor.get(IKrtBotListService);
+		const notification = accessor.get(INotificationService);
+		const quickInput = accessor.get(IQuickInputService);
+
+		const workspace = await pickActiveWorkspace(accessor);
+		if (!workspace) {
+			notification.notify({
+				severity: Severity.Info,
+				message: localize(
+					'krt.bots.add.noWorkspace',
+					"Add a workspace first — bot lists are scoped per workspace.",
+				),
+			});
+			return;
+		}
+
+		// Build the picker from the active PR's commenters when one is
+		// open. Free-form input is the fallback when no PR is active.
+		const candidates = new Map<string, string>(); // login -> displayName
+		const activeInput = editorService.activeEditor;
+		if (activeInput instanceof KrtPullRequestEditorInput) {
+			const cached = getCached(activeInput.url);
+			if (cached) {
+				const seen = new Set<string>();
+				const collect = (login: string) => {
+					if (login && !seen.has(login.toLowerCase())) {
+						seen.add(login.toLowerCase());
+						candidates.set(login, login);
+					}
+				};
+				for (const c of cached.pr.comments) { collect(c.author.login); }
+				for (const ev of cached.activity ?? []) { collect(ev.actor.login); }
+				if (cached.reviewComments) {
+					for (const c of cached.reviewComments) { collect(c.author.login); }
+				}
+			}
+		}
+
+		const existing = new Set(botList.getBots(workspace.folderUri).map(l => l.toLowerCase()));
+		const picker = quickInput.createQuickPick();
+		picker.title = localize('krt.bots.add.pickerTitle', "Add bot user — {0}/{1}", workspace.owner, workspace.repo);
+		picker.placeholder = localize('krt.bots.add.placeholder', "Pick a commenter or type a GitHub username");
+		picker.items = [...candidates.values()]
+			.filter(login => !existing.has(login.toLowerCase()))
+			.sort()
+			.map(login => ({ label: login }));
+
+		const login = await new Promise<string | undefined>(resolve => {
+			picker.onDidAccept(() => {
+				const selected = picker.selectedItems[0]?.label;
+				const typed = picker.value.trim();
+				resolve(selected ?? (typed.length > 0 ? typed : undefined));
+				picker.hide();
+			});
+			picker.onDidHide(() => resolve(undefined));
+			picker.show();
+		});
+		picker.dispose();
+		if (!login) {
+			return;
+		}
+
+		botList.addBot(workspace.folderUri, login);
+		notification.notify({
+			severity: Severity.Info,
+			message: localize(
+				'krt.bots.add.success',
+				"Added `{0}` to the bot list for {1}/{2}.",
+				login,
+				workspace.owner,
+				workspace.repo,
+			),
+		});
+	}
+}
+
+class KrtRemoveBotAction extends Action2 {
+	static readonly ID = 'krt.bots.remove';
+
+	constructor() {
+		super({
+			id: KrtRemoveBotAction.ID,
+			title: localize2('krt.bots.remove.title', "Remove Bot User…"),
+			category: KRT_CATEGORY,
+			f1: true,
+		});
+	}
+
+	override async run(accessor: ServicesAccessor): Promise<void> {
+		const botList = accessor.get(IKrtBotListService);
+		const notification = accessor.get(INotificationService);
+		const quickInput = accessor.get(IQuickInputService);
+
+		const workspace = await pickActiveWorkspace(accessor);
+		if (!workspace) {
+			return;
+		}
+		const bots = botList.getBots(workspace.folderUri);
+		if (bots.length === 0) {
+			notification.notify({
+				severity: Severity.Info,
+				message: localize(
+					'krt.bots.remove.empty',
+					"No bots configured for {0}/{1}.",
+					workspace.owner,
+					workspace.repo,
+				),
+			});
+			return;
+		}
+		const picked = await quickInput.pick(
+			bots.map(login => ({ label: login })),
+			{ placeHolder: localize('krt.bots.remove.placeholder', "Pick a bot to remove") },
+		);
+		if (!picked) {
+			return;
+		}
+		botList.removeBot(workspace.folderUri, picked.label);
+		notification.notify({
+			severity: Severity.Info,
+			message: localize(
+				'krt.bots.remove.success',
+				"Removed `{0}` from the bot list for {1}/{2}.",
+				picked.label,
+				workspace.owner,
+				workspace.repo,
+			),
+		});
+	}
+}
+
+registerAction2(KrtAddBotAction);
+registerAction2(KrtRemoveBotAction);
