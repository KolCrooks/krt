From 4b568729118a3cdef64b01113e08194f719e880d Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 16:21:20 -0400
Subject: [PATCH] Phase D polish: only scroll on collapse when the card is
 off-screen

Reported: collapsing a card that's already on-screen scrolls the
page unnecessarily.

Cause: `toggleCollapsed` always called `card.scrollIntoView({ block:
'start' })` after marking the card collapsed. The intent was to
anchor at the header so the next card didn't jump up under the
user's reading position -- but if the card is already in the
viewport, that's an unwanted forced scroll.

Check the card's vertical overlap with the window viewport before
scrolling. If any part of the card is on-screen, leave scroll
alone. Only scroll when the user has scrolled past the card and
collapsing would otherwise leave the post-collapse content in an
unanchored position.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 .../contrib/krt/browser/pr/krtPrFlatDiff.ts       | 15 +++++++++++----
 1 file changed, 11 insertions(+), 4 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
index 0f271c8dd5c..aca33f4b83c 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
@@ -215,10 +215,17 @@ export class KrtPrFlatDiff extends Disposable {
 			if (willCollapse) {
 				this.collapsedPaths.add(file.path);
 				card.classList.add('collapsed');
-				// Anchor at the just-collapsed header so the next card
-				// doesn't jump up the page under the user's reading
-				// position.
-				card.scrollIntoView({ block: 'start' });
+				// Anchor at the just-collapsed header *only* if the
+				// card's header has scrolled out of view. Always
+				// scrolling on collapse fights the user when the card
+				// they're collapsing is already on-screen.
+				const rect = card.getBoundingClientRect();
+				const win = DOM.getWindow(card);
+				const viewportHeight = win?.innerHeight ?? 0;
+				const inViewport = rect.bottom > 0 && rect.top < viewportHeight;
+				if (!inViewport) {
+					card.scrollIntoView({ block: 'start' });
+				}
 			} else {
 				this.collapsedPaths.delete(file.path);
 				card.classList.remove('collapsed');
-- 
