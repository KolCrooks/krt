 .../krt/browser/tabs/krtTabs.contribution.ts  |  9 +++++++
 .../contrib/krt/browser/tabs/krtTabs.css      | 24 +++++++++++++++++++
 3 files changed, 34 insertions(+)
 create mode 100644 src/vs/workbench/contrib/krt/browser/tabs/krtTabs.contribution.ts
 create mode 100644 src/vs/workbench/contrib/krt/browser/tabs/krtTabs.css

diff --git a/src/vs/workbench/contrib/krt/browser/krt.contribution.ts b/src/vs/workbench/contrib/krt/browser/krt.contribution.ts
index 8fbd861f573..658f31786d4 100644
--- a/src/vs/workbench/contrib/krt/browser/krt.contribution.ts
+++ b/src/vs/workbench/contrib/krt/browser/krt.contribution.ts
@@ -14,6 +14,7 @@ import { IStatusbarService, StatusbarAlignment } from '../../../services/statusb
 // on import. Keep this list flat so each piece is easy to find.
 import './theme/krtAccent.contribution.js';
 import './chrome/krtChrome.contribution.js';
+import './tabs/krtTabs.contribution.js';
 
 class KrtStatusBarContribution extends Disposable implements IWorkbenchContribution {
 
diff --git a/src/vs/workbench/contrib/krt/browser/tabs/krtTabs.contribution.ts b/src/vs/workbench/contrib/krt/browser/tabs/krtTabs.contribution.ts
new file mode 100644
index 00000000000..5d026ae946f
