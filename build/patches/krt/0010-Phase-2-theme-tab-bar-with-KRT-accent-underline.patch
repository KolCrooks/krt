+// Pure CSS contribution — no JS. The import alone is enough to bundle the
+// stylesheet into the workbench CSS bundle. Lives as a contribution so it
+// shows up in the KRT barrel alongside theme/chrome/etc.
+import './krtTabs.css';
diff --git a/src/vs/workbench/contrib/krt/browser/tabs/krtTabs.css b/src/vs/workbench/contrib/krt/browser/tabs/krtTabs.css
new file mode 100644
index 00000000000..2f2068e4372
--- /dev/null
+++ b/src/vs/workbench/contrib/krt/browser/tabs/krtTabs.css
@@ -0,0 +1,24 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+/* KRT tab-bar theming. Active tab gets a 2px accent underline (drawn as an
+ * inset shadow so it doesn't compete with the upstream tab-border slots).
+ * Phase 3 will add a per-mode dot (review / editor / view) once tabs carry
+ * a viewMode; until then this just brands the active tab in KRT colours. */
+
+.monaco-workbench .part.editor > .content .editor-group-container > .title .tabs-container > .tab.active::after {
+	content: '';
+	position: absolute;
+	left: 0;
+	right: 0;
+	bottom: 0;
+	height: 2px;
+	background: var(--krt-accent);
+	pointer-events: none;
+}
+
+.monaco-workbench .part.editor > .content .editor-group-container > .title .tabs-container > .tab {
+	position: relative;
+}
