+	/**
+	 * Inline toggle on each comment header that flips the author's bot
+	 * status for the active workspace. Renders nothing when no
+	 * workspace is registered for the PR (the bot list has no scope to
+	 * land in). Visible on hover so it doesn't clutter the timeline.
+	 */
+	private renderBotToggle(parent: HTMLElement, login: string): void {
+		const pr = this.currentPr;
+		if (!pr) {
+			return;
+		}
+		const workspace = this.workspaceRegistry.findByOwnerRepo(pr.owner, pr.repo);
+		if (!workspace) {
+			return;
+		}
+		const isBot = this.botListService.isBot(workspace.folderUri, login);
+		const btn = DOM.append(parent, DOM.$('button.krt-pr-comment-bot-toggle')) as HTMLButtonElement;
+		btn.type = 'button';
+		if (isBot) {
+			btn.classList.add('active');
+			btn.textContent = localize('krt.pr.botToggle.unmark', "Move to Discussion");
+			btn.title = localize(
+				'krt.pr.botToggle.unmark.tooltip',
+				"Stop treating `{0}` as a bot in {1}/{2}.",
+				login,
+				workspace.owner,
+				workspace.repo,
+			);
+		} else {
+			btn.textContent = localize('krt.pr.botToggle.mark', "Move to Automation");
+			btn.title = localize(
+				'krt.pr.botToggle.mark.tooltip',
+				"Treat `{0}` as a bot in {1}/{2}. Their comments will route to the Automation tab.",
+				login,
+				workspace.owner,
+				workspace.repo,
+			);
+		}
+		this.bodyDisposables.add(DOM.addDisposableListener(btn, 'click', e => {
+			e.stopPropagation();
+			if (isBot) {
+				this.botListService.removeBot(workspace.folderUri, login);
+			} else {
+				this.botListService.addBot(workspace.folderUri, login);
+			}
+		}));
+	}
+
