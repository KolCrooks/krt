From 3b63795db7cfdd96a026536f68840ac9d105e718 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 16:18:43 -0400
Subject: [PATCH] Phase D polish: collapsible diff cards

Each `KrtPrFlatDiff` card now has a clickable header with a chevron
that toggles the card's collapsed state. Click anywhere on the
header (except interactive children -- buttons, labels) to toggle;
Enter / Space toggle when the header is keyboard-focused.

Collapsed state persists across `setPullRequest` re-renders (e.g.
when the side-by-side / inline toggle re-renders the pane) but
not across `KrtPrFlatDiff` instance disposal -- which matches how
this is scoped per-pane instance anyway.

Collapsing scrolls the card's header to the top of the viewport
so the next card doesn't jump up under the user's reading
position.

Header gets `role="button" tabindex="0"` for keyboard activation
+ `:focus-visible` outline for keyboard users.

CSS:
- `.krt-pr-flat-diff-caret` chevron, rotates -90deg when collapsed.
- `.collapsed .krt-pr-flat-diff-editor { display: none }` hides the
  body. The DiffEditorWidget stays mounted so re-expanding is
  instant.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 .../contrib/krt/browser/pr/krtPrFlatDiff.ts   | 51 +++++++++++++++++--
 .../browser/pr/krtPullRequestEditorPane.css   | 29 +++++++++++
 2 files changed, 77 insertions(+), 3 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
index 4a08800a2dc..0f271c8dd5c 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrFlatDiff.ts
@@ -50,6 +50,14 @@ export class KrtPrFlatDiff extends Disposable {
 
 	private renderStore = this._register(new DisposableStore());
 	private cardsByPath = new Map<string, HTMLElement>();
+	/**
+	 * Persists collapsed state across `setPullRequest` re-renders
+	 * (e.g. when the user flips the side-by-side / inline toggle the
+	 * pane re-renders, but a card the user collapsed should stay
+	 * collapsed). Keyed on the file's path; cleared when the
+	 * `KrtPrFlatDiff` itself disposes.
+	 */
+	private collapsedPaths = new Set<string>();
 
 	constructor(
 		private readonly container: HTMLElement,
@@ -173,11 +181,17 @@ export class KrtPrFlatDiff extends Disposable {
 			}));
 		}
 
-		// DOM: card with a header (status / path / +- counts) and an
-		// auto-sized editor body. Keeps the same visual idiom the
-		// per-file sections used in earlier diff iterations.
+		// DOM: card with a header (caret / status / path / +- counts)
+		// and an auto-sized editor body. Click the header (anywhere
+		// except interactive children) to collapse / expand.
 		const card = DOM.append(this.container, DOM.$('.krt-pr-flat-diff-card'));
+		if (this.collapsedPaths.has(file.path)) {
+			card.classList.add('collapsed');
+		}
 		const head = DOM.append(card, DOM.$('.krt-pr-flat-diff-head'));
+		head.setAttribute('role', 'button');
+		head.setAttribute('tabindex', '0');
+		DOM.append(head, DOM.$('span.krt-pr-flat-diff-caret.codicon.codicon-chevron-down'));
 		const status = DOM.append(head, DOM.$('span.krt-pr-flat-diff-status'));
 		status.classList.add(file.status);
 		status.textContent = statusGlyph(file.status);
@@ -193,6 +207,37 @@ export class KrtPrFlatDiff extends Disposable {
 		const del = DOM.append(counts, DOM.$('span.del'));
 		del.textContent = `-${file.deletions}`;
 
+		// Click anywhere on the header (except interactive children)
+		// toggles the card. Enter / Space activate too for keyboard
+		// users since we set `role="button" tabindex="0"`.
+		const toggleCollapsed = () => {
+			const willCollapse = !card.classList.contains('collapsed');
+			if (willCollapse) {
+				this.collapsedPaths.add(file.path);
+				card.classList.add('collapsed');
+				// Anchor at the just-collapsed header so the next card
+				// doesn't jump up the page under the user's reading
+				// position.
+				card.scrollIntoView({ block: 'start' });
+			} else {
+				this.collapsedPaths.delete(file.path);
+				card.classList.remove('collapsed');
+			}
+		};
+		store.add(DOM.addDisposableListener(head, 'click', e => {
+			const target = e.target as HTMLElement | null;
+			if (target?.closest('label, input, button, a')) {
+				return;
+			}
+			toggleCollapsed();
+		}));
+		store.add(DOM.addDisposableListener(head, 'keydown', e => {
+			if (e.key === 'Enter' || e.key === ' ') {
+				e.preventDefault();
+				toggleCollapsed();
+			}
+		}));
+
 		const editorContainer = DOM.append(card, DOM.$('.krt-pr-flat-diff-editor'));
 
 		// One DiffEditorWidget per file, default contributions so
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
index eff0960857f..e3df418c5ee 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
@@ -828,6 +828,35 @@
 	background: var(--vscode-editorGroupHeader-tabsBackground, transparent);
 	border-bottom: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.25));
 	font-size: 12px;
+	cursor: pointer;
+	user-select: none;
+}
+
+.krt-pr-flat-diff-head:hover {
+	background: var(--vscode-toolbar-hoverBackground, rgba(127, 127, 127, 0.1));
+}
+
+.krt-pr-flat-diff-head:focus-visible {
+	outline: 1px solid var(--vscode-focusBorder, var(--vscode-button-background));
+	outline-offset: -1px;
+}
+
+.krt-pr-flat-diff-caret {
+	font-size: 14px;
+	color: var(--vscode-descriptionForeground);
+	transition: transform 120ms ease;
+}
+
+.krt-pr-flat-diff-card.collapsed .krt-pr-flat-diff-caret {
+	transform: rotate(-90deg);
+}
+
+.krt-pr-flat-diff-card.collapsed .krt-pr-flat-diff-head {
+	border-bottom-color: transparent;
+}
+
+.krt-pr-flat-diff-card.collapsed .krt-pr-flat-diff-editor {
+	display: none;
 }
 
 .krt-pr-flat-diff-status {
-- 
