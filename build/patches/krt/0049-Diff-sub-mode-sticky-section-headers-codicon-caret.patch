From 564a29370e7917872d4a049c46ae7635eef33cc9 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 14:15:09 -0400
Subject: [PATCH] Diff sub-mode: sticky section headers + codicon caret
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Headers (`.krt-pr-diff-section-head`) are `position: sticky; top: 0`
  so they pin to the top of the outer `.krt-pr-editor` scroll while
  the section is in view. Long diffs let you collapse without
  scrolling back to the header.
- Switched the caret from a thin unicode glyph to
  `codicon-chevron-down` — clean, sized to match the workbench, and
  rotates on `.collapsed` via the existing CSS transition.
- Removed `overflow: hidden` from `.krt-pr-diff-section` (it was for
  rounded-corner clipping but breaks sticky positioning when the
  section is taller than the viewport). Added bottom rounding on
  `.krt-pr-diff-monaco` and top rounding on the head so the card
  still has the same visual frame.
---
 .../krt/browser/pr/krtPullRequestEditorPane.css  | 16 +++++++++++-----
 .../krt/browser/pr/krtPullRequestEditorPane.ts   |  4 +---
 2 files changed, 12 insertions(+), 8 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
index 5ffef30ba8f..dfc34d948e4 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.css
@@ -912,8 +912,8 @@
 .krt-pr-diff-section {
 	border: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
 	border-radius: 6px;
-	overflow: hidden;
 	scroll-margin-top: 8px;
+	/* overflow: visible by default — sticky headers below need a non-overflow-clipped containing block. */
 }
 
 .krt-pr-diff-section.reviewed {
@@ -927,6 +927,7 @@
 
 .krt-pr-diff-section.collapsed > .krt-pr-diff-section-head {
 	border-bottom: none;
+	border-radius: 6px;
 }
 
 .krt-pr-diff-section.collapsed .krt-pr-diff-section-caret {
@@ -939,16 +940,20 @@
 	gap: 10px;
 	padding: 8px 12px;
 	border-bottom: 1px solid var(--vscode-widget-border, rgba(127, 127, 127, 0.3));
-	background: var(--vscode-editorWidget-background, rgba(127, 127, 127, 0.05));
+	background: var(--vscode-editorWidget-background, rgba(127, 127, 127, 0.06));
 	font-size: 12px;
 	cursor: pointer;
 	user-select: none;
+	/* Sticky within the outer .krt-pr-editor scroll — pins to viewport top while section is in view, slides off when the section ends. */
+	position: sticky;
+	top: 0;
+	z-index: 2;
+	border-radius: 6px 6px 0 0;
 }
 
 .krt-pr-diff-section-caret {
-	display: inline-block;
-	font-size: 10px;
-	width: 10px;
+	flex: 0 0 auto;
+	font-size: 14px;
 	color: var(--vscode-descriptionForeground);
 	transition: transform 80ms ease-out;
 }
@@ -1013,6 +1018,7 @@
 .krt-pr-diff-monaco {
 	width: 100%;
 	overflow: hidden;
+	border-radius: 0 0 6px 6px;
 }
 
 .krt-pr-diff-zone-host {
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
index e0b2d52fcc0..290f9481367 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
@@ -945,9 +945,7 @@ export class KrtPullRequestEditorPane extends EditorPane {
 				section.classList.add('collapsed');
 			}
 		}));
-		const caret = DOM.append(head, DOM.$('span.krt-pr-diff-section-caret'));
-		// allow-any-unicode-next-line
-		caret.textContent = '▾';
+		DOM.append(head, DOM.$('span.krt-pr-diff-section-caret.codicon.codicon-chevron-down'));
 		const status = DOM.append(head, DOM.$('span.krt-pr-diff-status-dot'));
 		status.classList.add(file.status);
 		status.textContent = statusGlyph(file.status);
-- 
2.52.0

