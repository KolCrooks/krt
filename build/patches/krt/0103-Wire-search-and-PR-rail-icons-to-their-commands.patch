From 6c849241eb92c393d6da521858821ad10f4d6799 Mon Sep 17 00:00:00 2001
From: julietmoss <juliet.moss@datadoghq.com>
Date: Tue, 12 May 2026 15:38:13 -0400
Subject: [PATCH 1/4] Wire search and PR rail icons to their commands

---
 src/vs/workbench/services/krt/browser/krtRail.ts | 9 +++++----
 1 file changed, 5 insertions(+), 4 deletions(-)

diff --git a/src/vs/workbench/services/krt/browser/krtRail.ts b/src/vs/workbench/services/krt/browser/krtRail.ts
index 8f8cac320bc..d8a6dab1191 100644
--- a/src/vs/workbench/services/krt/browser/krtRail.ts
+++ b/src/vs/workbench/services/krt/browser/krtRail.ts
@@ -22,15 +22,16 @@ const KRT_RAIL_BUTTONS: ReadonlyArray<KrtRailButton> = [
 		key: 'search',
 		icon: 'search',
 		tooltip: localize('krt.rail.search', "Search PRs"),
-		// Phase 4 wires this to the KRT search overlay.
-		onClick: () => { /* no-op until Phase 4 */ },
+		// Opens the KRT search overlay (same as ⌘K).
+		onClick: commandService => { commandService.executeCommand('krt.search'); },
 	},
 	{
 		key: 'pr',
 		icon: 'pr',
 		tooltip: localize('krt.rail.pr', "PR view"),
-		// Phase 5 sets the active PR tab's view mode.
-		onClick: () => { /* no-op until Phase 5 */ },
+		// Until Phase 5 can set the active tab's view mode, treat the PR
+		// icon as "open a PR" — same action as F1 → KRT: Open PR.
+		onClick: commandService => { commandService.executeCommand('krt.openPullRequest'); },
 	},
 	{
 		key: 'review',
-- 
