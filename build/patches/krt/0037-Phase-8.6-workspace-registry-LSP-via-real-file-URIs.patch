+export type GhErrorKind = 'gh-missing' | 'gh-auth-expired' | 'gh-rate-limit' | 'gh-invocation' | 'krt-bad-url' | 'git-missing' | 'git-invocation' | 'git-not-a-repo' | 'git-no-remote';
 
