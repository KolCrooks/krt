-			headUri,
-			false,
-		);
-		this._register(toDisposable(() => baseModel.dispose()));
-		this._register(toDisposable(() => headModel.dispose()));
+		const file = opts.file;
+
+		// Per-side URI strategy:
+		//   1. If a workspace is registered for this PR's repo:
+		//      - head: file://<workspace>/<path>   (LSP-eligible)
+		//      - base: krt-git://<workspace>/<baseSha>/<previousPath>  (`git show`)
+		//      But: added files have no base; removed files have no head.
+		//      In those cases fall through to the patch-reconstructed
+		//      virtual fallback for the missing side.
+		//   2. Otherwise (no workspace), both sides use the Phase 8.5
+		//      virtual URIs — same as before, no LSP, but syntax + diff.
+		const reconstructed = reconstructFromPatch(opts.file.patch ?? '');
+
+		const baseModel = (() => {
+			if (opts.workspace && file.status !== 'added') {
+				const krtGitUri = encodeKrtGit(opts.workspace.folderUri, opts.baseSha, previousPath);
+				const existing = modelService.getModel(krtGitUri);
+				if (existing) {
+					return existing;
+				}
+				// Create an empty model now; the krt-git:// content provider
+				// fills it in on first model resolution. We populate the
+				// reconstructed text as a synchronous fallback so the diff
+				// has *something* to render until the async git-show lands.
+				return modelService.createModel(
+					reconstructed.base,
+					languageService.createByFilepathOrFirstLine(URI.file(previousPath)),
+					krtGitUri,
+					false,
+				);
+			}
+			const baseUri = URI.parse(`krt-pr-base://${encodeURIComponent(opts.owner)}/${encodeURIComponent(opts.repo)}/${encodeURIComponent(opts.baseSha)}/${encodeURI(previousPath)}`);
+			return modelService.createModel(
+				reconstructed.base,
+				languageService.createByFilepathOrFirstLine(baseUri),
+				baseUri,
+				false,
+			);
+		})();
+
+		const headModel: ITextModel = (() => {
+			if (opts.workspace && file.status !== 'removed') {
+				const headFileUri = URI.joinPath(URI.file(opts.workspace.folderPath), path);
+				const existing = modelService.getModel(headFileUri);
+				if (existing) {
+					// Existing file:// model from the workspace — perfect.
+					// Don't let our Disposable destroy it on `dispose()`;
+					// the workbench owns its lifetime.
+					return existing;
+				}
+				// No file:// model exists yet — create a virtual head model
+				// instead. The demo gate verifies the LSP path; this branch
+				// is the graceful fallback when the user hasn't opened the
+				// file in the workbench tree.
+			}
+			const headUri = URI.parse(`krt-pr-head://${encodeURIComponent(opts.owner)}/${encodeURIComponent(opts.repo)}/${encodeURIComponent(opts.headSha)}/${encodeURI(path)}`);
+			return modelService.createModel(
+				reconstructed.head,
+				languageService.createByFilepathOrFirstLine(headUri),
+				headUri,
+				false,
+			);
+		})();
+
+		// Only dispose models we own (i.e. created above). Models that
+		// pre-existed (file:// from the open workbench tree) are not ours
+		// to dispose.
+		const ownsBase = baseModel.uri.scheme !== 'file';
+		const ownsHead = headModel.uri.scheme !== 'file';
+		this._register(toDisposable(() => {
+			if (ownsBase) { baseModel.dispose(); }
+			if (ownsHead) { headModel.dispose(); }
+		}));
 
 		this.widget.setModel({ original: baseModel, modified: headModel });
 
