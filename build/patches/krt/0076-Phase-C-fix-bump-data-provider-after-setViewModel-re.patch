 .../krt/browser/pr/krtPrCommentController.ts  | 34 +++++++++-
 .../contrib/krt/browser/pr/krtPrMultiDiff.ts  | 16 +++++
 .../pr/krtPullRequestEditor.contribution.ts   |  1 +
 4 files changed, 115 insertions(+), 1 deletion(-)
