From 46b2836613ca392c178efd7e8af36ba467da2787 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 14:00:42 -0400
Subject: [PATCH] Monaco diff: static height from patch, no polling
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Final answer: stop reading `getContentHeight()` to size the card.
Compute the height up-front from the patch — every non-meta line is
one row, every hunk implies one "+ N hidden lines" widget. That's
deterministic and matches what `hideUnchangedRegions` will render
once the autorun fires.

- `estimateEditorHeight(patch)`: counts visible lines + hunks, returns
  `lines * 19 + (hunks + 1) * 28 + 12`. Computed once at construction.
- `automaticLayout: true` so Monaco tracks wrapper width itself.
- The wrapper's `style.height` is set ONCE to the static estimate
  during construction. No settling poll, no waitForDiff, no rAF
  dance, no `getContentHeight` calls during render.
- `onDidContentSizeChange` is the one runtime hook — it covers
  changes the static estimate can't predict (review-comment view
  zones, user expanding a hidden region). Refreshes the wrapper
  height from `getContentHeight()` only when an event fires, never
  speculatively.

Removed:
- `INITIAL_CARD_HEIGHT_PX`, `MAX_CARD_HEIGHT_PX` constants — no caps,
  no placeholder.
- `startSettlingPoll` and `layoutToContent` private methods.
- `widget.layout()` calls during construction (handled by automaticLayout).
---
 .../contrib/krt/browser/pr/krtMonacoDiff.ts   | 149 +++++++++---------
 1 file changed, 71 insertions(+), 78 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
index 3d845fc45fb..045f6fc68ef 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
@@ -45,15 +45,55 @@ interface ILineZoneOptions {
 	readonly domNode: HTMLElement;
 }
 
-// Card sizing: hug content with no upper cap. The user scrolls the
-// outer PR pane; cards stack vertically at their natural heights.
+// Card sizing — STATIC. We compute the editor's height from the patch
+// up-front: every visible line in the patch becomes one row in the
+// rendered diff, and each hunk implies a "+ N hidden lines" widget
+// from Monaco's `hideUnchangedRegions` feature. Both are
+// deterministic — the height is knowable before Monaco has rendered
+// anything, so we never read `getContentHeight()` or poll. The wrapper
+// element itself is *not* JS-sized; instead we pass the height to
+// `widget.layout({width, height})` and Monaco writes it onto its own
+// outer DOM, which the wrapper natural-fits via `height: auto`.
 //
-// `INITIAL_CARD_HEIGHT_PX` gives the inner editors a non-zero
-// container to lay out into on first paint — Monaco won't compute a
-// content height until it has rendered at least once.
-const INITIAL_CARD_HEIGHT_PX = 240;
+// `onDidContentSizeChange` still drives re-layout for content growth
+// that ISN'T knowable from the patch (review-comment view zones,
+// user expanding a hidden region) — those rare events refit Monaco
+// directly without touching the wrapper's CSS.
+const LINE_HEIGHT_PX = 19;
+const HIDDEN_REGION_WIDGET_PX = 28;
 const MIN_CARD_HEIGHT_PX = 80;
-const CARD_CHROME_PX = 8;
+const CARD_CHROME_PX = 12;
+
+/**
+ * Compute the editor height we expect Monaco to render the patch at.
+ * Counts non-meta lines in the patch (each becomes one view-row) plus
+ * one hidden-region placeholder widget per hunk (a slight overestimate
+ * — `hunks + 1` would be exact when the file has content both before
+ * the first hunk and after the last, which is the common case; we use
+ * `hunks + 1` to err safely toward enough room).
+ */
+function estimateEditorHeight(patch: string | undefined): number {
+	if (!patch) {
+		return MIN_CARD_HEIGHT_PX;
+	}
+	let visibleLines = 0;
+	let hunks = 0;
+	for (const raw of patch.split('\n')) {
+		if (raw.startsWith('@@')) {
+			hunks++;
+		} else if (raw.length === 0 || raw.startsWith('\\')) {
+			// trailing blank line (split artifact) or "\ No newline at end of file"
+			continue;
+		} else {
+			visibleLines++;
+		}
+	}
+	const widgets = hunks + 1;
+	return Math.max(
+		visibleLines * LINE_HEIGHT_PX + widgets * HIDDEN_REGION_WIDGET_PX + CARD_CHROME_PX,
+		MIN_CARD_HEIGHT_PX,
+	);
+}
 
 /**
  * Embeds Monaco's `DiffEditorWidget` in a container, populates it with
@@ -80,7 +120,10 @@ export class KrtMonacoDiffView extends Disposable {
 		super();
 
 		this.container = DOM.append(parent, DOM.$('.krt-pr-diff-monaco'));
-		this.container.style.height = `${INITIAL_CARD_HEIGHT_PX}px`;
+		// One-shot static height from the patch — see `estimateEditorHeight`.
+		// No polling, no `getContentHeight`-races. The width comes from
+		// `automaticLayout: true` watching the wrapper's CSS-driven width.
+		this.container.style.height = `${estimateEditorHeight(opts.file.patch)}px`;
 
 		this.widget = this._register(instantiationService.createInstance(
 			DiffEditorWidget,
@@ -96,17 +139,14 @@ export class KrtMonacoDiffView extends Disposable {
 					minimumLineCount: 4,
 				},
 				renderOverviewRuler: false,
-				// We control the height via `layoutToContent`; automatic
-				// layout would fight us by re-fitting to its container.
-				automaticLayout: false,
+				// `automaticLayout: true` makes Monaco observe the
+				// wrapper for both width and height. Width comes from
+				// CSS (parent grid/flex); height comes from the inline
+				// style we set above (one-shot, derived from the patch).
+				// No JS event listeners, no polling.
+				automaticLayout: true,
 				scrollBeyondLastLine: false,
 				minimap: { enabled: false },
-				scrollbar: {
-					// When the card hits MAX_CARD_HEIGHT_PX, Monaco owns
-					// the wheel inside; once the user reaches the edge,
-					// the outer pane takes over.
-					alwaysConsumeMouseWheel: false,
-				},
 				lineNumbersMinChars: 4,
 			},
 			{
@@ -210,67 +250,20 @@ export class KrtMonacoDiffView extends Disposable {
 		// Leave them in `IModelService` for the workbench's lifetime; they
 		// share a URI per (owner, repo, sha, path) so memory stays bounded.
 
-		this.widget.layout();
-		// `onDidContentSizeChange` covers post-settle changes — the user
-		// expanding a "Show N unchanged lines" region, a comment thread's
-		// markdown finishing render and growing its view zone, etc.
-		this._register(this.widget.onDidContentSizeChange(() => this.layoutToContent()));
-		// During the construction → diff-compute → hideUnchangedRegions-
-		// applies pipeline, Monaco's events are spread across multiple
-		// reactive ticks and one of them frequently doesn't bubble
-		// through `onDidContentSizeChange` cleanly. Rather than guess
-		// which tick to listen on, poll `getContentHeight()` per frame
-		// until it stabilizes — that's the source of truth and it's
-		// immune to event-order quirks. Bounded by a stability window
-		// (5 consecutive identical reads → done) and a 200-frame fuse
-		// (~3s @ 60fps) so a pathological input can't poll forever.
-		this.startSettlingPoll();
-	}
-
-	private layoutToContent(): void {
-		const target = Math.max(
-			this.widget.getContentHeight() + CARD_CHROME_PX,
-			MIN_CARD_HEIGHT_PX,
-		);
-		if (this.container.clientHeight !== target) {
-			this.container.style.height = `${target}px`;
-			this.widget.layout();
-		}
-	}
-
-	private startSettlingPoll(): void {
-		const win = DOM.getWindow(this.container);
-		let lastHeight = -1;
-		let stableFrames = 0;
-		let framesRemaining = 200;
-		let rafId = 0;
-		let cancelled = false;
-
-		const tick = () => {
-			if (cancelled) {
-				return;
-			}
-			framesRemaining--;
-			const h = this.widget.getContentHeight();
-			if (h !== lastHeight) {
-				lastHeight = h;
-				stableFrames = 0;
-				this.layoutToContent();
-			} else {
-				stableFrames++;
-			}
-			if (stableFrames >= 5 || framesRemaining <= 0) {
-				rafId = 0;
-				return;
-			}
-			rafId = win.requestAnimationFrame(tick);
-		};
-
-		rafId = win.requestAnimationFrame(tick);
-		this._register(toDisposable(() => {
-			cancelled = true;
-			if (rafId) {
-				win.cancelAnimationFrame(rafId);
+		// `onDidContentSizeChange` only matters for changes the static
+		// estimate can't predict — review-comment view zones rendering
+		// markdown, the user expanding a "+ N hidden lines" region. On
+		// any such fire, refresh the wrapper's height from Monaco's
+		// current content height. (This is the one place runtime
+		// re-sizing can happen; on first construction the height is
+		// set up-front from the patch, no Monaco APIs consulted.)
+		this._register(this.widget.onDidContentSizeChange(() => {
+			const target = Math.max(
+				this.widget.getContentHeight() + CARD_CHROME_PX,
+				MIN_CARD_HEIGHT_PX,
+			);
+			if (this.container.clientHeight !== target) {
+				this.container.style.height = `${target}px`;
 			}
 		}));
 	}
