From 5f18eea0abe3142882ec84c8ca9ccedf66774048 Mon Sep 17 00:00:00 2001
From: KRT <krt@local>
Date: Mon, 4 May 2026 16:01:56 -0400
Subject: [PATCH] Skip welcome page on startup; skip copilot engines hygiene
 check

Two related cleanups paired with the extensions/copilot/ removal:

- gettingStarted.contribution.ts: workbench.startupEditor default
  changes from 'welcomePage' to 'none', and
  workbench.welcomePage.experimentalOnboarding default flips to false.
  Result: no upstream 'Get Started with VS Code' page on launch.
  IWalkthroughsService stays registered (consumed by remote.ts).

- hygiene.ts: checkCopilotEnginesVersion() becomes a no-op. The
  upstream check reads extensions/copilot/package.json which
  prepare_vscode.sh removes.
---
 build/hygiene.ts                                   | 14 ++++----------
 .../browser/gettingStarted.contribution.ts         |  4 ++--
 2 files changed, 6 insertions(+), 12 deletions(-)

diff --git a/build/hygiene.ts b/build/hygiene.ts
index 0544879e14f..8910c153bc5 100644
--- a/build/hygiene.ts
+++ b/build/hygiene.ts
@@ -28,17 +28,11 @@ interface VinylFileWithLines extends VinylFile {
 }
 
 /**
- * Checks that engines.vscode in extensions/copilot/package.json matches ^{version} from the root package.json.
- * Returns an error message if mismatched, or undefined if OK.
+ * KRT: extensions/copilot/ is removed by build/prepare_vscode.sh. The original
+ * upstream check verified its engines.vscode matched root; with the dir gone,
+ * the check is a no-op.
  */
-export function checkCopilotEnginesVersion(repoRoot: string): string | undefined {
-	const rootPkg = JSON.parse(fs.readFileSync(path.join(repoRoot, 'package.json'), 'utf8'));
-	const copilotPkg = JSON.parse(fs.readFileSync(path.join(repoRoot, 'extensions/copilot/package.json'), 'utf8'));
-	const expected = `^${rootPkg.version}`;
-	const actual = copilotPkg?.engines?.vscode;
-	if (actual !== expected) {
-		return `engines.vscode in 'extensions/copilot/package.json' must be "${expected}" (the version from the root package.json), but found "${actual ?? '<missing>'}"`;
-	}
+export function checkCopilotEnginesVersion(_repoRoot: string): string | undefined {
 	return undefined;
 }
 
diff --git a/src/vs/workbench/contrib/welcomeGettingStarted/browser/gettingStarted.contribution.ts b/src/vs/workbench/contrib/welcomeGettingStarted/browser/gettingStarted.contribution.ts
index 803f7721998..c84f95e5c0f 100644
--- a/src/vs/workbench/contrib/welcomeGettingStarted/browser/gettingStarted.contribution.ts
+++ b/src/vs/workbench/contrib/welcomeGettingStarted/browser/gettingStarted.contribution.ts
@@ -327,7 +327,7 @@ configurationRegistry.registerConfiguration({
 				localize({ comment: ['This is the description for a setting. Values surrounded by single quotes are not to be translated.'], key: 'workbench.startupEditor.terminal' }, "Open a new terminal in the editor area."),
 				localize({ comment: ['This is the description for a setting. Values surrounded by single quotes are not to be translated.'], key: 'workbench.startupEditor.agentSessionsWelcomePage' }, "Open the Agent Sessions Welcome page. Will override the workbench secondary side bar visibility settings."),
 			],
-			'default': 'welcomePage',
+			'default': 'none', // KRT: don't show the upstream welcome/Get Started page
 			'description': localize('workbench.startupEditor', "Controls which editor is shown at startup, if none are restored from the previous session."),
 			'experiment': { mode: 'auto' }
 		},
@@ -341,7 +341,7 @@ configurationRegistry.registerConfiguration({
 		'workbench.welcomePage.experimentalOnboarding': {
 			scope: ConfigurationScope.APPLICATION,
 			type: 'boolean',
-			default: true,
+			default: false, // KRT: don't show the experimental onboarding overlay on first launch
 			tags: ['experimental'],
 			description: localize('workbench.welcomePage.experimentalOnboarding', "When enabled, show the new onboarding experience instead of the classic walkthrough on first launch."),
 			experiment: {
