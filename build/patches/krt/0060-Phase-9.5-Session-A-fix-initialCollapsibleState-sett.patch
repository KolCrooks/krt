From cb1c3ee3070dc717d0fdea28b42f19dec0bc7b93 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 09:49:18 -0400
Subject: [PATCH] Phase 9.5 Session A: fix initialCollapsibleState setter +
 coalesce registry events

Two issues found via runtime logging:

1. ReviewZoneWidget assigns to commentThread.initialCollapsibleState
   when it constructs (mirroring MainThreadCommentThread). Our
   KrtPrCommentThread only had a getter, so the assignment threw
   'Cannot set property which has only a getter' and the native
   thread widget never rendered. Add the matching setter that
   mutates the backing field and fires onDidChangeInitialCollapsibleState.

2. Re-rendering the PR pane churns 2N URI register/unregister events
   (N files * 2 sides), and each fired applyForPr unconditionally.
   Each applyForPr is itself O(N). With 12 files we burned ~288
   setDocumentComments fires per re-render. Coalesce the registry-
   change handler with queueMicrotask so a burst collapses into a
   single replay.
---
 .../krt/browser/pr/krtPrCommentController.ts  | 21 +++++++++++++++++--
 .../krt/browser/pr/krtPrCommentThread.ts      |  7 +++++++
 2 files changed, 26 insertions(+), 2 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
index 77fab279be6..38002b849f8 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
@@ -84,9 +84,26 @@ export class KrtPrCommentController extends Disposable implements ICommentContro
 		// first `getDocumentComments` call. Without this, comments
 		// loaded before the diff was rendered would stay invisible
 		// until the next pane re-render.
+		//
+		// Microtask-coalesced: a single PR re-render churns O(2N) URI
+		// register/unregister events. Each `applyForPr` is itself O(N)
+		// (one `setDocumentComments` per URI), so naively replaying
+		// per-event is quadratic. Coalescing collapses the burst into
+		// a single replay after the registry stabilises.
+		let scheduled = false;
 		this._register(onDidChangeKrtPrResources(() => {
-			this.logService.info('[krt] comment registry changed, replaying cached comments');
-			this.replayCached();
+			if (scheduled) {
+				return;
+			}
+			scheduled = true;
+			queueMicrotask(() => {
+				scheduled = false;
+				if (this._store.isDisposed) {
+					return;
+				}
+				this.logService.info('[krt] comment registry change burst, replaying cached comments');
+				this.replayCached();
+			});
 		}));
 	}
 
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
index d8b17a78f0f..248c1320716 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentThread.ts
@@ -76,6 +76,13 @@ export class KrtPrCommentThread implements CommentThread<IRange> {
 
 	private _initialCollapsibleState: CommentThreadCollapsibleState | undefined;
 	get initialCollapsibleState(): CommentThreadCollapsibleState | undefined { return this._initialCollapsibleState; }
+	// `ReviewZoneWidget` writes to this when it constructs (matches the
+	// pattern in `MainThreadCommentThread`). Without a setter the
+	// assignment throws and the widget never renders.
+	set initialCollapsibleState(value: CommentThreadCollapsibleState | undefined) {
+		this._initialCollapsibleState = value;
+		this._onDidChangeInitialCollapsibleState.fire(value);
+	}
 	private readonly _onDidChangeInitialCollapsibleState = new Emitter<CommentThreadCollapsibleState | undefined>();
 	readonly onDidChangeInitialCollapsibleState: Event<CommentThreadCollapsibleState | undefined> = this._onDidChangeInitialCollapsibleState.event;
 
