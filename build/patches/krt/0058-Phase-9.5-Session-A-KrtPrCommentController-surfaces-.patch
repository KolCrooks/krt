@@ -0,0 +1,73 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Emitter, Event } from '../../../../../base/common/event.js';
+import { IDisposable, toDisposable } from '../../../../../base/common/lifecycle.js';
+import { URI } from '../../../../../base/common/uri.js';
+
+export type DiffSide = 'LEFT' | 'RIGHT';
+
+/**
+ * Per-side metadata for a diff-editor model URI mounted by
+ * `KrtMonacoDiffView`. The native comments controller reads this to:
+ *   1. translate GitHub's real-file-line anchors into the model's
+ *      compact 1..N line numbers, and
+ *   2. compute commenting ranges (every model line that maps to a real
+ *      file line is commentable).
+ *
+ * `previousPath` differs from `path` only on renames. For LEFT-side
+ * comments GitHub keys on the pre-rename path, so the controller uses
+ * `previousPath` when matching; RIGHT-side uses `path`.
+ */
+export interface IKrtPrResource {
+	readonly side: DiffSide;
+	readonly path: string;
+	readonly previousPath: string;
+	readonly realLines: ReadonlyArray<number | undefined>;
+	readonly pr: {
+		readonly url: string;
+		readonly owner: string;
+		readonly repo: string;
+		readonly number: number;
+		readonly headSha: string;
+	};
+}
+
+const registry = new Map<string, IKrtPrResource>();
+const _onDidChange = new Emitter<void>();
+export const onDidChangeKrtPrResources: Event<void> = _onDidChange.event;
+
+/**
+ * Called by `KrtMonacoDiffView` once per model URI it mounts. The
+ * returned disposable removes the entry — but only if it still points
+ * at the same `resource` instance, so a later registration on the
+ * same URI (overlapping diff views during re-render) doesn't get
+ * clobbered when the previous one disposes.
+ */
+export function registerKrtPrResource(uri: URI, resource: IKrtPrResource): IDisposable {
+	const key = uri.toString();
+	registry.set(key, resource);
+	_onDidChange.fire();
+	return toDisposable(() => {
+		if (registry.get(key) === resource) {
+			registry.delete(key);
+			_onDidChange.fire();
+		}
+	});
+}
+
+export function lookupKrtPrResource(uri: URI): IKrtPrResource | undefined {
+	return registry.get(uri.toString());
+}
+
+export function findKrtPrResourcesByPrUrl(prUrl: string): ReadonlyArray<{ readonly uri: URI; readonly resource: IKrtPrResource }> {
+	const out: { uri: URI; resource: IKrtPrResource }[] = [];
+	for (const [key, resource] of registry) {
+		if (resource.pr.url === prUrl) {
+			out.push({ uri: URI.parse(key), resource });
+		}
+	}
+	return out;
+}
