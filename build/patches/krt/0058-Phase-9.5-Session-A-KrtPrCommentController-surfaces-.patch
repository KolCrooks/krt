diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
new file mode 100644
index 00000000000..a0f75c2aaab
--- /dev/null
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
@@ -0,0 +1,360 @@
+/*---------------------------------------------------------------------------------------------
