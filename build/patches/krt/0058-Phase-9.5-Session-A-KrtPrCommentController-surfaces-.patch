+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { CancellationToken } from '../../../../../base/common/cancellation.js';
+import { Disposable, toDisposable } from '../../../../../base/common/lifecycle.js';
+import { URI, UriComponents } from '../../../../../base/common/uri.js';
+import { IRange } from '../../../../../editor/common/core/range.js';
+import {
+	Comment as LanguageComment,
+	CommentReaction,
+	CommentThread,
+	CommentThreadCollapsibleState,
+} from '../../../../../editor/common/languages.js';
+import { createDecorator } from '../../../../../platform/instantiation/common/instantiation.js';
+import {
+	ICommentController,
+	ICommentInfo,
+	ICommentService,
+	INotebookCommentInfo,
+} from '../../../comments/browser/commentService.js';
+import { Comment as KrtComment } from '../../../../../platform/krt/common/krt.js';
+import {
+	findKrtPrResourcesByPrUrl,
+	IKrtPrResource,
+	lookupKrtPrResource,
+	onDidChangeKrtPrResources,
+} from './krtPrCommentRegistry.js';
+import { KrtPrCommentThread } from './krtPrCommentThread.js';
+
+export const KRT_PR_COMMENT_OWNER = 'krt-pr';
+
+/**
+ * Internal-to-KRT facet of the controller — the pane uses this to push
+ * GitHub review comments through after `loadReviewComments` resolves,
+ * keyed by PR url so the controller can fan out to whichever diff
+ * URIs are currently mounted for that PR.
+ *
+ * The `ICommentController` facet (consumed by the workbench's
+ * `ICommentService`) is implemented on the same singleton so that
+ * registration is automatic on workbench startup.
+ */
+export interface IKrtPrCommentController {
+	readonly _serviceBrand: undefined;
+	setCommentsForPr(prUrl: string, comments: readonly KrtComment[]): void;
+	clearCommentsForPr(prUrl: string): void;
+}
+
+export const IKrtPrCommentController = createDecorator<IKrtPrCommentController>('krtPrCommentController');
+
+export class KrtPrCommentController extends Disposable implements ICommentController, IKrtPrCommentController {
+
+	declare readonly _serviceBrand: undefined;
+
+	readonly id = KRT_PR_COMMENT_OWNER;
+	readonly label = 'KRT';
+	readonly owner = KRT_PR_COMMENT_OWNER;
+	readonly features = {};
+	activeComment: { thread: CommentThread; comment?: LanguageComment } | undefined;
+
+	/** uri.toString() → owned threads at that URI. */
+	private readonly threadsByUri = new Map<string, KrtPrCommentThread[]>();
+	/** PR URL → set of URIs currently owned (for fast clearCommentsForPr). */
+	private readonly urisByPr = new Map<string, Set<string>>();
+	/** Last-known KRT comments for a PR — replayed when a diff URI mounts late. */
+	private readonly cachedCommentsByPr = new Map<string, readonly KrtComment[]>();
+
+	private nextHandle = 1;
+
+	constructor(
+		@ICommentService private readonly commentService: ICommentService,
+	) {
+		super();
+		commentService.registerCommentController(KRT_PR_COMMENT_OWNER, this);
+		this._register(toDisposable(() => commentService.unregisterCommentController(KRT_PR_COMMENT_OWNER)));
+
+		// When a diff view mounts (registry adds a URI), replay any
+		// cached comments so the editor's freshly-attached
+		// CommentController contribution sees populated threads on its
+		// first `getDocumentComments` call. Without this, comments
+		// loaded before the diff was rendered would stay invisible
+		// until the next pane re-render.
+		this._register(onDidChangeKrtPrResources(() => this.replayCached()));
+	}
+
+	setCommentsForPr(prUrl: string, comments: readonly KrtComment[]): void {
+		this.cachedCommentsByPr.set(prUrl, comments);
+		this.applyForPr(prUrl);
+	}
+
+	clearCommentsForPr(prUrl: string): void {
+		this.cachedCommentsByPr.delete(prUrl);
+		const owned = this.urisByPr.get(prUrl);
+		if (!owned) {
+			return;
+		}
+		for (const key of owned) {
+			const previousThreads = this.threadsByUri.get(key);
+			if (previousThreads && previousThreads.length > 0) {
+				this.threadsByUri.delete(key);
+				this.commentService.updateComments(KRT_PR_COMMENT_OWNER, {
+					added: [],
+					removed: previousThreads,
+					changed: [],
+					pending: [],
+				});
+				this.commentService.setDocumentComments(URI.parse(key), this.commentInfosForUri(URI.parse(key)));
+				for (const t of previousThreads) {
+					t.dispose();
+				}
+			}
+		}
+		this.urisByPr.delete(prUrl);
+	}
+
+	async getDocumentComments(resource: URI, _token: CancellationToken): Promise<ICommentInfo<IRange>> {
+		const meta = lookupKrtPrResource(resource);
+		const threads = this.threadsByUri.get(resource.toString()) ?? [];
+		const ranges: IRange[] = [];
+		if (meta) {
+			for (let i = 0; i < meta.realLines.length; i++) {
+				if (meta.realLines[i] !== undefined) {
+					const ln = i + 1;
+					ranges.push({ startLineNumber: ln, startColumn: 1, endLineNumber: ln, endColumn: 1 });
+				}
+			}
+		}
+		return {
+			uniqueOwner: KRT_PR_COMMENT_OWNER,
+			label: this.label,
+			threads,
+			commentingRanges: { resource, ranges, fileComments: false },
+		};
+	}
+
+	async getNotebookComments(_resource: URI, _token: CancellationToken): Promise<INotebookCommentInfo> {
+		return { uniqueOwner: KRT_PR_COMMENT_OWNER, label: this.label, threads: [] };
+	}
+
+	// Session B will implement these. Until then they're no-ops so the
+	// `ICommentController` interface is satisfied without falsely
+	// claiming the user can post via the native `+`.
+	async createCommentThreadTemplate(_resource: UriComponents, _range: IRange | undefined, _editorId?: string): Promise<void> {
+		return;
+	}
+
+	async updateCommentThreadTemplate(_threadHandle: number, _range: IRange): Promise<void> {
+		return;
+	}
+
+	deleteCommentThreadMain(_commentThreadId: string): void {
+		return;
+	}
+
+	async toggleReaction(_uri: URI, _thread: CommentThread, _comment: LanguageComment, _reaction: CommentReaction, _token: CancellationToken): Promise<void> {
+		return;
+	}
+
+	async setActiveCommentAndThread(commentInfo: { thread: CommentThread; comment?: LanguageComment } | undefined): Promise<void> {
+		this.activeComment = commentInfo;
+	}
+
+	private replayCached(): void {
+		for (const prUrl of this.cachedCommentsByPr.keys()) {
+			this.applyForPr(prUrl);
+		}
+	}
+
+	private applyForPr(prUrl: string): void {
+		const comments = this.cachedCommentsByPr.get(prUrl) ?? [];
+		const resources = findKrtPrResourcesByPrUrl(prUrl);
+		const previouslyOwned = this.urisByPr.get(prUrl) ?? new Set<string>();
+		const nextOwned = new Set<string>();
+
+		// Group comments by (side, path) once — we look up per-URI by
+		// matching against `resource.side` and either `previousPath`
+		// (LEFT) or `path` (RIGHT). Skipping non-review (issue) comments.
+		type Bucket = { readonly comments: KrtComment[] };
+		const buckets = new Map<string, Bucket>();
+		for (const c of comments) {
+			if (c.location.kind !== 'review') {
+				continue;
+			}
+			const key = `${c.location.side}|${c.location.path}`;
+			const existing = buckets.get(key);
+			if (existing) {
+				existing.comments.push(c);
+			} else {
+				buckets.set(key, { comments: [c] });
+			}
+		}
+
+		for (const { uri, resource } of resources) {
+			const key = uri.toString();
+			const bucketKey = `${resource.side}|${resource.side === 'LEFT' ? resource.previousPath : resource.path}`;
+			const bucket = buckets.get(bucketKey);
+			const previousThreads = this.threadsByUri.get(key) ?? [];
+
+			if (!bucket || bucket.comments.length === 0) {
+				if (previousThreads.length > 0) {
+					this.threadsByUri.delete(key);
+					this.commentService.updateComments(KRT_PR_COMMENT_OWNER, {
+						added: [],
+						removed: previousThreads,
+						changed: [],
+						pending: [],
+					});
+					this.commentService.setDocumentComments(uri, this.commentInfosForUri(uri));
+					for (const t of previousThreads) {
+						t.dispose();
+					}
+				}
+				continue;
+			}
+
+			// One thread per real-file line. GitHub returns one comment
+			// per anchor row, but multiple comments can stack on the
+			// same line — we collapse them into a single thread.
+			const byLine = new Map<number, KrtComment[]>();
+			for (const c of bucket.comments) {
+				if (c.location.kind !== 'review') {
+					continue;
+				}
+				const arr = byLine.get(c.location.line);
+				if (arr) {
+					arr.push(c);
+				} else {
+					byLine.set(c.location.line, [c]);
+				}
+			}
+
+			const previousById = new Map(previousThreads.map(t => [t.threadId, t] as const));
+			const nextThreads: KrtPrCommentThread[] = [];
+			const added: KrtPrCommentThread[] = [];
+			const changed: KrtPrCommentThread[] = [];
+
+			for (const [realLine, lineComments] of byLine) {
+				const modelLine = realLineToModelLine(resource, realLine);
+				if (modelLine === undefined) {
+					continue;
+				}
+				const sorted = [...lineComments].sort(
+					(a, b) => a.createdAt < b.createdAt ? -1 : a.createdAt > b.createdAt ? 1 : 0,
+				);
+				const range: IRange = {
+					startLineNumber: modelLine,
+					startColumn: 1,
+					endLineNumber: modelLine,
+					endColumn: 1,
+				};
+				const threadId = `krt-pr|${prUrl}|${resource.side}|${resource.path}|${realLine}`;
+				const languageComments = sorted.map((c, i) => krtCommentToLanguageComment(c, i + 1));
+
+				const existing = previousById.get(threadId);
+				if (existing) {
+					existing.range = range;
+					existing.comments = languageComments;
+					changed.push(existing);
+					nextThreads.push(existing);
+					previousById.delete(threadId);
+				} else {
+					const fresh = new KrtPrCommentThread({
+						commentThreadHandle: this.nextHandle++,
+						controllerHandle: 0,
+						threadId,
+						resource: key,
+						range,
+						comments: languageComments,
+						canReply: false,
+						collapsibleState: CommentThreadCollapsibleState.Expanded,
+					});
+					nextThreads.push(fresh);
+					added.push(fresh);
+				}
+			}
+
+			const removed = [...previousById.values()];
+			this.threadsByUri.set(key, nextThreads);
+			nextOwned.add(key);
+
+			if (added.length > 0 || removed.length > 0 || changed.length > 0) {
+				this.commentService.updateComments(KRT_PR_COMMENT_OWNER, {
+					added,
+					removed,
+					changed,
+					pending: [],
+				});
+			}
+			// Always re-fire `setDocumentComments` so the editor's
+			// CommentController picks up our new state even on its very
+			// first attach (where `_commentInfos` doesn't yet contain
+			// anything for our owner, so the granular `updateComments`
+			// path would no-op).
+			this.commentService.setDocumentComments(uri, this.commentInfosForUri(uri));
+			for (const t of removed) {
+				t.dispose();
+			}
+		}
+
+		// URIs that were previously owned by this PR but no longer have
+		// any matching bucket → clear them.
+		for (const stale of previouslyOwned) {
+			if (nextOwned.has(stale)) {
+				continue;
+			}
+			const previousThreads = this.threadsByUri.get(stale);
+			if (previousThreads && previousThreads.length > 0) {
+				this.threadsByUri.delete(stale);
+				this.commentService.updateComments(KRT_PR_COMMENT_OWNER, {
+					added: [],
+					removed: previousThreads,
+					changed: [],
+					pending: [],
+				});
+				this.commentService.setDocumentComments(URI.parse(stale), this.commentInfosForUri(URI.parse(stale)));
+				for (const t of previousThreads) {
+					t.dispose();
+				}
+			}
+		}
+
+		this.urisByPr.set(prUrl, nextOwned);
+	}
+
+	private commentInfosForUri(uri: URI): ICommentInfo[] {
+		const meta = lookupKrtPrResource(uri);
+		const threads = this.threadsByUri.get(uri.toString()) ?? [];
+		const ranges: IRange[] = [];
+		if (meta) {
+			for (let i = 0; i < meta.realLines.length; i++) {
+				if (meta.realLines[i] !== undefined) {
+					const ln = i + 1;
+					ranges.push({ startLineNumber: ln, startColumn: 1, endLineNumber: ln, endColumn: 1 });
+				}
+			}
+		}
+		return [{
+			uniqueOwner: KRT_PR_COMMENT_OWNER,
+			label: this.label,
+			threads,
+			commentingRanges: { resource: uri, ranges, fileComments: false },
+		}];
+	}
+}
+
+function realLineToModelLine(resource: IKrtPrResource, realLine: number): number | undefined {
+	const idx = resource.realLines.indexOf(realLine);
+	return idx === -1 ? undefined : idx + 1;
+}
+
+function krtCommentToLanguageComment(c: KrtComment, uniqueIdInThread: number): LanguageComment {
+	return {
+		uniqueIdInThread,
+		body: c.body,
+		userName: c.author.login,
+		userIconPath: c.author.avatarUrl ? URI.parse(c.author.avatarUrl) : undefined,
+		timestamp: c.createdAt,
+	};
+}
