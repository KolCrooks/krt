From ce79ec6bded3d9a81c508fc459ed20c33792b090 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 10:17:23 -0400
Subject: [PATCH] Phase 9.5 Session A: log updateComments fires + model
 resource count

Logs every time we push added/removed/changed threads through
updateComments, including how many resources the global
commentsModel has after the call. Lets us tell whether the empty
Comments panel is because (a) updateComments isn't firing with
threads, (b) it fires but the model doesn't accept them, or (c) the
panel just isn't picking up model changes.
---
 .../workbench/contrib/krt/browser/pr/krtPrCommentController.ts   | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
index 38002b849f8..75d58072a29 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrCommentController.ts
@@ -306,6 +306,7 @@ export class KrtPrCommentController extends Disposable implements ICommentContro
 			nextOwned.add(key);
 
 			if (added.length > 0 || removed.length > 0 || changed.length > 0) {
+				this.logService.info(`[krt] updateComments ${resource.side} ${resource.path}: added=${added.length} removed=${removed.length} changed=${changed.length} (model now has ${this.commentService.commentsModel.resourceCommentThreads.length} resources)`);
 				this.commentService.updateComments(KRT_PR_COMMENT_OWNER, {
 					added,
 					removed,
