+/* ---------- Loading spinner (Tour + Storyboard) ---------- */
+
+.krt-pr-tour-loading {
+	display: flex;
+	align-items: center;
+	gap: 12px;
+	padding: 16px 20px;
+	color: var(--vscode-descriptionForeground);
+	font-size: 13px;
+}
+
+.krt-pr-tour-loading-text {
+	color: var(--vscode-foreground);
+}
+
+.krt-pr-spinner {
+	flex-shrink: 0;
+	display: inline-block;
+}
+
+.krt-pr-spinner-track {
+	fill: none;
+	stroke: var(--vscode-widget-border, rgba(127, 127, 127, 0.25));
+	stroke-width: 2.5;
+}
+
+.krt-pr-spinner-arc {
+	fill: none;
+	stroke: var(--krt-accent, var(--vscode-focusBorder, #007acc));
+	stroke-width: 2.5;
+	stroke-linecap: round;
+	stroke-dasharray: 14 60;
+	transform-origin: 12px 12px;
+	animation: krt-pr-spinner-rotate 0.9s linear infinite;
+}
+
+@keyframes krt-pr-spinner-rotate {
+	from { transform: rotate(0deg); }
+	to   { transform: rotate(360deg); }
+}
