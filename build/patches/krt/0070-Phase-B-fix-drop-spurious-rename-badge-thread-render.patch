From 2422c170e2b5beb08b22b401f1751058c6eb1aee Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 14:28:46 -0400
Subject: [PATCH] Phase B fix: drop spurious rename badge + thread render-mode
 toggle

Two reports against the new MultiDiffEditor stack:

1. Every modified file showed an "R" rename badge.
   Cause: `MultiDiffEditorItemTemplate` flags an item as renamed iff
   `original.path !== modified.path`. With the previous encoding,
   `originalUri.path` was the repo-relative path (`/src/main.rs`)
   while `modifiedUri.path` was the workspace-absolute path
   (`/Users/kol/myrepo/src/main.rs`), so every file looked renamed.
   Fix: encode the krt-git URI's path as the absolute fs path
   (matching modified), and stash the repo-relative path inside
   the URI's query alongside `(folderUri, ref)`. Real renames
   (`file.previousPath !== file.path`) still differentiate the two
   sides via `previousPath`, so the rename badge keeps firing for
   the cases that actually are renames.

2. Side-by-side / inline toggle didn't work.
   Cause: `KrtPrMultiDiff.setPullRequest` hardcoded
   `renderSideBySide: true` per `IDocumentDiffItem`. The toggle's
   click handler re-rendered the pane (`renderLoaded`) but the
   newly mounted widget kept the same hardcoded option.
   Fix: thread `this.diffRenderMode` through as an explicit
   `{ renderSideBySide }` parameter on `setPullRequest`. The pane
   reads it from storage, the toggle writes back + re-renders.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 .../contrib/krt/browser/pr/krtPrMultiDiff.ts  |  6 +--
 .../browser/pr/krtPullRequestEditorPane.ts    | 12 +++--
 .../workspace/krtGitContentProvider.ts        | 44 ++++++++++++-------
 3 files changed, 39 insertions(+), 23 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
index 889f259b776..728bbbf5567 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
@@ -75,7 +75,7 @@ export class KrtPrMultiDiff extends Disposable {
 	 * remaining files still render. A more nuanced "couldn't load
 	 * this file's base" UI can land in a polish pass.
 	 */
-	async setPullRequest(pr: PullRequest, files: readonly PullRequestFile[], workspace: KrtWorkspace): Promise<void> {
+	async setPullRequest(pr: PullRequest, files: readonly PullRequestFile[], workspace: KrtWorkspace, opts: { renderSideBySide: boolean }): Promise<void> {
 		const previous = this.currentModel;
 
 		const items: RefCounted<IDocumentDiffItem>[] = [];
@@ -83,7 +83,7 @@ export class KrtPrMultiDiff extends Disposable {
 			const itemStore = new DisposableStore();
 			const previousPath = file.previousPath ?? file.path;
 			const originalUri = file.status !== 'added'
-				? encodeKrtGit(workspace.folderUri, pr.base.sha, previousPath)
+				? encodeKrtGit(workspace.folderUri, workspace.folderPath, pr.base.sha, previousPath)
 				: undefined;
 			const modifiedUri = file.status !== 'removed'
 				? URI.joinPath(URI.file(workspace.folderPath), file.path)
@@ -120,7 +120,7 @@ export class KrtPrMultiDiff extends Disposable {
 				options: {
 					readOnly: true,
 					originalEditable: false,
-					renderSideBySide: true,
+					renderSideBySide: opts.renderSideBySide,
 					hideUnchangedRegions: { enabled: true, contextLineCount: 3, minimumLineCount: 4 },
 				},
 			};
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
index 94223909d5f..4fa85a7ca47 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPullRequestEditorPane.ts
@@ -1102,10 +1102,16 @@ export class KrtPullRequestEditorPane extends EditorPane {
 		this.renderDiffTree(tree, this.diffFiles, this.diffTreeRowsByPath);
 
 		// Mount the multi-diff widget in the host. The widget owns its
-		// own virtualised stack + internal scroll.
+		// own virtualised stack + internal scroll. The render mode
+		// flows through as a per-file `IDocumentDiffItem.options`
+		// override; flipping the toggle re-runs `renderLoaded` (see
+		// the click handlers in `renderDiffTopBar`) which rebuilds the
+		// pane and remounts a fresh widget with the new option.
 		const multiDiff = this.instantiationService.createInstance(KrtPrMultiDiff, host);
 		this.bodyDisposables.add(multiDiff);
-		void multiDiff.setPullRequest(pr, this.diffFiles, workspace);
+		void multiDiff.setPullRequest(pr, this.diffFiles, workspace, {
+			renderSideBySide: this.diffRenderMode === 'side-by-side',
+		});
 
 		// Tree clicks → reveal the file inside the widget. The URIs
 		// here mirror what `KrtPrMultiDiff` builds internally.
@@ -1119,7 +1125,7 @@ export class KrtPullRequestEditorPane extends EditorPane {
 				? URI.joinPath(URI.file(workspace.folderPath), file.path)
 				: undefined;
 			const originalUri = file.status !== 'added'
-				? encodeKrtGit(workspace.folderUri, pr.base.sha, previousPath)
+				? encodeKrtGit(workspace.folderUri, workspace.folderPath, pr.base.sha, previousPath)
 				: undefined;
 			this.bodyDisposables.add(DOM.addDisposableListener(row, 'click', () => {
 				multiDiff.revealFile(modifiedUri, originalUri);
diff --git a/src/vs/workbench/contrib/krt/browser/workspace/krtGitContentProvider.ts b/src/vs/workbench/contrib/krt/browser/workspace/krtGitContentProvider.ts
index 65456f62085..49ecd2db96d 100644
--- a/src/vs/workbench/contrib/krt/browser/workspace/krtGitContentProvider.ts
+++ b/src/vs/workbench/contrib/krt/browser/workspace/krtGitContentProvider.ts
@@ -77,25 +77,39 @@ class KrtGitContentProvider implements ITextModelContentProvider {
 
 /**
  * Encodes a workspace + ref + path tuple into a stable `krt-git://`
- * URI. Both the workspace identity (`folderUri`) and the ref live in
- * the URI's **query** as JSON because VS Code's `URI.from` lowercases
- * the authority component — encoding the folder URI there strips the
- * case from `/Users/...` paths and the registry lookup misses on
- * case-sensitive comparison. Query and path are case-preserved. The
- * file `path` lives in the URI's path component so language detection
- * (which keys off the basename + extension) works without parsing the
- * query.
+ * URI.
+ *
+ * The URI's **path** component matches the corresponding `file://`
+ * URI's path (i.e. the file's absolute fs path inside the workspace).
+ * `MultiDiffEditorItemTemplate` flags a file as renamed when
+ * `original.path !== modified.path`; if we just put the repo-relative
+ * path in the URI here, every modified file would render with a
+ * spurious "R" badge.
+ *
+ * The workspace identity, ref, and the repo-relative path used by
+ * `git show` all live in the URI's **query** as JSON. Both query and
+ * path are case-preserved (unlike the authority, which `URI.from`
+ * lowercases — that broke the registry lookup on `/Users/...` paths).
  */
 interface KrtGitFields {
 	readonly folderUri: string;
 	readonly ref: string;
+	/**
+	 * Repo-relative path passed to `git show ref:path`. Stored here
+	 * rather than derived from `URI.path` because the URI's path is
+	 * the absolute fs path (see comment above) and reverse-deriving
+	 * the relative form would require knowing the workspace's
+	 * `folderPath`, which the decoder doesn't have at parse time.
+	 */
+	readonly path: string;
 }
 
-export function encodeKrtGit(folderUri: string, ref: string, path: string): URI {
-	const fields: KrtGitFields = { folderUri, ref };
+export function encodeKrtGit(folderUri: string, folderPath: string, ref: string, repoRelativePath: string): URI {
+	const fields: KrtGitFields = { folderUri, ref, path: repoRelativePath };
+	const absolute = URI.joinPath(URI.file(folderPath), repoRelativePath);
 	return URI.from({
 		scheme: KRT_GIT_SCHEME,
-		path: `/${path}`,
+		path: absolute.path,
 		query: JSON.stringify(fields),
 	});
 }
@@ -110,17 +124,13 @@ function decodeKrtGit(resource: URI): { folderUri: string; ref: string; path: st
 	} catch {
 		return undefined;
 	}
-	if (typeof fields?.folderUri !== 'string' || typeof fields?.ref !== 'string') {
-		return undefined;
-	}
-	const path = resource.path.replace(/^\//, '');
-	if (!path) {
+	if (typeof fields?.folderUri !== 'string' || typeof fields?.ref !== 'string' || typeof fields?.path !== 'string') {
 		return undefined;
 	}
 	return {
 		folderUri: fields.folderUri,
 		ref: fields.ref,
-		path,
+		path: fields.path,
 	};
 }
 
