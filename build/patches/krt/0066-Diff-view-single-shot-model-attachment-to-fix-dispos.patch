+	/**
+	 * Single-shot model resolution + attach. Picks workspace-backed
+	 * URIs (file:// + krt-git://) when the working tree is on the PR
+	 * head and both sides resolve cleanly, otherwise falls back to the
+	 * patch-reconstructed virtual URIs. Calls `setDiffModel` exactly
+	 * once — the previous "synchronous virtual then async upgrade"
+	 * pattern triggered Monaco's `onWillDispose`-on-old-model error
+	 * path on subsequent interactions.
+	 */
+	private async attachModels(reconstructed: Reconstructed): Promise<void> {
+		const upgrade = this.opts.workspace
+			? await this.tryWorkspaceModels(this.opts.workspace)
+			: undefined;
+		if (this._store.isDisposed) {
+			return;
