+		let head: ITextModel;
+		let identity: boolean;
+		if (upgrade) {
+			base = upgrade.base;
+			head = upgrade.head;
+			this.baseRealLines = identityArray(base.getLineCount());
+			this.headRealLines = identityArray(head.getLineCount());
+			identity = true;
+		} else {
+			const virtual = this.buildVirtualModels(reconstructed);
+			base = virtual.base;
+			head = virtual.head;
+			this.baseRealLines = reconstructed.base.realLines;
+			this.headRealLines = reconstructed.head.realLines;
+			identity = false;
+		}
+
+		this.applyDiffModel(base, head);
+		this.applyLineNumbers(identity);
+		this.registerCommentResources(base.uri, head.uri);
