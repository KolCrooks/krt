From 0375c8ccc43a1e1c84239118b3b99f62947eca75 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 13:37:08 -0400
Subject: [PATCH] Monaco diff: drop height cap, settle via per-frame
 getContentHeight poll
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The 720px cap was a workaround for the unreliable event-driven refit
during the construction → diff-compute → hideUnchangedRegions pipeline.
Removing it.

Switched to a self-bounded settling poll: every animation frame, read
`widget.getContentHeight()`. If it changed, refit the container. Stop
after 5 consecutive identical reads (size has stabilized) or 200
frames (~3s @ 60fps, pathological-input fuse). `getContentHeight()`
is the source of truth — it's `viewModel.viewLayout.getContentHeight()`
which respects `setHiddenAreas` — so we don't depend on whichever
Monaco event fires (or fails to fire) at which reactive tick.

`onDidContentSizeChange` still drives post-settle refits (user
expanding a hidden region, comment thread markdown finishing render
and growing its view zone).

No upper cap. A 10000-line diff renders as a 190000px-tall card and
the user scrolls the outer PR pane to walk through it.
---
 .../contrib/krt/browser/pr/krtMonacoDiff.ts   | 86 +++++++++++++------
 1 file changed, 59 insertions(+), 27 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
index 6a966422624..3d845fc45fb 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
@@ -45,11 +45,13 @@ interface ILineZoneOptions {
 	readonly domNode: HTMLElement;
 }
 
-// Card sizing: hug content up to `MAX_CARD_HEIGHT_PX`, then internal
-// scroll. `INITIAL_CARD_HEIGHT_PX` gives the editors something non-zero
-// to lay out into on first paint before the real size is known.
+// Card sizing: hug content with no upper cap. The user scrolls the
+// outer PR pane; cards stack vertically at their natural heights.
+//
+// `INITIAL_CARD_HEIGHT_PX` gives the inner editors a non-zero
+// container to lay out into on first paint — Monaco won't compute a
+// content height until it has rendered at least once.
 const INITIAL_CARD_HEIGHT_PX = 240;
-const MAX_CARD_HEIGHT_PX = 720;
 const MIN_CARD_HEIGHT_PX = 80;
 const CARD_CHROME_PX = 8;
 
@@ -209,33 +211,26 @@ export class KrtMonacoDiffView extends Disposable {
 		// share a URI per (owner, repo, sha, path) so memory stays bounded.
 
 		this.widget.layout();
-		// `onDidContentSizeChange` fires whenever the modified editor's
-		// content height changes — including when `hideUnchangedRegions`
-		// applies its hidden areas in a later autorun tick. That covers
-		// most of the lifecycle.
+		// `onDidContentSizeChange` covers post-settle changes — the user
+		// expanding a "Show N unchanged lines" region, a comment thread's
+		// markdown finishing render and growing its view zone, etc.
 		this._register(this.widget.onDidContentSizeChange(() => this.layoutToContent()));
-		// Belt-and-braces: also re-fit a couple of frames after the diff
-		// settles. Two `requestAnimationFrame`s give the
-		// `hideUnchangedRegions` autorun a tick to fire even if its size
-		// change doesn't bubble through `onDidContentSizeChange` cleanly.
-		const win = DOM.getWindow(this.container);
-		const rafIds: number[] = [];
-		this._register(toDisposable(() => {
-			for (const id of rafIds) {
-				win.cancelAnimationFrame(id);
-			}
-		}));
-		void this.widget.waitForDiff().then(() => {
-			rafIds.push(win.requestAnimationFrame(() => {
-				rafIds.push(win.requestAnimationFrame(() => this.layoutToContent()));
-			}));
-		});
+		// During the construction → diff-compute → hideUnchangedRegions-
+		// applies pipeline, Monaco's events are spread across multiple
+		// reactive ticks and one of them frequently doesn't bubble
+		// through `onDidContentSizeChange` cleanly. Rather than guess
+		// which tick to listen on, poll `getContentHeight()` per frame
+		// until it stabilizes — that's the source of truth and it's
+		// immune to event-order quirks. Bounded by a stability window
+		// (5 consecutive identical reads → done) and a 200-frame fuse
+		// (~3s @ 60fps) so a pathological input can't poll forever.
+		this.startSettlingPoll();
 	}
 
 	private layoutToContent(): void {
-		const target = Math.min(
-			Math.max(this.widget.getContentHeight() + CARD_CHROME_PX, MIN_CARD_HEIGHT_PX),
-			MAX_CARD_HEIGHT_PX,
+		const target = Math.max(
+			this.widget.getContentHeight() + CARD_CHROME_PX,
+			MIN_CARD_HEIGHT_PX,
 		);
 		if (this.container.clientHeight !== target) {
 			this.container.style.height = `${target}px`;
@@ -243,6 +238,43 @@ export class KrtMonacoDiffView extends Disposable {
 		}
 	}
 
+	private startSettlingPoll(): void {
+		const win = DOM.getWindow(this.container);
+		let lastHeight = -1;
+		let stableFrames = 0;
+		let framesRemaining = 200;
+		let rafId = 0;
+		let cancelled = false;
+
+		const tick = () => {
+			if (cancelled) {
+				return;
+			}
+			framesRemaining--;
+			const h = this.widget.getContentHeight();
+			if (h !== lastHeight) {
+				lastHeight = h;
+				stableFrames = 0;
+				this.layoutToContent();
+			} else {
+				stableFrames++;
+			}
+			if (stableFrames >= 5 || framesRemaining <= 0) {
+				rafId = 0;
+				return;
+			}
+			rafId = win.requestAnimationFrame(tick);
+		};
+
+		rafId = win.requestAnimationFrame(tick);
+		this._register(toDisposable(() => {
+			cancelled = true;
+			if (rafId) {
+				win.cancelAnimationFrame(rafId);
+			}
+		}));
+	}
+
 	/**
 	 * Attach a DOM node as a Monaco view zone after the given line on the
 	 * specified side. Returns a disposable that removes the zone.
-- 
2.52.0

