From cd8178bc1bbe8ad3b3c2e288c103a9d15f910494 Mon Sep 17 00:00:00 2001
From: julietmoss <juliet.moss@datadoghq.com>
Date: Tue, 12 May 2026 14:36:19 -0400
Subject: [PATCH 1/4] PR browse: scoped empty states

---
 .../pullRequestProviderMainService.ts           |  3 +++
 .../krt/browser/search/krtSearchOverlay.ts      | 17 +++++++++++++----
 2 files changed, 16 insertions(+), 4 deletions(-)

diff --git a/src/vs/platform/krt/electron-main/pullRequestProviderMainService.ts b/src/vs/platform/krt/electron-main/pullRequestProviderMainService.ts
index c1a9421b6d1..a37ec4181e2 100644
--- a/src/vs/platform/krt/electron-main/pullRequestProviderMainService.ts
+++ b/src/vs/platform/krt/electron-main/pullRequestProviderMainService.ts
@@ -321,6 +321,9 @@ function buildSearchQuery(query: string, scope: SearchScope, repos?: readonly {
 	switch (scope) {
 		case 'all-open':
 			qualifiers.push('is:open');
+			if (!trimmed) {
+				qualifiers.push('author:@me');
+			}
 			break;
 		case 'reviewed':
 			qualifiers.push('reviewed-by:@me');
diff --git a/src/vs/workbench/contrib/krt/browser/search/krtSearchOverlay.ts b/src/vs/workbench/contrib/krt/browser/search/krtSearchOverlay.ts
index f11b9a262df..41c305f1336 100644
--- a/src/vs/workbench/contrib/krt/browser/search/krtSearchOverlay.ts
+++ b/src/vs/workbench/contrib/krt/browser/search/krtSearchOverlay.ts
@@ -191,6 +191,7 @@ class KrtSearchOverlay extends Disposable {
 	private attachEventListeners(): void {
 		this.listeners.add(DOM.addDisposableListener(this.inputElement, 'input', () => {
 			this.query = this.inputElement.value;
+			this.refreshRecents();
 			this.scheduleSearch();
 		}));
 		this.listeners.add(DOM.addDisposableListener(this.inputElement, 'keydown', (raw) => {
@@ -341,9 +342,17 @@ class KrtSearchOverlay extends Disposable {
 				return;
 			}
 			const el = DOM.append(this.resultsElement, DOM.$('.krt-search-empty'));
-			el.textContent = this.query
-				? localize('krt.search.noMatches', "No PRs match.")
-				: localize('krt.search.startTyping', "Type to search PRs in your registered workspaces.");
+			if (this.query) {
+				el.textContent = localize('krt.search.noMatches', "No PRs match.");
+			} else {
+				if (this.scope === 'all-open') {
+					el.textContent = localize('krt.search.emptyAllOpen', "You have no open PRs. Type to search across GitHub.");
+				} else if (this.scope === 'reviewed') {
+					el.textContent = localize('krt.search.emptyReviewed', "You haven't reviewed any PRs. Type to search across GitHub.");
+				} else if (this.scope === 'awaiting-review') {
+					el.textContent = localize('krt.search.emptyAwaiting', "No PRs are awaiting your review. Type to search across GitHub.");
+				}
+			}
 			return;
 		}
 		this.resultRowElements = [];
@@ -409,7 +418,7 @@ class KrtSearchOverlay extends Disposable {
 	private refreshRecents(): void {
 		DOM.clearNode(this.recentsGrid);
 		const recents = readRecentPullRequests(this.storageService).slice(0, RECENTS_GRID_LIMIT);
-		if (recents.length === 0) {
+		if (recents.length === 0 || this.query.trim().length > 0) {
 			this.recentsContainer.hidden = true;
 			return;
 		}
-- 
