From 9815697c5f8a6ce11dcf0049e6a30b1d7c4cfde9 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Thu, 7 May 2026 14:48:26 -0400
Subject: [PATCH] Phase B fix: diff against merge-base, not pr.base.sha
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Reported: modified files showed huge phantom changes — every line
flagged different even when the PR only touched a handful. Cause:
the original side was being resolved against `pr.base.sha`, which is
the *current* tip of the target branch. GitHub's PR view diffs
against the merge base of the PR's two refs (the common ancestor),
not the target's current tip. When the target branch has moved
forward since the PR was opened, the two SHAs diverge and `git diff
target-tip pr-head` includes every commit that landed on target as
a "reverted" change in the PR — which is what showed up as huge
phantom diffs.

- `IKrtGitService.getMergeBase(folderPath, a, b)`: thin wrapper
  around `git merge-base a b`.
- `KrtPrMultiDiff.setPullRequest`: compute the merge base once at
  the top, use it as the base SHA for all original-side URIs (per
  file). On `git merge-base` failure (e.g. one of the SHAs isn't
  fetched locally), fall back to `pr.base.sha` and let the
  per-side resolver's warning logs surface the issue.

The earlier "exists on disk, but not in baseSha" warnings the user
also saw were caused by the same root issue: GitHub's API reported
files added between the original merge base and `pr.base.sha`'s
current target-tip, so `git show pr.base.sha:path` couldn't find
them. Diffing against the merge base resolves both symptoms.

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>
---
 src/vs/platform/krt/common/krtGit.ts          | 11 ++++++++
 .../krt/electron-main/krtGitMainService.ts    |  9 +++++++
 .../contrib/krt/browser/pr/krtPrMultiDiff.ts  | 26 ++++++++++++++++++-
 3 files changed, 45 insertions(+), 1 deletion(-)

diff --git a/src/vs/platform/krt/common/krtGit.ts b/src/vs/platform/krt/common/krtGit.ts
index 63d7be8487a..e617a6821cd 100644
--- a/src/vs/platform/krt/common/krtGit.ts
+++ b/src/vs/platform/krt/common/krtGit.ts
@@ -40,6 +40,17 @@ export interface IKrtGitService {
 	detectVcs(folderPath: string): Promise<KrtVcs | null>;
 	getRemoteUrl(folderPath: string, remoteName?: string): Promise<string>;
 	getHeadSha(folderPath: string): Promise<string>;
+	/**
+	 * `git merge-base <a> <b>` — the common ancestor of two SHAs.
+	 * Phase 10/B uses this to find the SHA GitHub shows the PR's diff
+	 * *against*, which is the merge base of `pr.head.sha` and
+	 * `pr.base.sha` rather than `pr.base.sha` directly. When the PR's
+	 * target branch has moved forward since the PR was opened,
+	 * `pr.base.sha` is the *current* target-branch tip (far past the
+	 * merge base) and diffing against it shows every commit that
+	 * landed on the target branch as a "reverted" change in the PR.
+	 */
+	getMergeBase(folderPath: string, a: string, b: string): Promise<string>;
 	showFile(folderPath: string, ref: string, path: string): Promise<string>;
 
 	// --- Phase 8.7: status -----------------------------------------------
diff --git a/src/vs/platform/krt/electron-main/krtGitMainService.ts b/src/vs/platform/krt/electron-main/krtGitMainService.ts
index 0142fc038ed..4e7983b9307 100644
--- a/src/vs/platform/krt/electron-main/krtGitMainService.ts
+++ b/src/vs/platform/krt/electron-main/krtGitMainService.ts
@@ -82,6 +82,15 @@ export class KrtGitMainService implements IKrtGitService {
 		throw gitInvocation(result.stderr || result.stdout);
 	}
 
+	async getMergeBase(folderPath: string, a: string, b: string): Promise<string> {
+		await this.detect();
+		const result = await this.spawnGit(folderPath, ['merge-base', a, b]);
+		if (result.code === 0) {
+			return result.stdout.trim();
+		}
+		throw gitInvocation(result.stderr || result.stdout);
+	}
+
 	async showFile(folderPath: string, ref: string, path: string): Promise<string> {
 		await this.detect();
 		const result = await this.spawnGit(folderPath, ['show', `${ref}:${path}`]);
diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
index 4b99ecc970d..8d96c917cd1 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtPrMultiDiff.ts
@@ -12,6 +12,7 @@ import { IResourceLabel, IWorkbenchUIElementFactory } from '../../../../../edito
 import { RefCounted } from '../../../../../editor/browser/widget/diffEditor/utils.js';
 import { IResolvedTextEditorModel, ITextModelService } from '../../../../../editor/common/services/resolverService.js';
 import { IInstantiationService } from '../../../../../platform/instantiation/common/instantiation.js';
+import { IKrtGitService } from '../../../../../platform/krt/common/krtGit.js';
 import { ILogService } from '../../../../../platform/log/common/log.js';
 import { PullRequest, PullRequestFile } from '../../../../../platform/krt/common/krt.js';
 import { ResourceLabel } from '../../../../browser/labels.js';
@@ -56,6 +57,7 @@ export class KrtPrMultiDiff extends Disposable {
 		@ITextModelService private readonly textModelService: ITextModelService,
 		@ILogService private readonly logService: ILogService,
 		@IKrtPrCommentController private readonly commentController: IKrtPrCommentController,
+		@IKrtGitService private readonly gitService: IKrtGitService,
 	) {
 		super();
 		const factory = this.instantiationService.createInstance(KrtMultiDiffUIElementFactory);
@@ -85,12 +87,34 @@ export class KrtPrMultiDiff extends Disposable {
 		const previous = this.currentModel;
 		this.uriRegistrations.clear();
 
+		// Compute the merge base of the PR's two refs. GitHub diffs the
+		// PR against the merge base, NOT `pr.base.sha` directly:
+		// `pr.base.sha` is the *current* tip of the target branch, so
+		// when the target has moved forward since the PR was opened,
+		// diffing against it shows every commit that landed on target
+		// as a "reverted" change in the PR. Merge base = common
+		// ancestor = the SHA the PR's diff should anchor on.
+		// Fall back to `pr.base.sha` if `git merge-base` fails (the
+		// per-side resolver will warn on each file in that case).
+		let baseSha = pr.base.sha;
+		try {
+			baseSha = await this.gitService.getMergeBase(workspace.folderPath, pr.base.sha, pr.head.sha);
+		} catch (err) {
+			this.logService.warn(
+				`[krt] multi-diff: git merge-base ${pr.base.sha.slice(0, 7)} ${pr.head.sha.slice(0, 7)} failed in ${workspace.folderPath} — falling back to pr.base.sha`,
+				err,
+			);
+		}
+		if (this._store.isDisposed) {
+			return;
+		}
+
 		const items: RefCounted<IDocumentDiffItem>[] = [];
 		for (const file of files) {
 			const itemStore = new DisposableStore();
 			const previousPath = file.previousPath ?? file.path;
 			const originalUri = file.status !== 'added'
-				? encodeKrtGit(workspace.folderUri, workspace.folderPath, pr.base.sha, previousPath)
+				? encodeKrtGit(workspace.folderUri, workspace.folderPath, baseSha, previousPath)
 				: undefined;
 			const modifiedUri = file.status !== 'removed'
 				? URI.joinPath(URI.file(workspace.folderPath), file.path)
