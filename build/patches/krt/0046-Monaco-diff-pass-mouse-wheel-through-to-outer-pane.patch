From 5034739480fbc2618842d0257c1b0128c5a9f330 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Wed, 6 May 2026 14:02:50 -0400
Subject: [PATCH] Monaco diff: pass mouse-wheel through to outer pane
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Each card now sizes to its full content (no internal scroll), so any
wheel event landing inside the card should bubble out to the outer
PR pane. Set both `handleMouseWheel: false` (Monaco ignores the
event entirely) and `alwaysConsumeMouseWheel: false` (defensive —
covers any path where Monaco might otherwise stopPropagation).
---
 src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
index 045f6fc68ef..fe780ddf76e 100644
--- a/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
+++ b/src/vs/workbench/contrib/krt/browser/pr/krtMonacoDiff.ts
@@ -147,6 +147,13 @@ export class KrtMonacoDiffView extends Disposable {
 				automaticLayout: true,
 				scrollBeyondLastLine: false,
 				minimap: { enabled: false },
+				// The card hugs its content (no internal scroll), so
+				// any wheel event hitting it should pass straight through
+				// to the outer PR pane for whole-page scroll.
+				scrollbar: {
+					handleMouseWheel: false,
+					alwaysConsumeMouseWheel: false,
+				},
 				lineNumbersMinChars: 4,
 			},
 			{
-- 
