From 042bfe6d5e2cef06a488bc170ef57725a7b20d54 Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Tue, 5 May 2026 11:13:08 -0400
Subject: [PATCH] Phase 8: widen port-y spread to 70% of card height

Three or more edges leaving the same node were crowding into
a 60px central band (the 30%-70% port-y range). Widen to
15%-85% so consecutive ports are clearly separated, and switch
adjacent-edge channel sort key from blended source/target-y to
plain source-y so the source side stays cleanly ordered.
---
 .../krt/browser/ai/krtStoryboardLayout.ts     | 22 +++++++++++--------
 1 file changed, 13 insertions(+), 9 deletions(-)

diff --git a/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts b/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
index 751808eb2e7..ede82934e36 100644
--- a/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
+++ b/src/vs/workbench/contrib/krt/browser/ai/krtStoryboardLayout.ts
@@ -258,12 +258,15 @@ function routeEdges(
 	}
 
 	const portY = (count: number, index: number, top: number, height: number): number => {
-		// Distribute `count` ports evenly along the node's vertical
-		// edge across the central 40% so corners don't crowd.
+		// Distribute `count` ports along the node's vertical edge
+		// using as much of the height as the corner radius allows.
+		// Wide spread (15%-85%) so multiple edges leaving the same
+		// node fan out clearly instead of crowding a thin central
+		// band.
 		if (count <= 1) {
 			return top + height / 2;
 		}
-		return top + height * (0.3 + (index / Math.max(1, count - 1)) * 0.4);
+		return top + height * (0.15 + (index / Math.max(1, count - 1)) * 0.7);
 	};
 
 	// Pass 1 — collect every edge with its source/target ports.
@@ -307,15 +310,16 @@ function routeEdges(
 		const span = e.targetTier - e.sourceTier;
 		if (span >= 2) {
 			// Multi-tier edges use both the channel right after the
-			// source tier (entry) and the channel right before the
-			// target tier (exit).
+			// source tier (entry, sorted by source-y) and the channel
+			// right before the target tier (exit, sorted by target-y).
 			push(channelBuckets, e.sourceTier, { edgeIdx: i, sortKey: e.sy });
 			push(channelBuckets, e.targetTier - 1, { edgeIdx: i, sortKey: e.ty });
 		} else if (span === 1) {
-			// Adjacent-tier edges use the single gap they cross.
-			// Sort key blends source-y and target-y so siblings
-			// converging on the same target stay nicely ordered.
-			push(channelBuckets, e.sourceTier, { edgeIdx: i, sortKey: (e.sy + e.ty) / 2 });
+			// Adjacent-tier edges use the single gap they cross. Sort
+			// by source-y so the channel reflects the order edges
+			// leave the source — the source side is what the user
+			// looks at first when many edges fan out.
+			push(channelBuckets, e.sourceTier, { edgeIdx: i, sortKey: e.sy });
 		}
 	}
 
