 import { IStorageService, StorageScope, StorageTarget } from '../../../../../platform/storage/common/storage.js';
 
 /**
- * BYOK Anthropic settings persisted across runs. The API key is
- * encrypted via `IEncryptionService` (safeStorage; macOS Keychain
- * on Mac, DPAPI on Windows, libsecret/kwallet on Linux) before
- * landing in `IStorageService`. Model + prompt-caching toggle are
- * plain — they don't carry a secret.
+ * BYOK Anthropic settings persisted across runs. The API key is stored via
+ * ISecretStorageService, which uses the OS keychain when available and falls
+ * back to in-memory storage otherwise. Model + prompt-caching toggle are plain
+ * — they don't carry a secret.
  *
- * APPLICATION/MACHINE scope to match the recent-PRs and reviewed
- * stores: KRT is single-window/single-user, profiles aren't a
- * meaningful axis here.
+ * APPLICATION/MACHINE scope to match the recent-PRs and reviewed stores: KRT
+ * is single-window/single-user, profiles aren't a meaningful axis here.
  */
 export const ANTHROPIC_KEY_STORAGE = 'krt.ai.anthropicKey';
 export const ANTHROPIC_MODEL_STORAGE = 'krt.ai.model';
@@ -31,38 +29,21 @@ export const SUPPORTED_MODELS: readonly { id: string; label: string; description
 	{ id: 'claude-haiku-4-5-20251001', label: 'Haiku 4.5', description: 'Cheapest. For very small PRs.' },
 ];
 
-export async function readAnthropicKey(
-	storageService: IStorageService,
-	encryptionService: IEncryptionService,
-): Promise<string | undefined> {
-	const blob = storageService.get(ANTHROPIC_KEY_STORAGE, StorageScope.APPLICATION);
-	if (!blob) {
-		return undefined;
-	}
-	try {
-		return await encryptionService.decrypt(blob);
-	} catch {
-		// If decryption fails (e.g. keychain unavailable), treat as not configured.
-		return undefined;
-	}
+export async function readAnthropicKey(secretStorageService: ISecretStorageService): Promise<string | undefined> {
+	return secretStorageService.get(ANTHROPIC_KEY_STORAGE);
 }
 
-export async function writeAnthropicKey(
-	storageService: IStorageService,
-	encryptionService: IEncryptionService,
-	key: string,
-): Promise<void> {
+export async function writeAnthropicKey(secretStorageService: ISecretStorageService, key: string): Promise<void> {
 	const trimmed = key.trim();
 	if (!trimmed) {
-		storageService.remove(ANTHROPIC_KEY_STORAGE, StorageScope.APPLICATION);
+		await secretStorageService.delete(ANTHROPIC_KEY_STORAGE);
 		return;
 	}
-	const encrypted = await encryptionService.encrypt(trimmed);
-	storageService.store(ANTHROPIC_KEY_STORAGE, encrypted, StorageScope.APPLICATION, StorageTarget.MACHINE);
+	await secretStorageService.set(ANTHROPIC_KEY_STORAGE, trimmed);
 }
 
-export function clearAnthropicKey(storageService: IStorageService): void {
-	storageService.remove(ANTHROPIC_KEY_STORAGE, StorageScope.APPLICATION);
+export async function clearAnthropicKey(secretStorageService: ISecretStorageService): Promise<void> {
+	await secretStorageService.delete(ANTHROPIC_KEY_STORAGE);
 }
 
