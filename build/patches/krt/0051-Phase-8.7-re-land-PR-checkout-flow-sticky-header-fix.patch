+			this.notificationService.notify({ severity: Severity.Info, message: detail });
+		} catch (err) {
+			const message = isKrtError(err) ? `${err.message} — ${err.hint}` : String(err);
+			this.notificationService.notify({ severity: Severity.Error, message });
