From 04df28ae243be9191bd87cae87955c2e603cdfee Mon Sep 17 00:00:00 2001
From: Kol Crooks <kol.crooks@datadoghq.com>
Date: Mon, 4 May 2026 14:14:22 -0400
Subject: [PATCH] Add KRT status-bar contribution
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Phase 0 of KRT (Kol's Review Tool) — wires a trivial workbench
contribution that registers a status-bar item reading 'KRT'. Proves the
contribution mechanism works end-to-end before any real KRT views land.

Files:
- src/vs/workbench/contrib/krt/browser/krt.contribution.ts (new) — the
  status-bar contribution class plus registration via the workbench
  contributions registry at LifecyclePhase.Restored.
- src/vs/workbench/workbench.common.main.ts — side-effect import so the
  contribution is registered at startup.
- build/lib/i18n.resources.json — register vs/workbench/contrib/krt for
  translation extraction (silences the i18n hygiene reminder).

The copyright header on the new file uses the upstream Microsoft form for
hygiene/eslint compatibility. Phase 11 of KRT's PLAN.md handles the
public-release licensing/branding (LICENSE, NOTICE, custom headers).

See KRT's PLAN.md \xc2\xa74 Phase 0 and docs/phases/phase-00-scaffold.md for
context. The full KRT tree will live under src/vs/workbench/contrib/krt/.
---
 build/lib/i18n.resources.json                 |  4 +++
 .../contrib/krt/browser/krt.contribution.ts   | 35 +++++++++++++++++++
 src/vs/workbench/workbench.common.main.ts     |  3 ++
 3 files changed, 42 insertions(+)
 create mode 100644 src/vs/workbench/contrib/krt/browser/krt.contribution.ts

diff --git a/build/lib/i18n.resources.json b/build/lib/i18n.resources.json
index fa167fffcc9..3843397bacf 100644
--- a/build/lib/i18n.resources.json
+++ b/build/lib/i18n.resources.json
@@ -134,6 +134,10 @@
 			"name": "vs/workbench/contrib/keybindings",
 			"project": "vscode-workbench"
 		},
+		{
+			"name": "vs/workbench/contrib/krt",
+			"project": "vscode-workbench"
+		},
 		{
 			"name": "vs/workbench/contrib/markers",
 			"project": "vscode-workbench"
diff --git a/src/vs/workbench/contrib/krt/browser/krt.contribution.ts b/src/vs/workbench/contrib/krt/browser/krt.contribution.ts
new file mode 100644
index 00000000000..c64338b8f35
--- /dev/null
+++ b/src/vs/workbench/contrib/krt/browser/krt.contribution.ts
@@ -0,0 +1,35 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { localize } from '../../../../nls.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { Extensions as WorkbenchExtensions, IWorkbenchContribution, IWorkbenchContributionsRegistry } from '../../../common/contributions.js';
+import { LifecyclePhase } from '../../../services/lifecycle/common/lifecycle.js';
+import { IStatusbarService, StatusbarAlignment } from '../../../services/statusbar/browser/statusbar.js';
+
+class KrtStatusBarContribution extends Disposable implements IWorkbenchContribution {
+
+	static readonly ID = 'workbench.contrib.krt.statusBar';
+
+	constructor(
+		@IStatusbarService statusbarService: IStatusbarService,
+	) {
+		super();
+		this._register(statusbarService.addEntry(
+			{
+				name: localize('krt.statusBar.name', "KRT"),
+				text: 'KRT',
+				ariaLabel: localize('krt.statusBar.ariaLabel', "KRT"),
+			},
+			KrtStatusBarContribution.ID,
+			StatusbarAlignment.LEFT,
+			1000,
+		));
+	}
+}
+
+Registry.as<IWorkbenchContributionsRegistry>(WorkbenchExtensions.Workbench)
+	.registerWorkbenchContribution(KrtStatusBarContribution, LifecyclePhase.Restored);
diff --git a/src/vs/workbench/workbench.common.main.ts b/src/vs/workbench/workbench.common.main.ts
index 87861d8b823..1c14cdc1d74 100644
--- a/src/vs/workbench/workbench.common.main.ts
+++ b/src/vs/workbench/workbench.common.main.ts
@@ -458,4 +458,7 @@ import './contrib/editTelemetry/browser/editTelemetry.contribution.js';
 // Opener
 import './contrib/opener/browser/opener.contribution.js';
 
+// KRT (Kol's Review Tool) — see PLAN.md and src/vs/workbench/contrib/krt/
+import './contrib/krt/browser/krt.contribution.js';
+
 //#endregion
